#!/bin/bash
# MolmoAct2 (Ai2) 1-Click UserData Script (LIBERO sim, local in-process mode)
# Model:      {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}) — Apache-2.0, public/non-gated
# LeRobot:    allenai/lerobot fork @ {{ lerobot_branch }} ({{ lerobot_commit[:8] if lerobot_commit else 'HEAD' }}) — MolmoAct2 NOT upstream
# Pattern:    SINGLE process — lerobot-eval loads MolmoAct2Policy in-process on the sim GPU
#             (no policy server, unlike rldx/gr00t). Mirrors openvla-oft's local LIBERO eval.
# DTYPE:      fp32 (official LIBERO recipe, use_amp=false) → needs single GPU >=40GB (g6e/L40S).
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with:
#   python generate.py --vla molmoact2
#
# CloudFormation Fn::Sub placeholders (resolved at deploy time):
#   ${S3BucketName}       — results S3 bucket
#   ${SnsTopicArn}        — completion notification SNS topic
#   ${StackName}          — CDK stack name
#   ${WaitConditionUrl}   — CFN WaitConditionHandle presigned URL
#   ${Region}             — deployment region
#   ${AutoTerminate}      — "true" to auto-terminate EC2 after completion

set -euo pipefail

LEROBOT_DIR=/home/ubuntu/lerobot
HF_CACHE_DIR=/home/ubuntu/.cache/huggingface
EVAL_BASE_DIR=/tmp/molmoact2-eval
VIDEO_BASE_DIR=/tmp/molmoact2-videos
RUN_ID=$(date '+%Y-%m-%d-%H%M')

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

# UserData runs as root; HOME must be set so uv puts caches in a stable place.
export HOME=/root
export HF_HOME="${HF_CACHE_DIR}"
# uv installs into ~/.local/bin
export PATH="/root/.local/bin:${PATH}"

log() { echo "[MOLMOACT2] $(date '+%H:%M:%S') $*" | tee -a /var/log/molmoact2-userdata.log; }

cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/molmoact2-userdata.log \
        && log "cfn_signal $_status sent" \
        || log "[warn] cfn_signal send failed (continuing)"
}

die() {
    log "ERROR: $*"
    # Best-effort: dump diagnostics to S3 before CFN rollback eats the instance
    if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
        local _diag_prefix="s3://${S3_BUCKET}/${RUN_ID:-unknown-run}/diag-fail"
        log "  Uploading /tmp/molmoact2_*.log to ${_diag_prefix}..."
        aws s3 cp /var/log/molmoact2-userdata.log "${_diag_prefix}/userdata.log" --region "$REGION" 2>/dev/null || true
        for _f in /tmp/molmoact2_*.log; do
            [ -f "$_f" ] || continue
            aws s3 cp "$_f" "${_diag_prefix}/$(basename "$_f")" --region "$REGION" 2>/dev/null || true
        done
    fi
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

log "===== MolmoAct2 UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/7] System dependencies ──────────────────────────────────────
log "[1/7] Installing system packages..."
export DEBIAN_FRONTEND=noninteractive

systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/molmoact2_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/molmoact2_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    git git-lfs curl ca-certificates awscli jq \
    libgl1-mesa-glx libegl1 libgles2 \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    ffmpeg build-essential \
    2>&1 | tee /tmp/molmoact2_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

# ── [1.5/7] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/7] Setting up CloudWatch Logs agent..."
# Log group MUST match the stack's IAM grant (/${vla}/* → /molmoact2/*).
CW_LOG_GROUP="/molmoact2/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/molmoact2-userdata.log",
            "log_group_name": "/molmoact2/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/molmoact2_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs local only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs local only"
fi

# ── [2/7] NVIDIA driver check + fp32 VRAM floor guard ───────────────
log "[2/7] Checking GPU driver..."
nvidia-smi -L 2>&1 | tee /tmp/molmoact2_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI (continuing with EGL headless)"
# fp32 5B inference peaks well over 24GB. Single GPU must have >=40GB or the eval OOMs at load.
# This is a fail-fast liveness gate ([[feedback_job_running_not_progressing]]) — without it an
# undersized GPU silently burns the full creationpolicy_timeout before WaitCondition times out.
GPU_MEM_MIB=$(nvidia-smi --query-gpu=memory.total --format=csv,noheader,nounits 2>/dev/null | head -1 | tr -d ' ' || echo "0")
log "  GPU0 memory: ${GPU_MEM_MIB} MiB"
if [ "${GPU_MEM_MIB:-0}" -lt 40000 ]; then
    die "fp32 MolmoAct2 (5B) needs a single GPU >=40GB; GPU0 has ${GPU_MEM_MIB} MiB. Use g6e.* (L40S 48GB). See models/molmoact2.yaml dtype note."
fi
# Host-RAM floor: fp32 from_pretrained holds ~20GB resident weights + page-cache for the 22GB
# safetensors during load. g6e.xlarge (32 GiB RAM, no swap) THRASHES — GPU stuck 0% for 24min,
# never receives weights (RUN_ID 1856). Same fail-fast liveness gate as the VRAM floor: catch the
# undersized host BEFORE the 20-30min uv sync + 22GB DL rather than at WaitCondition timeout.
# 49000 MiB floor passes g6e.2xlarge (64 GiB) / 4xlarge (128 GiB), rejects xlarge (32 GiB).
HOST_MEM_MIB=$(awk '/MemTotal/ {printf "%d", $2/1024}' /proc/meminfo 2>/dev/null || echo "0")
log "  Host RAM: ${HOST_MEM_MIB} MiB"
if [ "${HOST_MEM_MIB:-0}" -lt 49000 ]; then
    die "fp32 MolmoAct2 (5B) needs >=64GiB host RAM (g6e.2xlarge+); host has ${HOST_MEM_MIB} MiB. g6e.xlarge (32GiB) thrashes the ckpt load. See models/molmoact2.yaml instance note."
fi

# ── [3/7] uv install + LeRobot fork clone (pinned) ──────────────────
log "[3/7] Installing uv (DLAMI does not pre-install)..."
if ! command -v uv >/dev/null 2>&1; then
    curl -LsSf https://astral.sh/uv/install.sh | sh 2>&1 | tee /tmp/molmoact2_uv_install.log \
        || die "uv install failed"
fi
log "  $(uv --version)"

log "[3/7] Cloning allenai/lerobot @ {{ lerobot_branch }} ({{ lerobot_commit[:8] if lerobot_commit else 'HEAD' }})..."
if [ ! -d "${LEROBOT_DIR}" ]; then
    git clone --branch {{ lerobot_branch }} {{ lerobot_repo }} "${LEROBOT_DIR}" \
        2>&1 | tee /tmp/molmoact2_clone.log \
        || die "lerobot fork clone failed"
{%- if lerobot_commit %}
    git -C "${LEROBOT_DIR}" checkout "{{ lerobot_commit }}" \
        || die "lerobot fork: checkout pinned commit {{ lerobot_commit[:8] }} failed"
{%- endif %}
fi
ACTUAL_COMMIT=$(git -C "${LEROBOT_DIR}" rev-parse HEAD)
log "  lerobot fork commit: ${ACTUAL_COMMIT}"
{%- if lerobot_commit %}
if [ "${ACTUAL_COMMIT}" != "{{ lerobot_commit }}" ]; then
    die "lerobot fork commit mismatch: expected {{ lerobot_commit }}, got ${ACTUAL_COMMIT}"
fi
{%- endif %}

# ── [4/7] uv sync (fork source install) — molmoact2 policy + libero env extras ──
# MolmoAct2 is NOT pip-installable (not upstream); install the fork from source via uv.
# uv.lock at repo root → reproducible. --extra molmoact2 (transformers/peft/scipy) +
# --extra libero (hf-libero, the LIBERO sim env). ~20-30min on a fresh instance.
# --python {{ python_version }}: the fork targets 3.12/3.13 only (requires-python ">=3.12", no
# upper bound). Without this pin uv grabs 3.14, whose argparse rejects draccus' `type=str | None`
# (lerobot-eval CLI parse crashes: "str | None is not callable"). Pin to the tested interpreter.
log "[4/7] uv sync --locked --python {{ python_version }} --extra molmoact2 --extra libero (fork source build, ~20-30min)..."
cd "${LEROBOT_DIR}"
uv sync --locked --python {{ python_version }} --extra molmoact2 --extra libero 2>&1 | tee /tmp/molmoact2_uv_sync.log \
    || die "uv sync failed (see /tmp/molmoact2_uv_sync.log)"
# Confirm the venv interpreter is the pinned version (fail fast if uv ignored --python).
VENV_PY=$(uv run --active python -c 'import sys; print("%d.%d" % sys.version_info[:2])' 2>/dev/null)
log "  venv python: ${VENV_PY}"
if [ "${VENV_PY}" != "{{ python_version }}" ]; then
    die "venv python ${VENV_PY} != pinned {{ python_version }} (uv ignored --python; draccus needs 3.12/3.13)"
fi

# LIBERO seeds a config on first import via input() → seed it non-interactively FIRST.
# libero/libero/__init__.py prompts (and EOFErrors headless) only when ~/.libero/config.yaml
# is absent; answering 'N' writes the config with default paths, so every later import
# (the venv check below AND the [6/7] lerobot-eval subprocess) skips the prompt. HOME=/root
# is exported once at top, so the config persists across all uv-run invocations.
# MUST precede any `from lerobot.envs.libero import ...` (that import transitively hits the prompt).
log "[4/7] Seeding LIBERO config (suppress first-import interactive prompt)..."
uv run --active python -c "
import builtins
builtins.input = lambda *a, **k: 'N'
from libero.libero import benchmark, get_libero_path
benchmark.get_benchmark_dict()
import os
cfg = os.path.expanduser('~/.libero/config.yaml')
assert os.path.exists(cfg), 'LIBERO config not written: ' + cfg
print('LIBERO config seeded at', cfg)
" 2>&1 | tee /tmp/molmoact2_libero_seed.log \
    || die "LIBERO config seed failed (see /tmp/molmoact2_libero_seed.log)"

# Verify the venv: lerobot-eval entrypoint + MolmoAct2Policy import + torch sees the GPU,
# BEFORE downloading the 22GB checkpoint. Fail fast on a broken install.
# LiberoEnv import now resolves silently (config seeded above).
log "[4/7] Verifying venv (lerobot-eval entrypoint, MolmoAct2 imports, torch CUDA)..."
uv run --active python -c "
import torch
print('torch:', torch.__version__, 'cuda available:', torch.cuda.is_available())
assert torch.cuda.is_available(), 'CUDA not visible to torch'
from lerobot.policies.molmoact2 import MolmoAct2Policy, MolmoAct2Config, make_molmoact2_pre_post_processors
print('MolmoAct2Policy:', MolmoAct2Policy.__name__)
from lerobot.envs.libero import LiberoEnv  # libero extra installed
print('LiberoEnv import OK')
" 2>&1 | tee /tmp/molmoact2_import_check.log \
    || die "venv import/CUDA check failed (see /tmp/molmoact2_import_check.log)"
# The lerobot-eval console script must resolve in the venv.
uv run --active which lerobot-eval 2>&1 | tee -a /tmp/molmoact2_import_check.log \
    || die "lerobot-eval entrypoint not found in venv"

# ── [5/7] Pre-download MolmoAct2-LIBERO checkpoint (public, no token) ──
mkdir -p "${HF_CACHE_DIR}"
{% if hf_model_revision %}
log "[5/7] Pre-downloading {{ hf_repo }} (rev {{ hf_model_revision[:8] }}, ~22GB)..."
uv run --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}', revision='{{ hf_model_revision }}')
print('checkpoint downloaded to:', path)
" 2>&1 | tee /tmp/molmoact2_hf_download.log \
    || die "HF checkpoint download failed (see /tmp/molmoact2_hf_download.log)"
{% else %}
log "[5/7] HF revision not pinned — lerobot-eval will download {{ hf_repo }} on demand (~22GB)..."
uv run --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}')
print('checkpoint downloaded to:', path)
" 2>&1 | tee /tmp/molmoact2_hf_download.log \
    || die "HF checkpoint download failed"
{% endif %}

# ── [6/7] Run LIBERO eval per task entry (in-process lerobot-eval) ──
# Headless MuJoCo render needs EGL.
export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1
mkdir -p "${EVAL_BASE_DIR}" "${VIDEO_BASE_DIR}"

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    SUITE=$(echo "$TASK" | jq -r '.suite')
    N_EPISODES=$(echo "$TASK" | jq -r '.n_episodes')
    SEED=$(echo "$TASK" | jq -r '.seed // 1000')
    DESCRIPTION=$(echo "$TASK" | jq -r '.description // ""')
    # task_ids: optional JSON array restricting which suite tasks to run (pipe-proof cap).
    # Empty/absent → omit the flag → lerobot-eval runs ALL tasks in the suite.
    TASK_IDS_ARR=$(echo "$TASK" | jq -c '.task_ids // empty')

    OUT_DIR="${EVAL_BASE_DIR}/task-${TASK_IDX}"
    rm -rf "${OUT_DIR}"
    mkdir -p "${OUT_DIR}"

    log "[6/7] Task $((TASK_IDX+1))/${TASK_COUNT}: suite=${SUITE}, n_episodes=${N_EPISODES}/task, task_ids=${TASK_IDS_ARR:-ALL}"
    touch /tmp/molmoact2_task${TASK_IDX}_start.marker

    # Build the lerobot-eval command (official LIBERO recipe, A0-verified):
    #   --policy.type=molmoact2 + checkpoint_path (HF repo id) + fp32 + use_amp=false + norm_tag.
    #   --env.type=libero + task(suite) + camera_name_mapping (match ckpt image_keys).
    #   --eval.n_episodes is PER TASK; lerobot-eval iterates all suite tasks (or task_ids subset).
    # Optional --env.task_ids restricts the suite to a subset for an affordable pipe-proof.
    EVAL_ARGS=(
        --policy.type=molmoact2
        --policy.checkpoint_path={{ hf_repo }}
        --policy.norm_tag={{ norm_tag }}
        --policy.inference_action_mode={{ inference_action_mode }}
        --policy.model_dtype={{ model_dtype }}
        --policy.use_amp={{ 'true' if use_amp else 'false' }}
        --policy.enable_inference_cuda_graph={{ 'true' if enable_inference_cuda_graph else 'false' }}
        --policy.device=cuda
        --env.type=libero
        --env.task="${SUITE}"
        --env.camera_name_mapping='{{ camera_name_mapping }}'
        --eval.batch_size=1
        --eval.n_episodes="${N_EPISODES}"
        --output_dir="${OUT_DIR}"
        --seed="${SEED}"
    )
    if [ -n "${TASK_IDS_ARR}" ]; then
        EVAL_ARGS+=( --env.task_ids="${TASK_IDS_ARR}" )
    fi

    log "  Checkpoint: {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}), dtype={{ model_dtype }}, norm_tag={{ norm_tag }}"

    # Disable BOTH errexit AND the ERR trap around the eval: a non-zero exit must NOT auto-fire
    # cfn_signal here — capture EVAL_EXIT and fail explicitly via die() below, AFTER S3 diag upload.
    set +e
    trap - ERR
    (
        cd "${LEROBOT_DIR}"
        uv run --active lerobot-eval "${EVAL_ARGS[@]}"
    ) 2>&1 | tee "/tmp/molmoact2_task${TASK_IDX}.log"
    EVAL_EXIT=${PIPESTATUS[0]}
    set -e
    trap '_trap_handler' ERR
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        log "  [error] Task ${TASK_IDX} eval exit=${EVAL_EXIT} — will fail after uploading diagnostics"
    fi

    # lerobot-eval writes ${OUT_DIR}/videos/{suite}_{task_id}/eval_episode_N.mp4 and eval_info.json.
    # Collect every mp4 into a flat per-task video dir for upload.
    VIDEO_DIR="${VIDEO_BASE_DIR}/task-${TASK_IDX}"
    mkdir -p "$VIDEO_DIR"
    find "${OUT_DIR}/videos" -name "*.mp4" -newer /tmp/molmoact2_task${TASK_IDX}_start.marker \
        -exec cp {} "${VIDEO_DIR}/" \; 2>/dev/null || true
    VIDEO_COUNT=$(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | wc -l)
    log "  Videos collected: ${VIDEO_COUNT}"

    # Parse success rate from eval_info.json (info["overall"]["pc_success"], 0-100).
    SR="unknown"
    INFO_JSON="${OUT_DIR}/eval_info.json"
    if [ -f "${INFO_JSON}" ]; then
        SR=$(jq -r '.overall.pc_success // empty' "${INFO_JSON}" 2>/dev/null || echo "")
        [ -n "${SR}" ] && SR=$(awk -v p="${SR}" 'BEGIN{printf "%.3f", p/100}') || SR="unknown"
    fi
    log "  success_rate=${SR} (pc_success/100)"

    {
        echo "model: molmoact2"
        echo "checkpoint: {{ hf_repo }}@{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
        echo "lerobot_fork: allenai/lerobot@{{ lerobot_commit[:8] if lerobot_commit else 'HEAD' }} ({{ lerobot_branch }})"
        echo "dtype: {{ model_dtype }} (use_amp={{ 'true' if use_amp else 'false' }})"
        echo "norm_tag: {{ norm_tag }}"
        echo "suite: ${SUITE}"
        echo "task_ids: ${TASK_IDS_ARR:-ALL}"
        echo "n_episodes_per_task: ${N_EPISODES}"
        echo "success_rate: ${SR}"
        echo "description: ${DESCRIPTION}"
    } > "/tmp/molmoact2_task${TASK_IDX}_summary.txt"

    # S3 upload (videos + per-video context + eval_info.json + log + summary)
    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"
    UPLOAD_COUNT=0
    while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
        [ -f "$mp4_file" ] || continue
        fname=$(basename "$mp4_file")
        base="${fname%.mp4}"

        txt_file="/tmp/molmoact2_ctx_task${TASK_IDX}_ep${UPLOAD_COUNT}.txt"
        {
            echo "=== MolmoAct2 Simulation Context ==="
            printf "Video:      %s\n"  "${fname}"
            printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
            echo ""
            echo "--- Environment ---"
            printf "Suite:      %s\n"  "${SUITE}"
            printf "Robot:      Franka Panda 7-DOF (LIBERO)\n"
            echo ""
            echo "--- Model ---"
            printf "Checkpoint: %s (rev %s)\n" "{{ hf_repo }}" "{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
            printf "LeRobot:    allenai/lerobot@%s (%s — fork, NOT upstream)\n" "{{ lerobot_commit[:8] if lerobot_commit else 'HEAD' }}" "{{ lerobot_branch }}"
            printf "Policy:     MolmoAct2 (Ai2 Action Reasoning Model, 5B, flow-matching action expert)\n"
            printf "Inference:  %s, norm_tag=%s, %s\n" "{{ model_dtype }}" "{{ norm_tag }}" "{{ inference_action_mode }}"
            printf "License:    Apache-2.0\n"
            echo ""
            echo "--- Rollout ---"
            printf "run_id:        %s\n"  "${RUN_ID}"
            printf "task_idx:      %s\n"  "${TASK_IDX}"
            printf "suite_success: %s (suite avg, pc_success/100)\n" "${SR}"
            echo ""
            echo "--- Infrastructure ---"
            printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
            printf "Region:   %s\n"  "${REGION}"
            printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
        } > "$txt_file"

        if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/${fname}" \
            --region "$REGION" 2>&1 | tee -a /var/log/molmoact2-userdata.log; then
            UPLOAD_COUNT=$((UPLOAD_COUNT+1))
            aws s3 cp "$txt_file" "${S3_TASK_PREFIX}/videos/${base}.txt" \
                --region "$REGION" 2>/dev/null || true
        else
            log "  [warn] Upload failed: $fname"
        fi
    done < <(find "$VIDEO_DIR" -name "*.mp4" 2>/dev/null | sort)
    log "  Videos uploaded: ${UPLOAD_COUNT}/${VIDEO_COUNT}"

    aws s3 cp "/tmp/molmoact2_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/eval.log" --region "$REGION" || true
    [ -f "${INFO_JSON}" ] && \
        aws s3 cp "${INFO_JSON}" \
        "${S3_TASK_PREFIX}/eval_info.json" --region "$REGION" || true
    [ -f "/tmp/molmoact2_task${TASK_IDX}_summary.txt" ] && \
        aws s3 cp "/tmp/molmoact2_task${TASK_IDX}_summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

    SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${SUITE} — success_rate=${SR} (${N_EPISODES} ep/task, task_ids=${TASK_IDS_ARR:-ALL})"
    log "  Task $((TASK_IDX+1)) done"

    # Hard-fail after S3 upload if eval crashed or produced no rollouts.
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        die "Task ${TASK_IDX} eval failed (exit=${EVAL_EXIT}) — see s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}/eval.log"
    fi
    if [ "${VIDEO_COUNT}" -eq 0 ]; then
        die "Task ${TASK_IDX} produced 0 rollouts — eval likely short-circuited (see s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}/eval.log)"
    fi
done

# ── [7/7] SNS notification + cfn-signal ──────────────────────────
log "[7/7] Sending SNS notification..."

SNS_MESSAGE="[${STACK_NAME}] MolmoAct2 simulation complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

Model: MolmoAct2 (Ai2 — 5B Action Reasoning Model, flow-matching action expert)
Checkpoint: {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}), {{ model_dtype }}, norm_tag={{ norm_tag }}
LeRobot: allenai/lerobot@{{ lerobot_commit[:8] if lerobot_commit else 'HEAD' }} ({{ lerobot_branch }} — fork, NOT upstream)
License: Apache-2.0
Simulation: LIBERO (robosuite + MuJoCo, headless EGL)
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./molmoact2-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py --vla molmoact2"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "MolmoAct2 simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "[7/7] Sending cfn-signal..."
cfn_signal 0

if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== MolmoAct2 UserData complete ====="
