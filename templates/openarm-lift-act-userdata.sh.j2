#!/bin/bash
# OpenArm-Lift-ACT 1-Click UserData Script — DEMO COLLECTION ONLY (Phase 1b cost part)
#   OpenArm UNIMANUAL Lift-Cube × ACT overlay × enactic/openarm_isaac_lab (Isaac Lab 2.3)
# Pattern:    NGC Isaac Lab container (IsaacSim 5.1 + Lab 2.3 + Py3.11) runs everything. A teleop-free
#             scripted pick-lift state machine (collect_demos_sm.py) drives the ACT env overlay and
#             exports SUCCESSFUL lift demos to a single HDF5. NO LeRobot, NO checkpoint download, NO
#             rollout video — the only deliverable is the HDF5 (+ logs) uploaded to S3.
# Why so much leaner than openarm-isaac: collection needs only `pip install -e source/openarm`
#             (warp + h5py + RecorderManager ship in the image). The openarm-isaac py3.11 LeRobot
#             patch + gated PaliGemma tokenizer blockers DO NOT apply here.
# FIRST RUN GOAL: validate C1–C4 (does the SM actually grasp+lift?). Read the exported success count
#             from the container log — near-0 ⇒ tune _TCP_OFFSET / _DOWN_QUAT / thresholds in the
#             overlay before scaling num_demos up.
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with:
#   python generate.py --vla openarm-lift-act
#
# Bootstrap-exported env vars (set by cdk/lib/vla-simulator-stack.ts via Fn::Sub):
#   ${S3BucketName} ${SnsTopicArn} ${StackName} ${WaitConditionUrl} ${Region} ${AutoTerminate}

set -euo pipefail

HOST_ASSETS_DIR=/home/ubuntu/openarm-lift-act-assets    # the 2 python files (mounted into container)
HOST_OUT_DIR=/home/ubuntu/openarm-lift-act-out          # HDF5 dataset + logs (mounted into container)
CONTAINER_NAME=openarm-lift-act
ISAAC_LAB_IMAGE="{{ isaac_lab_image }}"
RUN_ID=$(date '+%Y-%m-%d-%H%M')

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

log() { echo "[OpenArm-Lift-ACT] $(date '+%H:%M:%S') $*" | tee -a /var/log/openarm-lift-act-userdata.log; }

cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/openarm-lift-act-userdata.log \
        && log "cfn_signal $_status sent" \
        || log "[warn] cfn_signal send failed (continuing)"
}

die() {
    log "ERROR: $*"
    # Stop the background progress streamer (PRE-FIX ②) so it can't race the diag-fail upload below.
    [ -n "${_STREAM_PID:-}" ] && kill "$_STREAM_PID" 2>/dev/null || true
    # Best-effort: dump diagnostics to S3 before CFN rollback eats the instance.
    if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
        local _diag="s3://${S3_BUCKET}/${RUN_ID:-unknown-run}/diag-fail"
        log "  Uploading logs to ${_diag}..."
        aws s3 cp /var/log/openarm-lift-act-userdata.log "${_diag}/userdata.log" --region "$REGION" 2>/dev/null || true
        for _f in /tmp/openarm_*.log "${HOST_OUT_DIR}"/*.log; do
            [ -f "$_f" ] || continue
            aws s3 cp "$_f" "${_diag}/$(basename "$_f")" --region "$REGION" 2>/dev/null || true
        done
        docker logs "$CONTAINER_NAME" > /tmp/openarm_container.log 2>&1 || true
        [ -f /tmp/openarm_container.log ] && \
            aws s3 cp /tmp/openarm_container.log "${_diag}/container.log" --region "$REGION" 2>/dev/null || true
    fi
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

log "===== OpenArm-Lift-ACT UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [0/6] ECC guard: L40S/L4 require ECC disabled for Omniverse/Isaac Sim ──
# Identical mechanism to the openarm-isaac target (proven across 6th–9th deploys): NVIDIA NGC #331666
# — Omniverse/Isaac Sim crash at first-render when GPU ECC is Enabled (AWS L40S/L4 ship ECC=Enabled).
# ECC mode is unreadable at early boot (inforom read needs an initialized GPU; a short-lived
# nvidia-smi query returns "Unknown"), so we do NOT probe — we wait for the driver then UNCONDITIONALLY
# `nvidia-smi -e 0` + reboot on boot-1. A systemd oneshot (openarm-lift-act-resume.service) re-runs the
# self-copied script on boot-2, where the ecc-done marker is present and the pipeline runs once.
# Pattern: knowledge/tools/userdata-2stage-reboot-pattern.md. See the openarm-isaac template for the
# full deploy-by-deploy rationale this is distilled from.
#
# Marker files:
#   /var/lib/openarm-lift-act/ecc-done       — ECC disabled in boot-1, prevents a re-disable loop
#   /var/lib/openarm-lift-act/userdata-done  — full script completed, blocks resume on future reboots
mkdir -p /var/lib/openarm-lift-act

if [ ! -f /var/lib/openarm-lift-act/userdata-done ]; then
    if [ ! -f /var/lib/openarm-lift-act/ecc-done ]; then
        # ── BOOT-1: disable ECC + reboot (no read; enforce desired state) ──

        # ── Stage A: wait for the NVIDIA driver to enumerate GPUs (needed for nvidia-smi -e 0) ──
        DRIVER_MAX_ATTEMPTS=60       # 60 × 5s = up to 300s for kernel module + GSP firmware
        _driver_ready=false
        for _attempt in $(seq 1 "$DRIVER_MAX_ATTEMPTS"); do
            if nvidia-smi -L 2>/dev/null | grep -q '^GPU 0:'; then
                log "[0/6] NVIDIA driver ready: $(nvidia-smi -L 2>/dev/null | wc -l) GPU(s) enumerated (attempt ${_attempt}/${DRIVER_MAX_ATTEMPTS})"
                _driver_ready=true
                break
            fi
            log "[0/6] nvidia-smi -L not listing GPUs yet — driver loading, retry ${_attempt}/${DRIVER_MAX_ATTEMPTS} in 5s"
            sleep 5
        done
        if [ "$_driver_ready" != true ]; then
            die "[0/6] nvidia-smi -L never listed a GPU after ${DRIVER_MAX_ATTEMPTS} attempts — NVIDIA driver did not come up; aborting"
        fi

        log "[0/6] ECC read intentionally skipped (unreadable at boot). Disabling ECC unconditionally + reboot. Boot-2 resumes via openarm-lift-act-resume.service."

        # Copy the rendered main script to a stable path so boot-2 can re-run it.
        USERDATA_SRC=$(readlink -f "$0" 2>/dev/null || echo /var/lib/cloud/instance/scripts/part-001)
        if [ ! -f "$USERDATA_SRC" ]; then
            USERDATA_SRC=/var/lib/cloud/instance/scripts/part-001
        fi
        if [ ! -f "$USERDATA_SRC" ]; then
            die "[0/6] user-data source not found (tried \$0 and /var/lib/cloud/instance/scripts/part-001) — ECC 2-stage aborted"
        fi
        cp "$USERDATA_SRC" /var/lib/openarm-lift-act/userdata-resume.sh
        chmod +x /var/lib/openarm-lift-act/userdata-resume.sh
        log "[0/6] user-data source copied to /var/lib/openarm-lift-act/userdata-resume.sh (src: ${USERDATA_SRC})"

        # Persist the CFN-injected env vars that the cloud-init wrapper exports (boot-2's systemd
        # unit has none of them; without this EnvironmentFile the resume script dies under set -u
        # on the first "${S3BucketName}" reference).
        awk '/^export /' /var/lib/cloud/instance/scripts/part-001 \
            | sed 's/^export //' \
            > /var/lib/openarm-lift-act/userdata-env
        chmod 600 /var/lib/openarm-lift-act/userdata-env
        log "[0/6] wrote EnvironmentFile /var/lib/openarm-lift-act/userdata-env ($(wc -l < /var/lib/openarm-lift-act/userdata-env) vars)"

        # Register the systemd oneshot unit for boot-2 resume. Do NOT add After=cloud-final.service
        # (creates an ordering cycle with our WantedBy → systemd drops the start job).
        cat > /etc/systemd/system/openarm-lift-act-resume.service <<'UNIT'
[Unit]
Description=OpenArm-Lift-ACT UserData resume (post-ECC-disable reboot)
After=network-online.target docker.service
Wants=network-online.target
ConditionPathExists=/var/lib/openarm-lift-act/ecc-done
ConditionPathExists=!/var/lib/openarm-lift-act/userdata-done

[Service]
Type=oneshot
EnvironmentFile=/var/lib/openarm-lift-act/userdata-env
ExecStart=/var/lib/openarm-lift-act/userdata-resume.sh
StandardOutput=journal
StandardError=journal
RemainAfterExit=yes
# TimeoutStartSec was 7200 (2h) — too short once num_demos scaled up. run9 (50 demos) ran >2h
# (docker pull + ~2h collection), so systemd SIGTERM'd this ExecStart at exactly the 2h mark,
# killing the post-collection HDF5-upload + cfn-signal steps (which run AFTER the `docker run`
# line in resume.sh). The docker container is owned by dockerd, so collection itself continued
# to 50/50 — but the result was never uploaded/signaled (had to be rescued manually via SSM).
# The real run bounds are max_steps + the WaitCondition PT240M; this service must never time out
# first. `infinity` defers entirely to those bounds.
TimeoutStartSec=infinity

[Install]
WantedBy=multi-user.target
UNIT
        systemctl daemon-reload
        systemctl enable openarm-lift-act-resume.service 2>&1 | tee -a /var/log/openarm-lift-act-userdata.log \
            || die "[0/6] systemctl enable openarm-lift-act-resume.service failed"

        # Disable ECC (pending-mode WRITE to the inforom; persists across reboots on L40S/L4). Unlike
        # a read this does not need the GPU initialized. fail-loud: surface a write failure now.
        nvidia-smi -e 0 2>&1 | tee -a /var/log/openarm-lift-act-userdata.log || die "[0/6] nvidia-smi -e 0 failed"
        touch /var/lib/openarm-lift-act/ecc-done

        # Ship the boot-1 log before reboot for traceability (boot-2 gets a fresh RUN_ID).
        if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
            aws s3 cp /var/log/openarm-lift-act-userdata.log \
                "s3://${S3_BUCKET}/${RUN_ID}-boot1/logs/userdata.log" \
                --region "$REGION" 2>&1 | tee -a /var/log/openarm-lift-act-userdata.log || true
        fi

        log "[0/6] Rebooting now. Boot-2 will get a new RUN_ID; WaitCondition stays open."
        systemctl reboot
        # Block until the reboot fires so the ERR trap does not prematurely signal FAILURE.
        sleep 120
        exit 0
    else
        # ── BOOT-2: ecc-done marker present → ECC disabled on boot-1; resume pipeline ──
        log "[0/6] ecc-done marker present — post-reboot resume, ECC already disabled; proceeding to pipeline"
    fi
fi

# ── [1/6] System dependencies ──────────────────────────────────────
log "[1/6] Installing system packages (docker + nvidia-container-toolkit are pre-installed on DLAMI)..."
export DEBIAN_FRONTEND=noninteractive

# Ubuntu 22.04 DLAMI reboots ~14-17min after boot. Root cause: cloud-init's modules:final
# runs package_update_upgrade_install concurrently with userdata → dpkg triggers fire
# (initramfs-tools, microcode-initrd) → systemd Reexecutes → needrestart DPkg::Post-Invoke
# hook schedules a reboot. Kill ALL of these mechanisms:
#
# 1. Prevent cloud-init from running package upgrades
cat > /etc/cloud/cloud.cfg.d/99_no_upgrade.cfg << 'EOF'
package_update: false
package_upgrade: false
package_reboot_if_required: false
EOF

# 2. Stop unattended-upgrades and kill any running apt-get
systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl mask unattended-upgrades 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
pkill -9 -f "apt.systemd.daily" 2>/dev/null || true

# 3. Suppress needrestart completely — remove DPkg::Post-Invoke hook
export NEEDRESTART_SUSPEND=1
export NEEDRESTART_MODE=l
rm -f /etc/apt/apt.conf.d/99needrestart 2>/dev/null || true
rm -f /etc/dpkg/dpkg.cfg.d/needrestart 2>/dev/null || true
if [ -f /etc/needrestart/needrestart.conf ]; then
    sed -i "s/^#\?\$nrconf{restart}.*$/\$nrconf{restart} = 'l';/" /etc/needrestart/needrestart.conf
fi
systemctl stop needrestart 2>/dev/null || true
systemctl disable needrestart 2>/dev/null || true
systemctl mask needrestart 2>/dev/null || true

# 4. Prevent systemd from rebooting even if something requests it
systemctl mask systemd-reboot.service 2>/dev/null || true
mkdir -p /run/systemd/system
cat > /run/systemd/system/systemd-reboot.service.d-override.conf << 'SYSEOF'
[Service]
ExecStart=
ExecStart=/bin/true
SYSEOF

sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/openarm_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/openarm_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    curl ca-certificates awscli jq \
    2>&1 | tee /tmp/openarm_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

command -v docker >/dev/null 2>&1 || die "docker not found — verify DLAMI (Deep Learning AMI ships Docker + NVIDIA Container Toolkit)"
log "  docker: $(docker --version 2>&1 | head -1)"

# ── [1.5/6] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/6] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/openarm-lift-act/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/openarm-lift-act-userdata.log",
            "log_group_name": "/openarm-lift-act/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/openarm_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs local only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs local only"
fi

# ── [1.6/6] Background progress-log streamer ──────────────────────────────────────────────────
# PRE-FIX ② (2026-06-08, after first run ROLLBACK = 4h WaitCondition blackout). The stock template
# uploads logs ONLY at die()/exit. When the first run timed out, the deploy poller (npx cdk deploy)
# died at creds-expiry (~64 min) while the stack/EC2 kept running server-side until the PT240M (4h)
# WaitCondition fired → CFN rollback ate the instance with NOTHING uploaded = total blackout.
# This loop periodically (every 60s) ships the in-flight boot-2 userdata.log + the collection
# container log to a STABLE S3 progress/ path, so even a hard timeout leaves a trail of how far the
# run got (pull → sim boot → collect, last exported count). PRE-FIX ① (max_steps↓) makes a stuck SM
# fail fast and reach die(); ② guarantees visibility even on the paths that never reach die().
PROGRESS_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/progress"
_stream_logs() {
    # Independent of the parent's set -e / ERR trap (runs in a background subshell).
    while true; do
        if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
            aws s3 cp /var/log/openarm-lift-act-userdata.log \
                "${PROGRESS_PREFIX}/userdata.log" --region "$REGION" >/dev/null 2>&1 || true
            [ -f /tmp/openarm_collect.log ] && aws s3 cp /tmp/openarm_collect.log \
                "${PROGRESS_PREFIX}/collect.log" --region "$REGION" >/dev/null 2>&1 || true
        fi
        sleep 60
    done
}
_STREAM_PID=""
if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
    _stream_logs &
    _STREAM_PID=$!
    log "[1.6/6] Background log streamer started (pid ${_STREAM_PID}, every 60s → ${PROGRESS_PREFIX})"
else
    log "[1.6/6] [warn] S3_BUCKET/REGION unset — progress streaming disabled"
fi

# ── [2/6] NVIDIA driver + container runtime check ──────────────────
log "[2/6] Checking GPU driver + NVIDIA container runtime..."
nvidia-smi -L 2>&1 | tee /tmp/openarm_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI"
# --entrypoint required: the isaac-lab image's default entrypoint is runheadless.sh, not a shell.
docker run --rm --gpus all --entrypoint nvidia-smi "$ISAAC_LAB_IMAGE" -L 2>/dev/null \
    || log "[warn] GPU not yet visible to docker (image not pulled yet — re-checked after pull)"

# ── [3/6] Write the 2 Python assets to host (mounted into the container) ──────────────────────
# Only the overlay env_cfg + the collection driver. No LeRobot, no converter, no patch script.
log "[3/6] Writing python assets to ${HOST_ASSETS_DIR}..."
mkdir -p "$HOST_ASSETS_DIR" "$HOST_OUT_DIR"

base64 -d > "${HOST_ASSETS_DIR}/openarm_uni_lift_act_env_cfg.py" << 'OVERLAY_CFG_EOF'
{{ overlay_cfg_b64 -}}
OVERLAY_CFG_EOF

base64 -d > "${HOST_ASSETS_DIR}/collect_demos_sm.py" << 'COLLECT_SM_EOF'
{{ collect_sm_b64 -}}
COLLECT_SM_EOF

log "  assets: $(ls -1 "$HOST_ASSETS_DIR" | tr '\n' ' ')"

# ── [3.5/6] NGC login (Isaac Lab image may require auth) ──────────────────────────────────────
# nvcr.io/nvidia/isaac-lab is published on NGC. Anonymous pull often works; if not, an NGC API key
# at SSM /vla-simulator/ngc-api-key enables docker login. The instance role grants ssm:GetParameter
# on /vla-simulator/* (vla-simulator-stack.ts). No HF token needed — no model download in collection.
log "[3.5/6] Resolving NGC credentials (optional)..."
NGC_API_KEY=$(aws ssm get-parameter --name /vla-simulator/ngc-api-key --with-decryption \
    --query 'Parameter.Value' --output text --region "$REGION" 2>/dev/null || echo "")
if [ -n "$NGC_API_KEY" ] && [ "$NGC_API_KEY" != "None" ]; then
    echo "$NGC_API_KEY" | docker login nvcr.io --username '$oauthtoken' --password-stdin \
        2>&1 | tee /tmp/openarm_ngc_login.log \
        && log "  NGC login OK" \
        || log "[warn] NGC login failed — will attempt anonymous pull"
else
    log "  No NGC API key in SSM (/vla-simulator/ngc-api-key) — attempting anonymous pull"
fi

# ── [4/6] Pull the Isaac Lab container ────────────────────────────────────────────────────────
log "[4/6] Pulling ${ISAAC_LAB_IMAGE} (~20-30 min, large image)..."
PULL_RETRY=0
until docker pull "$ISAAC_LAB_IMAGE" 2>&1 | tee /tmp/openarm_docker_pull.log; do
    PULL_RETRY=$((PULL_RETRY + 1))
    [ $PULL_RETRY -ge 3 ] && die "docker pull ${ISAAC_LAB_IMAGE} failed after 3 retries (NGC auth? see /tmp/openarm_docker_pull.log)"
    log "[warn] docker pull failed (attempt $PULL_RETRY), retrying in 60s..."
    sleep 60
done
log "  image pulled: $(docker image inspect "$ISAAC_LAB_IMAGE" --format '{{ '{{' }}.Id{{ '}}' }}' 2>/dev/null | head -c 19)"

# ── [5/6] Write the in-container build+collect script ─────────────────────────────────────────
# Runs INSIDE the Isaac Lab container (Py3.11 + IsaacSim 5.1 + IsaacLab 2.3 + warp + h5py present):
#   clone openarm_isaac_lab → pip install -e source/openarm → copy ACT overlay into unimanual/lift/config
#   → run collect_demos_sm.py (boots sim, scripted SM collects N successful lift demos → HDF5).
# CONTAINER_PY: the isaaclab-importable python in the NGC image (the `python` alias is absent in a
# non-interactive docker run; use the absolute kit python path). Same as openarm-isaac.
cat > "${HOST_ASSETS_DIR}/container_run.sh" << 'CONTAINER_EOF'
#!/bin/bash
set -euo pipefail
clog() { echo "[container] $(date '+%H:%M:%S') $*"; }

ASSETS=/workspace/assets
OUT=/workspace/out
WORK=/workspace/openarm_isaac_lab
CONTAINER_PY="${CONTAINER_PY:-/workspace/isaaclab/_isaac_sim/python.sh}"

export OPENARM_ISAAC_COMMIT="${OPENARM_ISAAC_COMMIT:?}"
export TASK_ID="${TASK_ID:?}"
export REGISTER_MODULE="${REGISTER_MODULE:?}"
export NUM_DEMOS="${NUM_DEMOS:?}"
export NUM_ENVS="${NUM_ENVS:?}"
export POSITION_THRESHOLD="${POSITION_THRESHOLD:?}"
export MAX_STEPS="${MAX_STEPS:?}"
export CAM_RES="${CAM_RES:?}"
# headless rendering env for Isaac Sim (cameras → RTX render)
export ACCEPT_EULA=Y
export PRIVACY_CONSENT=Y
# Container runs as root; Isaac Sim Kit needs this when launched as root (Isaac Lab's compose sets it).
export OMNI_KIT_ALLOW_ROOT=1

clog "python: $("$CONTAINER_PY" --version 2>&1)"

# 1. clone enactic/openarm_isaac_lab @ pinned commit
if [ ! -d "$WORK" ]; then
    clog "Cloning openarm_isaac_lab @ ${OPENARM_ISAAC_COMMIT}..."
    git clone https://github.com/enactic/openarm_isaac_lab.git "$WORK"
    git -C "$WORK" checkout "$OPENARM_ISAAC_COMMIT"
fi
clog "openarm_isaac_lab commit: $(git -C "$WORK" rev-parse HEAD)"

# 2. install the openarm package (editable; brings the unimanual Lift-Cube env + USD assets).
#    warp / h5py / RecorderManager are already in the Isaac Lab image — nothing else to install.
clog "pip install -e source/openarm ..."
"$CONTAINER_PY" -m pip install -e "$WORK/source/openarm" 2>&1 | tail -20

# 3. drop the ACT overlay into the editable source tree so its gym.register fires on import.
#    Destination = unimanual/lift/config/ (verified to exist alongside joint_pos_env_cfg.py).
OVERLAY_DST="$WORK/source/openarm/openarm/tasks/manager_based/openarm_manipulation/unimanual/lift/config/openarm_uni_lift_act_env_cfg.py"
[ -d "$(dirname "$OVERLAY_DST")" ] || { clog "ERROR: overlay dst dir missing: $(dirname "$OVERLAY_DST")"; exit 1; }
cp "$ASSETS/openarm_uni_lift_act_env_cfg.py" "$OVERLAY_DST"
clog "overlay copied → $OVERLAY_DST"

# 4. run the scripted collection driver (boots Isaac Sim, SM collects successful lift demos → HDF5).
# openarm's stock config modules use repo-rooted absolute imports (`from source.openarm.openarm...`);
# `source` has no __init__.py so it only resolves as a PEP-420 namespace pkg when the repo ROOT is on
# sys.path. collect_demos_sm.py is run from $ASSETS, so export the repo root on PYTHONPATH.
DATASET_FILE="$OUT/openarm_lift_act.hdf5"
clog "Running collect_demos_sm.py (boots Isaac Sim — first boot is slow)..."
export PYTHONPATH="${WORK}:${PYTHONPATH:-}"
cd "$ASSETS"
"$CONTAINER_PY" collect_demos_sm.py \
    --task             "${TASK_ID}" \
    --register_module  "${REGISTER_MODULE}" \
    --dataset_file     "${DATASET_FILE}" \
    --num_demos        "${NUM_DEMOS}" \
    --num_envs         "${NUM_ENVS}" \
    --position_threshold "${POSITION_THRESHOLD}" \
    --max_steps        "${MAX_STEPS}" \
    --cam_res          "${CAM_RES}" \
    --headless
clog "collect_demos_sm.py done — dataset in ${OUT}"
ls -la "$OUT" || true
CONTAINER_EOF
chmod +x "${HOST_ASSETS_DIR}/container_run.sh"

# ── [5.5/6] In-container CUDA-readiness gate ──────────────────────────────────────────────────
# Mirrors openarm-isaac: a host nvidia-smi -L being healthy does NOT guarantee
# torch.cuda.is_available()==True INSIDE the container right after a post-ECC-disable reboot. Gate
# on the container's own view; proceed-anyway on exhaustion (collect_demos_sm.py boots the sim which
# fails fast+cheap if CUDA is genuinely gone → CFN auto-rollback).
log "[5.5/6] Waiting for torch.cuda.is_available() INSIDE the Isaac container..."
CUDA_MAX_ATTEMPTS=6        # 6 × 10s = up to 60s for post-reboot GPU init to settle
_cuda_ready=false
for _attempt in $(seq 1 "$CUDA_MAX_ATTEMPTS"); do
    if docker run --rm --gpus all \
        --entrypoint /workspace/isaaclab/_isaac_sim/python.sh \
        "$ISAAC_LAB_IMAGE" \
        -c 'import torch, sys; sys.exit(0 if torch.cuda.is_available() else 1)' \
        >/dev/null 2>&1; then
        log "[5.5/6] torch.cuda.is_available()=True in container (attempt ${_attempt}/${CUDA_MAX_ATTEMPTS})"
        _cuda_ready=true
        break
    fi
    log "[5.5/6] torch.cuda not ready in container yet — retry ${_attempt}/${CUDA_MAX_ATTEMPTS} in 10s"
    sleep 10
done
if [ "$_cuda_ready" != true ]; then
    log "[warn] [5.5/6] torch.cuda.is_available() still False after ${CUDA_MAX_ATTEMPTS} attempts — proceeding anyway (sim boot fails fast if CUDA is genuinely gone)"
fi

# ── [6/6] Run the collection container ─────────────────────────────────────────────────────────
log "[6/6] Running scripted demo collection in the Isaac Lab container..."
export MUJOCO_GL=egl

NUM_DEMOS="{{ collection.num_demos }}"
NUM_ENVS="{{ collection.num_envs }}"
POSITION_THRESHOLD="{{ collection.position_threshold }}"
MAX_STEPS="{{ collection.max_steps }}"
CAM_RES="{{ collection.cam_res }}"
TASK_ID="{{ task_id }}"
REGISTER_MODULE="{{ register_module }}"
COLLECT_TASK="{{ collection.task }}"

log "  task_id=${TASK_ID}"
log "  num_demos=${NUM_DEMOS} (scaled collection; C1–C4 validated @ run8 2026-06-10-0708)"
log "  num_envs=${NUM_ENVS}, position_threshold=${POSITION_THRESHOLD}, max_steps=${MAX_STEPS}, cam_res=${CAM_RES}px"

docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
set +e
# Override the image ENTRYPOINT (runheadless.sh) with /bin/bash so container_run.sh actually executes
# (same as openarm-isaac + Isaac Lab's compose `entrypoint: bash`).
docker run --name "$CONTAINER_NAME" --gpus all --rm \
    --entrypoint /bin/bash \
    -e "ACCEPT_EULA=Y" -e "PRIVACY_CONSENT=Y" -e "OMNI_KIT_ALLOW_ROOT=1" \
    -e "OPENARM_ISAAC_COMMIT={{ openarm_isaac_commit }}" \
    -e "TASK_ID=${TASK_ID}" \
    -e "REGISTER_MODULE=${REGISTER_MODULE}" \
    -e "NUM_DEMOS=${NUM_DEMOS}" \
    -e "NUM_ENVS=${NUM_ENVS}" \
    -e "POSITION_THRESHOLD=${POSITION_THRESHOLD}" \
    -e "MAX_STEPS=${MAX_STEPS}" \
    -e "CAM_RES=${CAM_RES}" \
    -v "${HOST_ASSETS_DIR}:/workspace/assets" \
    -v "${HOST_OUT_DIR}:/workspace/out" \
    "$ISAAC_LAB_IMAGE" \
    /workspace/assets/container_run.sh \
    2>&1 | tee "/tmp/openarm_collect.log"
COLLECT_EXIT=${PIPESTATUS[0]}
set -e
if [ "${COLLECT_EXIT}" -ne 0 ]; then
    log "  [error] collection container exit=${COLLECT_EXIT} — will fail after uploading diagnostics"
fi

# Count exported demos from the HDF5 (via the container python — host has no h5py).
DATASET_FILE="${HOST_OUT_DIR}/openarm_lift_act.hdf5"
DEMO_COUNT="unknown"
if [ -f "$DATASET_FILE" ]; then
    DEMO_COUNT=$(docker run --rm \
        --entrypoint /workspace/isaaclab/_isaac_sim/python.sh \
        -v "${HOST_OUT_DIR}:/workspace/out" \
        "$ISAAC_LAB_IMAGE" \
        -c 'import h5py,sys
try:
    f=h5py.File("/workspace/out/openarm_lift_act.hdf5","r")
    print(len([k for k in f["data"].keys() if k.startswith("demo_")]))
except Exception as e:
    print("err:%r"%e); sys.exit(0)' 2>/dev/null | tail -1 || echo "unknown")
fi
log "  Exported successful demos in HDF5: ${DEMO_COUNT}"

# ── S3 upload (HDF5 dataset + collection log + context) ────────────────────────────────────────
S3_PREFIX="s3://${S3_BUCKET}/${RUN_ID}"
log "  S3 upload: ${S3_PREFIX}"

{
    echo "=== OpenArm-Lift-ACT Demo Collection Context ==="
    printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
    echo ""
    echo "--- Environment ---"
    printf "Sim:        NVIDIA Isaac Lab 2.3 / Isaac Sim 5.1 (enactic/openarm_isaac_lab @ %s)\n" "{{ openarm_isaac_commit }}"
    printf "Task id:    %s (unimanual Lift-Cube + IK abs action + 2 cameras + dict obs)\n" "${TASK_ID}"
    printf "Robot:      OpenArm unimanual (7-DOF arm + binary gripper)\n"
    printf "Collector:  collect_demos_sm.py — teleop-free scripted pick-lift state machine\n"
    printf "Task instr: %s\n" "${COLLECT_TASK}"
    echo ""
    echo "--- Collection ---"
    printf "run_id:       %s\n"  "${RUN_ID}"
    printf "num_demos:    %s (requested)\n"  "${NUM_DEMOS}"
    printf "demos_in_hdf5: %s (exported, SUCCESS-only)\n"  "${DEMO_COUNT}"
    printf "num_envs:     %s\n"  "${NUM_ENVS}"
    printf "position_threshold: %s\n"  "${POSITION_THRESHOLD}"
    printf "cam_res:      %spx (square; 224=ACT-training, higher=beauty re-render)\n"  "${CAM_RES}"
    printf "NOTE:         SCALED collection for ACT training. C1–C4 (TCP offset / grasp orientation /\n"
    printf "              thresholds / cameras) validated @ run8 (2026-06-10-0708). A demos_in_hdf5\n"
    printf "              well below requested ⇒ collection stalled; check progress/collect.log diag.\n"
    printf "NEXT:         Phase 1c — hdf5_to_lerobot.py converts this HDF5 → LeRobotDataset (off-GPU).\n"
    echo ""
    echo "--- Infrastructure ---"
    printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
    printf "Region:   %s\n"  "${REGION}"
    printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
} > "${HOST_OUT_DIR}/collection_context.txt"

if [ -f "$DATASET_FILE" ]; then
    aws s3 cp "$DATASET_FILE" "${S3_PREFIX}/datasets/openarm_lift_act.hdf5" \
        --region "$REGION" 2>&1 | tee -a /var/log/openarm-lift-act-userdata.log \
        && log "  HDF5 uploaded" \
        || log "  [warn] HDF5 upload failed"
else
    log "  [warn] No HDF5 produced at ${DATASET_FILE}"
fi
aws s3 cp "/tmp/openarm_collect.log"          "${S3_PREFIX}/run.log"                 --region "$REGION" 2>/dev/null || true
aws s3 cp "${HOST_OUT_DIR}/collection_context.txt" "${S3_PREFIX}/collection_context.txt" --region "$REGION" 2>/dev/null || true

# Hard-fail (after S3 upload) if the container crashed or produced no demos.
if [ "${COLLECT_EXIT}" -ne 0 ]; then
    die "Collection container failed (exit=${COLLECT_EXIT}) — see ${S3_PREFIX}/run.log"
fi
if [ ! -f "$DATASET_FILE" ]; then
    die "Collection produced no HDF5 — SM may never have succeeded (check C1–C4 in ${S3_PREFIX}/run.log)"
fi

# Stop the background progress streamer (PRE-FIX ②) now that the canonical run.log/HDF5 are uploaded.
[ -n "${_STREAM_PID:-}" ] && kill "$_STREAM_PID" 2>/dev/null || true

# ── SNS notification + cfn-signal ──────────────────────────────────
log "Sending SNS notification..."
SNS_MESSAGE="[${STACK_NAME}] OpenArm-Lift-ACT demo collection complete (RUN_ID: ${RUN_ID})

Exported successful lift demos: ${DEMO_COUNT} (requested ${NUM_DEMOS})
Task:  ${TASK_ID} (unimanual Lift-Cube × ACT overlay)
Sim:   NVIDIA Isaac Lab 2.3 / Isaac Sim 5.1 (enactic/openarm_isaac_lab)
Note:  Scripted teleop-free collection. FIRST RUN validates C1–C4 — a low demo count means the
       scripted SM is not grasping; tune _TCP_OFFSET / _DOWN_QUAT / thresholds in the overlay.
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./openarm-lift-act-results/${RUN_ID}/ --region ${REGION}

Next (Phase 1c, off-GPU): python hdf5_to_lerobot.py --hdf5 <downloaded>/datasets/openarm_lift_act.hdf5 ...

Teardown:
  python destroy.py --vla openarm-lift-act"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "OpenArm-Lift-ACT collection complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "Sending cfn-signal..."
# Marker blocks openarm-lift-act-resume.service from re-firing on any future reboot.
mkdir -p /var/lib/openarm-lift-act && touch /var/lib/openarm-lift-act/userdata-done
cfn_signal 0

if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== OpenArm-Lift-ACT UserData complete ====="
