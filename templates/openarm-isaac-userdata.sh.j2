#!/bin/bash
# OpenArm-Isaac 1-Click UserData Script
#   π0.5 (LeRobot pi05 `folding_latest`, 16-DOF bimanual) × enactic/openarm_isaac_lab (Isaac Lab 2.3)
# Pattern:    NGC Isaac Lab container (IsaacSim 5.1 + Lab 2.3 + Py3.11) runs everything; LeRobot pi05
#             inference is IN-PROCESS on the sim GPU (no separate policy server). The driver
#             (run_eval.py) bypasses lerobot-eval's HF-Hub env download and calls our local
#             env.py:make_env directly. SUCCESS BAR = PIPE PROOF (motion), not task success.
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with:
#   python generate.py --vla openarm-isaac
#
# Bootstrap-exported env vars (set by cdk/lib/vla-simulator-stack.ts via Fn::Sub):
#   ${S3BucketName} ${SnsTopicArn} ${StackName} ${WaitConditionUrl} ${Region} ${AutoTerminate}

set -euo pipefail

HOST_ASSETS_DIR=/home/ubuntu/openarm-isaac-assets       # the 3 python files (mounted into container)
HOST_OUT_DIR=/home/ubuntu/openarm-isaac-out             # videos + eval_info.json (mounted into container)
HOST_HF_CACHE=/home/ubuntu/.cache/huggingface           # persist HF downloads across container runs
CONTAINER_NAME=openarm-isaac
ISAAC_LAB_IMAGE="{{ isaac_lab_image }}"
RUN_ID=$(date '+%Y-%m-%d-%H%M')

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

log() { echo "[OpenArm-Isaac] $(date '+%H:%M:%S') $*" | tee -a /var/log/openarm-isaac-userdata.log; }

cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/openarm-isaac-userdata.log \
        && log "cfn_signal $_status sent" \
        || log "[warn] cfn_signal send failed (continuing)"
}

die() {
    log "ERROR: $*"
    # Best-effort: dump diagnostics to S3 before CFN rollback eats the instance.
    if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
        local _diag="s3://${S3_BUCKET}/${RUN_ID:-unknown-run}/diag-fail"
        log "  Uploading logs to ${_diag}..."
        aws s3 cp /var/log/openarm-isaac-userdata.log "${_diag}/userdata.log" --region "$REGION" 2>/dev/null || true
        for _f in /tmp/openarm_*.log "${HOST_OUT_DIR}"/*.log; do
            [ -f "$_f" ] || continue
            aws s3 cp "$_f" "${_diag}/$(basename "$_f")" --region "$REGION" 2>/dev/null || true
        done
        docker logs "$CONTAINER_NAME" > /tmp/openarm_container.log 2>&1 || true
        [ -f /tmp/openarm_container.log ] && \
            aws s3 cp /tmp/openarm_container.log "${_diag}/container.log" --region "$REGION" 2>/dev/null || true
    fi
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

log "===== OpenArm-Isaac UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/7] System dependencies ──────────────────────────────────────
log "[1/7] Installing system packages (docker + nvidia-container-toolkit are pre-installed on DLAMI)..."
export DEBIAN_FRONTEND=noninteractive

systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/openarm_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/openarm_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    curl ca-certificates awscli jq \
    2>&1 | tee /tmp/openarm_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

command -v docker >/dev/null 2>&1 || die "docker not found — verify DLAMI (Deep Learning AMI ships Docker + NVIDIA Container Toolkit)"
log "  docker: $(docker --version 2>&1 | head -1)"

# ── [1.5/7] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/7] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/openarm-isaac/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/openarm-isaac-userdata.log",
            "log_group_name": "/openarm-isaac/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/openarm_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs local only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs local only"
fi

# ── [2/7] NVIDIA driver + container runtime check ──────────────────
log "[2/7] Checking GPU driver + NVIDIA container runtime..."
nvidia-smi -L 2>&1 | tee /tmp/openarm_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI"
# Confirm the container runtime can see the GPU before pulling a ~25GB image.
# --entrypoint required: the isaac-lab image's default entrypoint is runheadless.sh, not a shell.
docker run --rm --gpus all --entrypoint nvidia-smi "$ISAAC_LAB_IMAGE" -L 2>/dev/null \
    || log "[warn] GPU not yet visible to docker (image not pulled yet — re-checked after pull)"

# ── [3/7] Write the 3 Python assets to host (mounted into the container) ──────────────────────
log "[3/7] Writing python assets to ${HOST_ASSETS_DIR}..."
mkdir -p "$HOST_ASSETS_DIR" "$HOST_OUT_DIR" "$HOST_HF_CACHE"

base64 -d > "${HOST_ASSETS_DIR}/env.py" << 'ENV_PY_EOF'
{{ env_py_b64 -}}
ENV_PY_EOF

base64 -d > "${HOST_ASSETS_DIR}/run_eval.py" << 'RUN_EVAL_PY_EOF'
{{ run_eval_py_b64 -}}
RUN_EVAL_PY_EOF

base64 -d > "${HOST_ASSETS_DIR}/openarm_bi_vla_env_cfg.py" << 'OVERLAY_CFG_EOF'
{{ overlay_cfg_b64 -}}
OVERLAY_CFG_EOF

log "  assets: $(ls -1 "$HOST_ASSETS_DIR" | tr '\n' ' ')"

# ── [3.5/7] NGC login (Isaac Lab image may require auth) ──────────────────────────────────────
# nvcr.io/nvidia/isaac-lab is published on NGC. Anonymous pull often works; if not, an NGC API key
# stored at SSM /vla-simulator/ngc-api-key enables `docker login`. The instance role grants
# ssm:GetParameter on /vla-simulator/* (see vla-simulator-stack.ts).
log "[3.5/7] Resolving NGC credentials (optional)..."
NGC_API_KEY=$(aws ssm get-parameter --name /vla-simulator/ngc-api-key --with-decryption \
    --query 'Parameter.Value' --output text --region "$REGION" 2>/dev/null || echo "")
if [ -n "$NGC_API_KEY" ] && [ "$NGC_API_KEY" != "None" ]; then
    echo "$NGC_API_KEY" | docker login nvcr.io --username '$oauthtoken' --password-stdin \
        2>&1 | tee /tmp/openarm_ngc_login.log \
        && log "  NGC login OK" \
        || log "[warn] NGC login failed — will attempt anonymous pull"
else
    log "  No NGC API key in SSM (/vla-simulator/ngc-api-key) — attempting anonymous pull"
fi

# ── [4/7] Pull the Isaac Lab container ────────────────────────────────────────────────────────
log "[4/7] Pulling ${ISAAC_LAB_IMAGE} (~20-30 min, large image)..."
PULL_RETRY=0
until docker pull "$ISAAC_LAB_IMAGE" 2>&1 | tee /tmp/openarm_docker_pull.log; do
    PULL_RETRY=$((PULL_RETRY + 1))
    [ $PULL_RETRY -ge 3 ] && die "docker pull ${ISAAC_LAB_IMAGE} failed after 3 retries (NGC auth? see /tmp/openarm_docker_pull.log)"
    log "[warn] docker pull failed (attempt $PULL_RETRY), retrying in 60s..."
    sleep 60
done
log "  image pulled: $(docker image inspect "$ISAAC_LAB_IMAGE" --format '{{ '{{' }}.Id{{ '}}' }}' 2>/dev/null | head -c 19)"

# ── [5/7] Write the in-container build+run script ─────────────────────────────────────────────
# Runs INSIDE the Isaac Lab container (Py3.11 + IsaacSim 5.1 + IsaacLab 2.3 already present):
#   clone openarm_isaac_lab → pip install -e source/openarm → copy overlay into bimanual/reach/config
#   → install lerobot(+pi extras) → download folding_latest → run_eval.py (boots sim, rolls out, video).
# CONTAINER_PY: the isaaclab-importable python in the NGC isaac-lab image. CONFIRMED (deploy run
# 2026-06-04-1726, exit 127 "python: command not found"): the image defines `python` only as a
# bash ALIAS in ~/.bashrc (Dockerfile.base: `alias python=${ISAACLAB_PATH}/_isaac_sim/python.sh`),
# which is NOT loaded in a non-interactive `docker run ... script.sh` shell. The real kit python is
# the absolute path below (ISAACLAB_PATH=/workspace/isaaclab per docker/.env.base; isaaclab.sh -p
# resolves to exactly this _isaac_sim/python.sh). Use the absolute path (single token → keeps the
# "$CONTAINER_PY" call sites intact; avoids the isaaclab.sh wrapper).
cat > "${HOST_ASSETS_DIR}/container_run.sh" << 'CONTAINER_EOF'
#!/bin/bash
set -euo pipefail
clog() { echo "[container] $(date '+%H:%M:%S') $*"; }

ASSETS=/workspace/assets
OUT=/workspace/out
WORK=/workspace/openarm_isaac_lab
# kit python (alias-only in interactive shells; non-interactive docker run needs the abs path).
CONTAINER_PY="${CONTAINER_PY:-/workspace/isaaclab/_isaac_sim/python.sh}"

export HF_HOME=/workspace/hf-cache
export OPENARM_ISAAC_COMMIT="${OPENARM_ISAAC_COMMIT:?}"
export LEROBOT_COMMIT="${LEROBOT_COMMIT:?}"
export HF_REPO="${HF_REPO:?}"
export HF_REVISION="${HF_REVISION:-}"
# headless rendering env for Isaac Sim
export ACCEPT_EULA=Y
export PRIVACY_CONSENT=Y
# The container runs as root; Isaac Sim Kit refuses/misbehaves as root without this. Isaac Lab's
# official docker-compose sets exactly this (docker/docker-compose.yaml: OMNI_KIT_ALLOW_ROOT=1).
# We bypass the image ENTRYPOINT (runheadless.sh) with --entrypoint bash — same as Isaac Lab's
# compose `entrypoint: bash` — so this env is what makes a root-launched AppLauncher boot cleanly.
export OMNI_KIT_ALLOW_ROOT=1

clog "python: $("$CONTAINER_PY" --version 2>&1)"

# 1. clone enactic/openarm_isaac_lab @ pinned commit
if [ ! -d "$WORK" ]; then
    clog "Cloning openarm_isaac_lab @ ${OPENARM_ISAAC_COMMIT}..."
    git clone https://github.com/enactic/openarm_isaac_lab.git "$WORK"
    git -C "$WORK" checkout "$OPENARM_ISAAC_COMMIT"
fi
clog "openarm_isaac_lab commit: $(git -C "$WORK" rev-parse HEAD)"

# 2. install the openarm package (editable; brings the bimanual Reach env + USD assets)
clog "pip install -e source/openarm ..."
"$CONTAINER_PY" -m pip install -e "$WORK/source/openarm" 2>&1 | tail -20

# 3. drop the Phase 2a overlay into the editable source tree so its gym.register fires on import
OVERLAY_DST="$WORK/source/openarm/openarm/tasks/manager_based/openarm_manipulation/bimanual/reach/config/openarm_bi_vla_env_cfg.py"
[ -d "$(dirname "$OVERLAY_DST")" ] || { clog "ERROR: overlay dst dir missing: $(dirname "$OVERLAY_DST")"; exit 1; }
cp "$ASSETS/openarm_bi_vla_env_cfg.py" "$OVERLAY_DST"
clog "overlay copied → $OVERLAY_DST"

# 4. install LeRobot (pi05 inference stack) @ pinned commit, with the pi extra
clog "Installing lerobot[pi] @ ${LEROBOT_COMMIT} ..."
"$CONTAINER_PY" -m pip install "lerobot[pi] @ git+https://github.com/huggingface/lerobot.git@${LEROBOT_COMMIT}" \
    2>&1 | tail -20 \
    || { clog "[warn] lerobot[pi] extra failed — retrying base lerobot"; \
         "$CONTAINER_PY" -m pip install "lerobot @ git+https://github.com/huggingface/lerobot.git@${LEROBOT_COMMIT}" 2>&1 | tail -20; }

# 5. download the folding_latest checkpoint (revision pinned if provided)
clog "Downloading checkpoint ${HF_REPO} (rev: ${HF_REVISION:-latest})..."
CKPT_DIR=$("$CONTAINER_PY" - << 'PYDL'
import os
from huggingface_hub import snapshot_download
rev = os.environ.get("HF_REVISION") or None
p = snapshot_download(os.environ["HF_REPO"], revision=rev)
print(p)
PYDL
)
CKPT_DIR=$(echo "$CKPT_DIR" | tail -1)
clog "checkpoint: ${CKPT_DIR}"

# 6. run the rollout driver (boots Isaac Sim, drives folding_latest over the bimanual env, writes video)
clog "Running run_eval.py (boots Isaac Sim — first boot is slow)..."
cd "$ASSETS"
"$CONTAINER_PY" run_eval.py \
    --policy-path  "$CKPT_DIR" \
    --output-dir   "$OUT" \
    --task         "${TASK_INSTR}" \
    --state-keys   "${STATE_KEYS}" \
    --camera-keys  "${CAMERA_KEYS}" \
    --state-dim    "${STATE_DIM}" \
    --action-dim   "${ACTION_DIM}" \
    --camera-height "${CAMERA_HEIGHT}" \
    --camera-width  "${CAMERA_WIDTH}" \
    --episode-length "${EPISODE_LENGTH}" \
    --n-episodes   "${N_EPISODES}" \
    --max-episodes-rendered "${MAX_EPISODES_RENDERED}" \
    --device       "${DEVICE}" \
    --seed         "${SEED}"
clog "run_eval.py done — outputs in ${OUT}"
CONTAINER_EOF
chmod +x "${HOST_ASSETS_DIR}/container_run.sh"

# ── [6/7] Run the container per task ──────────────────────────────────────────────────────────
log "[6/7] Running task(s) in the Isaac Lab container..."
export MUJOCO_GL=egl

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    TASK_NAME=$(echo "$TASK" | jq -r '.name // "task"')
    TASK_INSTR=$(echo "$TASK" | jq -r '.task')
    STATE_KEYS=$(echo "$TASK" | jq -r '.state_keys')
    CAMERA_KEYS=$(echo "$TASK" | jq -r '.camera_keys')
    STATE_DIM=$(echo "$TASK" | jq -r '.state_dim')
    ACTION_DIM=$(echo "$TASK" | jq -r '.action_dim')
    CAMERA_HEIGHT=$(echo "$TASK" | jq -r '.camera_height')
    CAMERA_WIDTH=$(echo "$TASK" | jq -r '.camera_width')
    EPISODE_LENGTH=$(echo "$TASK" | jq -r '.episode_length')
    N_EPISODES=$(echo "$TASK" | jq -r '.n_episodes')
    MAX_EPISODES_RENDERED=$(echo "$TASK" | jq -r '.max_episodes_rendered')
    DEVICE=$(echo "$TASK" | jq -r '.device // "cuda:0"')
    SEED=$(echo "$TASK" | jq -r '.seed // 1000')

    TASK_OUT="${HOST_OUT_DIR}/task-${TASK_IDX}"
    mkdir -p "$TASK_OUT"

    log "Task $((TASK_IDX+1))/${TASK_COUNT}: ${TASK_NAME} (instr=\"${TASK_INSTR}\")"
    log "  state_keys=${STATE_KEYS}"
    log "  camera_keys=${CAMERA_KEYS}, episode_length=${EPISODE_LENGTH}, n_episodes=${N_EPISODES}"

    docker rm -f "$CONTAINER_NAME" 2>/dev/null || true
    set +e
    # NOTE: the NGC isaac-lab image ships ENTRYPOINT ["/isaac-sim/runheadless.sh"] (verified via
    # registry config blob). Without --entrypoint, our "bash container_run.sh" would be APPENDED as
    # args to runheadless.sh — our script never runs and the image's default Isaac-Sim Streaming app
    # boots, then segfaults headless (Vulkan ERROR_INITIALIZATION_FAILED → libwayland). Override the
    # entrypoint so container_run.sh actually executes.
    docker run --name "$CONTAINER_NAME" --gpus all --rm \
        --entrypoint /bin/bash \
        -e "ACCEPT_EULA=Y" -e "PRIVACY_CONSENT=Y" -e "OMNI_KIT_ALLOW_ROOT=1" \
        -e "OPENARM_ISAAC_COMMIT={{ openarm_isaac_commit }}" \
        -e "LEROBOT_COMMIT={{ lerobot_commit }}" \
        -e "HF_REPO={{ hf_repo }}" \
        -e "HF_REVISION={{ hf_model_revision }}" \
        -e "TASK_INSTR=${TASK_INSTR}" \
        -e "STATE_KEYS=${STATE_KEYS}" \
        -e "CAMERA_KEYS=${CAMERA_KEYS}" \
        -e "STATE_DIM=${STATE_DIM}" \
        -e "ACTION_DIM=${ACTION_DIM}" \
        -e "CAMERA_HEIGHT=${CAMERA_HEIGHT}" \
        -e "CAMERA_WIDTH=${CAMERA_WIDTH}" \
        -e "EPISODE_LENGTH=${EPISODE_LENGTH}" \
        -e "N_EPISODES=${N_EPISODES}" \
        -e "MAX_EPISODES_RENDERED=${MAX_EPISODES_RENDERED}" \
        -e "DEVICE=${DEVICE}" \
        -e "SEED=${SEED}" \
        -v "${HOST_ASSETS_DIR}:/workspace/assets" \
        -v "${TASK_OUT}:/workspace/out" \
        -v "${HOST_HF_CACHE}:/workspace/hf-cache" \
        "$ISAAC_LAB_IMAGE" \
        /workspace/assets/container_run.sh \
        2>&1 | tee "/tmp/openarm_task${TASK_IDX}.log"
    EVAL_EXIT=${PIPESTATUS[0]}
    set -e
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        log "  [error] Task ${TASK_IDX} container exit=${EVAL_EXIT} — will fail after uploading diagnostics"
    fi

    VIDEO_COUNT=$(find "${TASK_OUT}" -name "*.mp4" 2>/dev/null | wc -l)
    log "  Videos collected: ${VIDEO_COUNT}"

    # pc_success from eval_info.json (expected ~0 — OOD pipe-proof; honest label).
    SR="unknown"
    if [ -f "${TASK_OUT}/eval_info.json" ]; then
        SR=$(jq -r '.aggregated.pc_success // empty' "${TASK_OUT}/eval_info.json" 2>/dev/null || echo "")
    fi
    [ -z "$SR" ] && SR="unknown"
    log "  pc_success=${SR} (OOD on empty Reach scene — pipe-proof, not task success)"

    {
        echo "model: openarm-isaac (pi05 folding_latest × Isaac Lab bimanual Reach)"
        echo "checkpoint: {{ hf_repo }}@{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
        echo "openarm_isaac_lab: {{ openarm_isaac_commit }}"
        echo "lerobot: {{ lerobot_commit }}"
        echo "task: ${TASK_NAME} — \"${TASK_INSTR}\""
        echo "state_keys: ${STATE_KEYS}"
        echo "camera_keys: ${CAMERA_KEYS}"
        echo "episode_length: ${EPISODE_LENGTH}, n_episodes: ${N_EPISODES}"
        echo "pc_success: ${SR}  (PIPE PROOF — folding policy is OOD on empty Reach scene)"
    } > "${TASK_OUT}/summary.txt"

    # ── S3 upload (videos + per-video context txt + logs + eval_info.json + summary) ──
    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"
    UPLOAD_COUNT=0
    while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
        [ -f "$mp4_file" ] || continue
        fname=$(basename "$mp4_file")
        base="${fname%.mp4}"
        txt_file="/tmp/openarm_ctx_task${TASK_IDX}_ep${UPLOAD_COUNT}.txt"
        {
            echo "=== OpenArm-Isaac Simulation Context ==="
            printf "Video:      %s\n"  "${fname}"
            printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
            echo ""
            echo "--- Environment ---"
            printf "Sim:        NVIDIA Isaac Lab 2.3 / Isaac Sim 5.1 (enactic/openarm_isaac_lab @ %s)\n" "{{ openarm_isaac_commit }}"
            printf "Gym ID:     Isaac-Reach-OpenArm-Bi-VLA-v0 (bimanual Reach + 3 cameras + 16-dim absolute action)\n"
            printf "Robot:      OpenArm bimanual (16-DOF: R_arm7+R_grip+L_arm7+L_grip)\n"
            printf "Task:       %s — \"%s\"\n" "${TASK_NAME}" "${TASK_INSTR}"
            echo ""
            echo "--- Model ---"
            printf "Policy:     %s (LeRobot pi05, rev %s)\n" "{{ hf_repo }}" "{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
            printf "Inference:  LeRobot pi05 in-process (16-DOF bimanual cloth-folding checkpoint)\n"
            echo ""
            echo "--- Rollout ---"
            printf "run_id:        %s\n"  "${RUN_ID}"
            printf "episode:       %s\n"  "${UPLOAD_COUNT}"
            printf "pc_success:    %s\n"  "${SR}"
            printf "NOTE:          PIPE PROOF — folding policy is OUT-OF-DISTRIBUTION on an empty Reach\n"
            printf "               scene. Video proves pi05 -> 16-joint OpenArm motion, NOT task success.\n"
            echo ""
            echo "--- Infrastructure ---"
            printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
            printf "Region:   %s\n"  "${REGION}"
            printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
        } > "$txt_file"

        if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/${fname}" \
            --region "$REGION" 2>&1 | tee -a /var/log/openarm-isaac-userdata.log; then
            UPLOAD_COUNT=$((UPLOAD_COUNT+1))
            aws s3 cp "$txt_file" "${S3_TASK_PREFIX}/videos/${base}.txt" \
                --region "$REGION" 2>/dev/null || true
        else
            log "  [warn] Upload failed: $fname"
        fi
    done < <(find "$TASK_OUT" -name "*.mp4" 2>/dev/null | sort)
    log "  Videos uploaded: ${UPLOAD_COUNT}/${VIDEO_COUNT}"

    aws s3 cp "/tmp/openarm_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/run.log" --region "$REGION" || true
    [ -f "${TASK_OUT}/eval_info.json" ] && \
        aws s3 cp "${TASK_OUT}/eval_info.json" \
        "${S3_TASK_PREFIX}/eval_info.json" --region "$REGION" || true
    [ -f "${TASK_OUT}/summary.txt" ] && \
        aws s3 cp "${TASK_OUT}/summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

    SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${TASK_NAME} — pc_success=${SR} (pipe-proof, OOD)"
    log "  Task $((TASK_IDX+1)) done"

    # Hard-fail after S3 upload if the container crashed or produced no video.
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        die "Task ${TASK_IDX} container failed (exit=${EVAL_EXIT}) — see ${S3_TASK_PREFIX}/run.log"
    fi
    if [ "${VIDEO_COUNT}" -eq 0 ]; then
        die "Task ${TASK_IDX} produced 0 videos — rollout short-circuited (see ${S3_TASK_PREFIX}/run.log)"
    fi
done

# ── [7/7] SNS notification + cfn-signal ──────────────────────────
log "[7/7] Sending SNS notification..."

SNS_MESSAGE="[${STACK_NAME}] OpenArm-Isaac simulation complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

Model: π0.5 (LeRobot pi05 {{ hf_repo }}, 16-DOF bimanual)
Sim:   NVIDIA Isaac Lab 2.3 / Isaac Sim 5.1 (enactic/openarm_isaac_lab)
Note:  PIPE PROOF — folding policy is OOD on an empty bimanual Reach scene. The video proves
       π0.5 -> 16-joint OpenArm motion in sim, NOT task success.
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./openarm-isaac-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py --vla openarm-isaac"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "OpenArm-Isaac simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "[7/7] Sending cfn-signal..."
cfn_signal 0

if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== OpenArm-Isaac UserData complete ====="
