#!/bin/bash
# GR00T 1-Click UserData Script (gr00t-g1 — N1.6 G1-PnPAppleToPlate + Unitree G1 + GR00T-WholeBodyControl)
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with: python generate.py --vla gr00t-g1
#
# CloudFormation Fn::Sub placeholders (resolved at deploy time):
#   ${S3BucketName}       — results S3 bucket
#   ${SnsTopicArn}        — completion notification SNS topic
#   ${StackName}          — CDK stack name
#   ${WaitConditionUrl}   — CFN WaitConditionHandle presigned URL
#   ${Region}             — deployment region
#   ${AutoTerminate}      — "true" to auto-terminate EC2 after completion

set -euo pipefail

ISAAC_GROOT_DIR=/home/ubuntu/Isaac-GR00T
# N1.6 G1: single venv for both rollout and server (GR00T-WholeBodyControl, GEAR WBC sim)
VENV="${ISAAC_GROOT_DIR}/gr00t/eval/sim/GR00T-WholeBodyControl/GR00T-WholeBodyControl_uv/.venv"
{% if server_n17 %}
# N1.7 rollout server (Step 2): the WBC sim env factory (gr00tlocomanip_g1_sim/*) exists ONLY at the
# N1.6 Isaac commit ({{ isaac_groot_commit[:8] }}) and the N1.7 Gr00tN1d7 model class exists ONLY at
# {{ server_isaac_groot_commit[:8] }}. So the policy server runs in a SECOND Isaac-GR00T checkout +
# its own uv-synced venv, talking to the WBC sim over ZMQ :8000. See models/gr00t-g1.yaml `server:`.
ISAAC_GROOT_N17_DIR=/home/ubuntu/Isaac-GR00T-N17
SERVER_VENV="${ISAAC_GROOT_N17_DIR}/.venv"
N17_CKPT_DIR=/home/ubuntu/gr00t-n17-ckpt
{% endif %}
VIDEO_BASE_DIR=/tmp/gr00t-videos
RUN_ID=$(date '+%Y-%m-%d-%H%M')
BRIDGE_DIR=/tmp/gr00t_bridge

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

# Remote gRPC endpoint (bridge mode): set by models/gr00t-g1.yaml → generate.py
# "" = local mode (run_gr00t_server.py), non-empty = bridge mode (gRPC delegation)
REMOTE_GRPC_ENDPOINT="{{ remote_grpc_endpoint }}"

log() { echo "[GR00T-G1] $(date '+%H:%M:%S') $*" | tee -a /var/log/gr00t-userdata.log; }

# cfn_signal: send signal to CloudFormation WaitConditionHandle presigned URL
cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    log "  instance-id: $_instance_id"
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/gr00t-userdata.log \
        && log "cfn_signal $_status sent to WaitCondition" \
        || log "[warn] cfn_signal WaitCondition send failed (continuing)"
}

die() {
    log "ERROR: $*"
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

log "===== GR00T-G1 UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/6] System dependencies ──────────────────────────────────────
log "[1/6] Installing system packages..."
export DEBIAN_FRONTEND=noninteractive

# Ubuntu 22.04 DLAMI reboots ~14-17min after boot. Root cause: cloud-init's modules:final
# runs package_update_upgrade_install concurrently with userdata → dpkg triggers fire
# (initramfs-tools, microcode-initrd) → systemd Reexecutes → needrestart DPkg::Post-Invoke
# hook schedules a reboot. Kill ALL of these mechanisms:
#
# 1. Prevent cloud-init from running package upgrades
cat > /etc/cloud/cloud.cfg.d/99_no_upgrade.cfg << 'EOF'
package_update: false
package_upgrade: false
package_reboot_if_required: false
EOF

# 2. Stop unattended-upgrades and kill any running apt-get
systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl mask unattended-upgrades 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
pkill -9 -f "apt.systemd.daily" 2>/dev/null || true

# 3. Suppress needrestart completely — remove DPkg::Post-Invoke hook
export NEEDRESTART_SUSPEND=1
export NEEDRESTART_MODE=l
rm -f /etc/apt/apt.conf.d/99needrestart 2>/dev/null || true
rm -f /etc/dpkg/dpkg.cfg.d/needrestart 2>/dev/null || true
if [ -f /etc/needrestart/needrestart.conf ]; then
    sed -i "s/^#\?\$nrconf{restart}.*$/\$nrconf{restart} = 'l';/" /etc/needrestart/needrestart.conf
fi
systemctl stop needrestart 2>/dev/null || true
systemctl disable needrestart 2>/dev/null || true
systemctl mask needrestart 2>/dev/null || true

# 4. Prevent systemd from rebooting even if something requests it
systemctl mask systemd-reboot.service 2>/dev/null || true
mkdir -p /run/systemd/system
cat > /run/systemd/system/systemd-reboot.service.d-override.conf << 'SYSEOF'
[Service]
ExecStart=
ExecStart=/bin/true
SYSEOF

sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/gr00t_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/gr00t_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

# G1/WBC: git-lfs is MANDATORY (setup_GR00T_WholeBodyControl.sh hard-fails without it; pulls sim assets).
# libegl1-mesa-dev + libglu1-mesa added per WBC README headless-render requirements.
APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    git git-lfs curl ca-certificates awscli jq \
    libgl1-mesa-glx libegl1 libgles2 libegl1-mesa-dev libglu1-mesa \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    ffmpeg python3-pip \
    2>&1 | tee /tmp/gr00t_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done
git lfs install --skip-repo 2>/dev/null || true


# ── [1.5/6] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/6] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/gr00t-g1/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/gr00t-userdata.log",
            "log_group_name": "/gr00t-g1/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config \
        -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/gr00t_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs saved locally only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs saved locally (/var/log/gr00t-userdata.log)"
fi

# ── [2/6] NVIDIA driver check ─────────────────────────────────────
log "[2/6] Checking GPU driver..."
nvidia-smi -L 2>&1 | tee /tmp/gr00t_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI is being used (continuing with EGL headless)"

# ── [3/6] uv install + Isaac-GR00T setup ──────────────────────────
log "[3/6] Installing uv (pinned: {{ uv_version if uv_version else 'latest' }})..."
if ! command -v uv &>/dev/null; then
{%- if uv_version %}
    curl -LsSf https://astral.sh/uv/install.sh | UV_VERSION="{{ uv_version }}" sh
{%- else %}
    curl -LsSf https://astral.sh/uv/install.sh | sh
{%- endif %}
fi
export PATH="/root/.local/bin:${PATH}"
export PATH="/home/ubuntu/.local/bin:${PATH}"

log "[3/6] Cloning Isaac-GR00T (pinned: {{ isaac_groot_commit[:8] if isaac_groot_commit else 'unpinned' }})..."
EXPECTED_COMMIT="{{ isaac_groot_commit }}"
if [ ! -d "${ISAAC_GROOT_DIR}" ]; then
    if [ -n "$EXPECTED_COMMIT" ]; then
        git clone https://github.com/NVIDIA/Isaac-GR00T.git \
            "${ISAAC_GROOT_DIR}" 2>&1 | tee /tmp/gr00t_clone.log
        git -C "${ISAAC_GROOT_DIR}" checkout "${EXPECTED_COMMIT}" 2>&1 \
            || die "Isaac-GR00T: failed to checkout pinned commit ${EXPECTED_COMMIT}"
    else
        git clone --branch main --depth 1 \
            https://github.com/NVIDIA/Isaac-GR00T.git \
            "${ISAAC_GROOT_DIR}" 2>&1 | tee /tmp/gr00t_clone.log
    fi
    ACTUAL_COMMIT=$(git -C "${ISAAC_GROOT_DIR}" rev-parse HEAD)
    log "  Commit: ${ACTUAL_COMMIT}"
else
    log "Isaac-GR00T already exists, skipping clone"
fi

# N1.6 G1: GR00T-WholeBodyControl (GEAR WBC) setup — pulls WBC submodule (+Git LFS), forked robosuite
# (xieleo5/robosuite @ leo/support_g1_locomanip), gr00trobosuite + gr00trobocasa editable, MuJoCo 3.2.6.
log "[3/6] Installing GR00T-WholeBodyControl environment (submodule + Git-LFS + 3 editable installs, ~25 min)..."
cd "${ISAAC_GROOT_DIR}"
export HOME="${HOME:-/root}"

bash gr00t/eval/sim/GR00T-WholeBodyControl/setup_GR00T_WholeBodyControl.sh \
    2>&1 | tee /tmp/gr00t_setup.log | tee -a /var/log/gr00t-userdata.log \
    || { log "  [setup ERROR] setup_GR00T_WholeBodyControl.sh failed — last 50 lines:"; \
         tail -50 /tmp/gr00t_setup.log | while IFS= read -r line; do log "  [setup] $line"; done; \
         die "setup_GR00T_WholeBodyControl.sh failed"; }
log "  [3/6] setup_GR00T_WholeBodyControl.sh complete"
{% if robosuite_commit %}
# N1.6 G1: pin the forked robosuite (xieleo5/robosuite). The WBC setup script clones it by BRANCH
# (leo/support_g1_locomanip) full-depth — pin to a commit to freeze against future branch drift.
ROBOSUITE_DIR="${ISAAC_GROOT_DIR}/external_dependencies/GR00T-WholeBodyControl/gr00t_wbc/dexmg/gr00trobosuite"
if [ -d "${ROBOSUITE_DIR}/.git" ]; then
    log "[3/6] Pinning forked robosuite to {{ robosuite_commit[:8] }}..."
    git -C "${ROBOSUITE_DIR}" checkout "{{ robosuite_commit }}" 2>&1 \
        | tee /tmp/gr00t_robosuite_pin.log \
        || die "robosuite pin checkout failed (commit {{ robosuite_commit[:8] }})"
    log "  robosuite at: $(git -C "${ROBOSUITE_DIR}" rev-parse HEAD)"
else
    log "[warn] robosuite dir not a git repo (${ROBOSUITE_DIR}) — skipping pin"
fi
{% endif %}

# N1.6 G1: install gr00t core deps into the WBC venv (same venv for both rollout + server).
# The WBC setup script installs the project with --no-deps, so the gr00t core deps must be added here.
log "[3/6] Installing Isaac-GR00T core deps into WBC venv..."
uv pip install wheel_stub --python "${VENV}/bin/python" 2>&1 | tee /tmp/gr00t_wheel.log
uv pip install -e . --python "${VENV}/bin/python" --no-build-isolation \
    2>&1 | tee /tmp/gr00t_install.log | tee -a /var/log/gr00t-userdata.log \
    || die "Isaac-GR00T pip install failed"

# N1.6 G1: the WBC setup script (unlike the GR1 setup) does NOT install torch/torchvision/flash-attn.
# The policy server (run_gr00t_server.py) loads the 3B checkpoint on CUDA → ensure a CUDA torch + flash-attn
# are present in the WBC venv. Pins mirror the GR1 setup (torch 2.5.1 / flash-attn 2.7.4.post1).
log "[3/6] Ensuring torch + flash-attn in WBC venv..."
if ! "${VENV}/bin/python" -c "import torch; assert torch.cuda.is_available()" 2>/dev/null; then
    uv pip install torch==2.5.1 torchvision==0.20.1 --python "${VENV}/bin/python" \
        2>&1 | tee /tmp/gr00t_torch.log || die "torch install into WBC venv failed"
fi
"${VENV}/bin/python" -c "import flash_attn" 2>/dev/null \
    || uv pip install flash-attn==2.7.4.post1 --no-build-isolation --python "${VENV}/bin/python" \
        2>&1 | tee /tmp/gr00t_flashattn.log \
        || log "[warn] flash-attn install failed (continuing; server may fall back to eager attention)"

log "[3/6] Running sanity test (gr00t + WBC import)..."
"${VENV}/bin/python" -c "
import torch; print('torch:', torch.__version__, 'cuda:', torch.cuda.is_available())
import gr00t; print('gr00t OK (path:', gr00t.__file__, ')')
" || die "Sanity test failed"

{% if server_n17 %}
# ── [3.2/6] N1.7 inference server: second Isaac-GR00T checkout + uv-synced venv ──────────────────
# The WBC sim (above) is pinned to the N1.6 Isaac commit because GR00T-WholeBodyControl was deleted
# from the repo at N1.7. The N1.7 Gr00tN1d7 model class (Cosmos-Reason2-2B backbone, transformers
# 4.57.3) only loads here, so we clone a SECOND checkout at {{ server_isaac_groot_commit[:8] }} and
# uv-sync its own venv. The two venvs talk over ZMQ :8000 (server here, sim client in WBC venv).
log "[3.2/6] [N1.7] Cloning second Isaac-GR00T for server (pinned: {{ server_isaac_groot_commit[:8] }})..."
if [ ! -d "${ISAAC_GROOT_N17_DIR}" ]; then
    git clone https://github.com/NVIDIA/Isaac-GR00T.git "${ISAAC_GROOT_N17_DIR}" 2>&1 \
        | tee /tmp/gr00t_n17_clone.log
    git -C "${ISAAC_GROOT_N17_DIR}" checkout "{{ server_isaac_groot_commit }}" 2>&1 \
        || die "N1.7 Isaac-GR00T: failed to checkout pinned commit {{ server_isaac_groot_commit }}"
    log "  [N1.7] commit: $(git -C "${ISAAC_GROOT_N17_DIR}" rev-parse HEAD)"
fi
log "[3.2/6] [N1.7] Installing server venv (uv sync --no-dev from uv.lock; flash-attn prebuilt wheel)..."
cd "${ISAAC_GROOT_N17_DIR}"
uv sync --no-dev 2>&1 | tee /tmp/gr00t_n17_server_venv.log \
    || die "N1.7 gr00t uv sync failed (see /tmp/gr00t_n17_server_venv.log)"
log "  [3.2/6] [N1.7] server venv ready: ${SERVER_VENV}"
"${SERVER_VENV}/bin/python" -c "
import transformers, torch
from gr00t.model.gr00t_n1d7.gr00t_n1d7 import Gr00tN1d7  # N1.7 model class — fails fast if commit is wrong
print('[N1.7] transformers', transformers.__version__, '| torch', torch.__version__, '| Gr00tN1d7 OK')
" 2>&1 | tee /tmp/gr00t_n17_sanity.log || die "N1.7 server venv sanity failed (Gr00tN1d7 import)"

# ── [3.3/6] Codec bridge: overlay the N1.7 ZMQ serializer onto the WBC (sim-client) venv ─────────
# The sim client (rollout_policy.py in the WBC venv @ {{ isaac_groot_commit[:8] }}) and the N1.7 server
# both use gr00t/policy/server_client.py, but the numpy wire codec diverged: N1.6 = np.save inside
# __ndarray_class__, N1.7 = msgpack_numpy envelope (+ __ModalityConfig__ rename). Mismatched codecs
# silently fail to deserialize obs/action. We copy the N1.7 server_client.py over the WBC venv's gr00t
# so both sides speak the same codec. Drop-in: imports (msgpack/msgpack_numpy/numpy/zmq/ModalityConfig/
# to_json_serializable/BasePolicy) all exist at {{ isaac_groot_commit[:8] }}; msgpack==1.1.0 /
# msgpack-numpy==0.4.8 / numpy==1.26.4 pins are identical at both commits.
log "[3.3/6] [N1.7] Overlaying N1.7 server_client.py codec onto WBC venv..."
N17_SERVER_CLIENT="${ISAAC_GROOT_N17_DIR}/gr00t/policy/server_client.py"
[ -f "${N17_SERVER_CLIENT}" ] || die "N1.7 server_client.py not found at ${N17_SERVER_CLIENT}"
# Resolve the WBC venv's gr00t package dir. CRITICAL: run from a NEUTRAL cwd (cd /), because we are
# currently inside ${ISAAC_GROOT_N17_DIR} (set for the [3.2] uv sync) and BOTH checkouts have a top-level
# gr00t/ package — Python prepends cwd ('') to sys.path, so `import gr00t` from the N1.7 dir resolves to
# the N1.7 source tree, NOT the WBC venv's editable install. That made src==dest and cp failed (observed
# 2026-06-19 redeploy). Resolving from / forces the venv's installed gr00t. Stderr→log so a warning can't
# corrupt the captured path.
WBC_GR00T_DIR=$(cd / && "${VENV}/bin/python" -c "import os, gr00t; print(os.path.dirname(gr00t.__file__))" 2>>/tmp/gr00t_wbcdir.err || true)
[ -n "${WBC_GR00T_DIR}" ] && [ -d "${WBC_GR00T_DIR}/policy" ] \
    || die "WBC venv gr00t/policy dir not resolvable (got: [${WBC_GR00T_DIR}]; see /tmp/gr00t_wbcdir.err)"
log "  [3.3/6] WBC gr00t dir: ${WBC_GR00T_DIR}"
# Guard: the WBC gr00t MUST be the N1.6 checkout (ISAAC_GROOT_DIR), never the N1.7 server checkout — else
# we'd overlay the file onto itself (src==dest) and/or corrupt the N1.7 server's own server_client.py.
case "${WBC_GR00T_DIR}" in
    "${ISAAC_GROOT_N17_DIR}"/*) die "WBC gr00t resolved to the N1.7 server checkout (${WBC_GR00T_DIR}) — cwd shadowed the import; refusing overlay (src==dest)";;
esac
[ "${N17_SERVER_CLIENT}" -ef "${WBC_GR00T_DIR}/policy/server_client.py" ] \
    && die "codec overlay src and dest are the same file (${N17_SERVER_CLIENT}) — wrong WBC dir resolved"
cp "${N17_SERVER_CLIENT}" "${WBC_GR00T_DIR}/policy/server_client.py" \
    || die "codec overlay copy failed (src=${N17_SERVER_CLIENT} dest=${WBC_GR00T_DIR}/policy/)"
# Leave the N1.7 dir BEFORE verifying — the verification (and the rollout client) must import the WBC
# venv's gr00t, not the N1.7 source tree that cwd would shadow.
cd "${ISAAC_GROOT_DIR}"
# msgpack_numpy is a server_client.py import → ensure it's present in the WBC (sim-client) venv.
"${VENV}/bin/python" -c "import msgpack_numpy" 2>/dev/null \
    || uv pip install "msgpack-numpy==0.4.8" --python "${VENV}/bin/python" 2>&1 | tee /tmp/gr00t_msgpacknumpy.log \
    || die "msgpack-numpy install into WBC venv failed"
# Verify from a neutral cwd that the WBC venv's gr00t (the overlay target) now speaks msgpack_numpy.
(cd / && "${VENV}/bin/python" -c "
import os, gr00t, inspect, msgpack_numpy
from gr00t.policy.server_client import MsgSerializer, PolicyClient
assert 'msgpack_numpy' in inspect.getsource(inspect.getmodule(MsgSerializer)), 'overlay did not take (no msgpack_numpy in module)'
print('[N1.7] codec overlay OK on', os.path.dirname(gr00t.__file__), '(WBC venv now speaks msgpack_numpy)')
") 2>&1 | tee /tmp/gr00t_codec_overlay.log || die "codec overlay verification failed"
{% endif %}

{% if remote_grpc_endpoint %}
# ── [3.5/6] Bridge mode: deps install + bridge files ─────────────
log "[3.5/6] Bridge mode — installing gRPC bridge dependencies..."
uv pip install "grpcio>=1.80.0" Pillow "protobuf>=5.0" \
    --python "${VENV}/bin/python" 2>&1 | tee /tmp/gr00t_bridge_deps.log \
    || die "Bridge dependency install failed"

log "[3.5/6] Writing bridge files to ${BRIDGE_DIR}..."
mkdir -p "$BRIDGE_DIR"

base64 -d > "$BRIDGE_DIR/zmq_grpc_bridge.py" << 'BRIDGE_SCRIPT_EOF'
{{ zmq_grpc_bridge_b64 -}}
BRIDGE_SCRIPT_EOF

base64 -d > "$BRIDGE_DIR/gr00t_pb2.py" << 'PB2_EOF'
{{ gr00t_pb2_b64 -}}
PB2_EOF

base64 -d > "$BRIDGE_DIR/gr00t_pb2_grpc.py" << 'GRPC_EOF'
{{ gr00t_pb2_grpc_b64 -}}
GRPC_EOF

log "[3.5/6] Bridge files ready: $(ls $BRIDGE_DIR)"
log "[3.5/6] gRPC endpoint: ${REMOTE_GRPC_ENDPOINT}"
{% endif %}

# ── [4/6] Sequential task execution ──────────────────────────────
log "[4/6] Starting sequential task execution..."

export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl
export HF_HOME=/home/ubuntu/.cache/huggingface

{% if remote_grpc_endpoint %}
log "[4/6] Bridge mode — skipping HF model download (inference delegated to ${REMOTE_GRPC_ENDPOINT})"
HF_MODEL_PATH=""
{% elif server_n17 %}
# N1.7 rollout server (Step 2): download the fine-tuned N1.7 G1 adapter ckpt (from Hugging Face if
# server.hf_repo is set, else from S3) and load it with the N1.7 SERVER_VENV. The fine-tuned ckpt and
# the gated Cosmos-Reason2-2B backbone are both re-fetched at model load → need an HF token. (The WBC
# sim env is built separately above; no model download for it.)
log "[4/6] [N1.7] Reading HF token from SSM ({{ server_hf_token_ssm }} @ ${REGION}) for gated NVIDIA weights..."
HF_TOKEN=$(aws ssm get-parameter \
    --name "{{ server_hf_token_ssm }}" \
    --with-decryption \
    --query 'Parameter.Value' --output text \
    --region "$REGION" 2>/dev/null || echo "")
if [ -n "$HF_TOKEN" ]; then
    export HUGGING_FACE_HUB_TOKEN="$HF_TOKEN"
    export HF_TOKEN="$HF_TOKEN"
    log "  [N1.7] HF token loaded"
else
    log "[warn] [N1.7] HF token not found in SSM ({{ server_hf_token_ssm }} @ ${REGION}) — gated weight download may fail"
fi

mkdir -p "${N17_CKPT_DIR}"
{% if server_hf_repo %}
# Public, reproducible path: pull the merged N1.7 G1 adapter from Hugging Face. The repo is gated
# (mirrors the upstream Cosmos-Reason2-2B posture) → the SSM HF token must have access granted.
log "[4/6] [N1.7] Downloading fine-tuned ckpt from Hugging Face: {{ server_hf_repo }}{% if server_hf_revision %} @ {{ server_hf_revision[:8] }}{% endif %}"
"${SERVER_VENV}/bin/python" - "${N17_CKPT_DIR}" <<'PYHF' 2>&1 | tee /tmp/gr00t_n17_hf_download.log \
    || die "[N1.7] HF ckpt download failed ({{ server_hf_repo }})"
import sys
from huggingface_hub import snapshot_download
snapshot_download(
    "{{ server_hf_repo }}",
{% if server_hf_revision %}    revision="{{ server_hf_revision }}",
{% endif %}    local_dir=sys.argv[1],
)
print("ckpt downloaded")
PYHF
{% else %}
# Private path: pull the fine-tuned ckpt from S3 (vla-ft output bucket). Only the top-level merged ckpt
# is needed for serving (config.json + 3 safetensors shards + index + processor/ + experiment_cfg/);
# exclude the intermediate checkpoint-*/ dirs (~125GB) to save bandwidth.
log "[4/6] [N1.7] Downloading fine-tuned ckpt from S3: {{ server_s3_ckpt_uri }}"
aws s3 sync "{{ server_s3_ckpt_uri }}" "${N17_CKPT_DIR}/" \
    --exclude "checkpoint-*/*" \
    --only-show-errors --region "$REGION" 2>&1 | tee /tmp/gr00t_n17_s3_sync.log \
    || die "[N1.7] S3 ckpt sync failed ({{ server_s3_ckpt_uri }})"
{% endif %}
HF_MODEL_PATH="${N17_CKPT_DIR}"
[ -f "${HF_MODEL_PATH}/config.json" ] || die "[N1.7] ckpt config.json missing after download (${HF_MODEL_PATH})"
SHARDS=$(find "${HF_MODEL_PATH}" -maxdepth 1 -name "model-*.safetensors" | wc -l | tr -d ' ')
log "  [N1.7] ckpt at ${HF_MODEL_PATH} (config.json + ${SHARDS} shards)"

log "[4.1/6] [N1.7] Pre-downloading Cosmos-Reason2-2B backbone (gated, ~4.9GB)..."
"${SERVER_VENV}/bin/python" -c "
from huggingface_hub import snapshot_download
snapshot_download('nvidia/Cosmos-Reason2-2B')
print('Cosmos-Reason2-2B downloaded')
" 2>&1 | tee /tmp/gr00t_cosmos_download.log || {
    log "[warn] [N1.7] Cosmos-Reason2-2B download failed — ZMQ server may fail at model load"
    tail -10 /tmp/gr00t_cosmos_download.log | while IFS= read -r line; do log "  $line"; done
}
# HF_HUB_OFFLINE not set — N1.7 model load needs the backbone model_info/tokenizer API.
{% else %}
# Local mode: pre-download GR00T N1.6 G1 checkpoint
{% if hf_model_revision %}
log "[4/6] Downloading HuggingFace model {{ hf_repo }} (pinned: {{ hf_model_revision[:8] }})..."
HF_MODEL_PATH=$("${VENV}/bin/python" -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}', revision='{{ hf_model_revision }}')
print(path)
" 2>&1 | tee /tmp/gr00t_hf_download.log | tail -1) \
    || die "HuggingFace model download failed (repo: {{ hf_repo }}, revision: {{ hf_model_revision[:8] }})"
log "  Model path: ${HF_MODEL_PATH}"
export HF_HUB_OFFLINE=1
{% else %}
log "[4/6] Downloading HuggingFace model {{ hf_repo }} (unpinned — reproducibility risk)..."
HF_MODEL_PATH=$("${VENV}/bin/python" -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}')
print(path)
" 2>&1 | tee /tmp/gr00t_hf_download.log | tail -1) \
    || die "HuggingFace model download failed (repo: {{ hf_repo }})"
log "  Model path: ${HF_MODEL_PATH}"
log "[warn] hf_model_revision not set — using unpinned HuggingFace snapshot (reproducibility risk)"
{% endif %}
{% endif %}

{% if collect %}
# ── [4/6] COLLECT mode: materialise the trajectory collector + LeRobot converter ──
# Step 2 (N1.7 G1 adapter FT data): instead of rollout_policy.py (MP4 + success rate), run
# collect_trajectories.py to dump SUCCESS-ONLY (obs,action) transitions to HDF5, then convert to a
# GR00T LeRobotDataset. Same WBC venv / ZMQ server / checkpoint — only the driver differs (policy
# runs at NATIVE chunk; per-step capture happens below MultiStepWrapper inside the script).
COLLECT_DIR=/home/ubuntu/gr00t-g1-collect
mkdir -p "${COLLECT_DIR}/datasets" "${COLLECT_DIR}/lerobot"
log "[4/6] [COLLECT] Writing collector assets to ${COLLECT_DIR}..."
base64 -d > "${COLLECT_DIR}/collect_trajectories.py" << 'COLLECT_TRAJ_EOF'
{{ collect_traj_b64 -}}
COLLECT_TRAJ_EOF
base64 -d > "${COLLECT_DIR}/gr00t_hdf5_to_lerobot.py" << 'HDF5_LEROBOT_EOF'
{{ hdf5_to_lerobot_b64 -}}
HDF5_LEROBOT_EOF
LEROBOT_TASK="{{ collection.lerobot_task }}"
LEROBOT_REPO_ID="{{ collection.repo_id }}"
MAX_TOTAL_EPISODES="{{ collection.max_total_episodes }}"
# num_demos override (collect target). 0 → fall back to per-task n_episodes (set in the loop).
COLLECT_NUM_DEMOS="{{ collection.num_demos }}"
log "[4/6] [COLLECT] assets ready: $(ls ${COLLECT_DIR})"
{% endif %}

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    ENV_NAME=$(echo "$TASK" | jq -r '.env_name')
    EMBODIMENT=$(echo "$TASK" | jq -r '.embodiment')
    N_EPISODES=$(echo "$TASK" | jq -r '.n_episodes')
    N_ENVS=$(echo "$TASK" | jq -r '.n_envs')
    MAX_STEPS=$(echo "$TASK" | jq -r '.max_episode_steps')
    N_ACTION_STEPS=$(echo "$TASK" | jq -r '.n_action_steps // 20')
    VIDEO_FPS=$(echo "$TASK" | jq -r '.video_fps')
    VIDEO_CRF=$(echo "$TASK" | jq -r '.video_crf')
    STEPS_PER_RENDER=$(echo "$TASK" | jq -r '.steps_per_render')

    VIDEO_DIR="${VIDEO_BASE_DIR}/task-${TASK_IDX}"
    mkdir -p "$VIDEO_DIR"

    # Parse task name + robot tag from ENV_NAME: suite/TaskName_G1_gear_wbc
    BASENAME=$(echo "$ENV_NAME" | rev | cut -d'/' -f1 | rev)
    TASK_NAME=$(echo "$BASENAME" | sed 's/_G1_gear_wbc$//')
    ROBOT_TAG="G1_gear_wbc"

    log "Task $((TASK_IDX+1))/${TASK_COUNT}: ${ENV_NAME}"
    log "  embodiment=${EMBODIMENT}, n_episodes=${N_EPISODES}, n_envs=${N_ENVS}, n_action_steps=${N_ACTION_STEPS}"
    log "  fps=${VIDEO_FPS}, crf=${VIDEO_CRF}, steps_per_render=${STEPS_PER_RENDER}"

    if [ -n "$REMOTE_GRPC_ENDPOINT" ]; then
        log "  [Bridge mode] Starting ZMQ↔gRPC bridge → ${REMOTE_GRPC_ENDPOINT} ..."
        PYTHONPATH="$BRIDGE_DIR" nohup "${VENV}/bin/python" "$BRIDGE_DIR/zmq_grpc_bridge.py" \
            --endpoint "$REMOTE_GRPC_ENDPOINT" \
            --zmq-port 8000 \
            > /tmp/gr00t_bridge_task${TASK_IDX}.log 2>&1 &
        SERVER_PID=$!
        log "  Bridge started (PID: $SERVER_PID)"
{% if server_n17 %}
    else
        log "  [N1.7 server] Starting ZMQ server from N1.7 venv (Cosmos backbone load ~5-8 min)..."
        # N1.7 G1 (Step 2): server runs in the SECOND Isaac checkout ({{ server_isaac_groot_commit[:8] }})
        # + its own uv-synced venv. --embodiment-tag UNITREE_G1 resolves to the value baked in the ckpt
        # (unitree_g1_full_body_with_waist_height_nav_cmd). Sim client (WBC venv) uses the overlaid codec.
        # CRITICAL: cd into the N1.7 checkout so the server's `import gr00t` resolves to the N1.7 tree
        # (cwd is otherwise ${ISAAC_GROOT_DIR} = the N1.6 WBC checkout, which has its own ./gr00t).
        nohup bash -c "cd '${ISAAC_GROOT_N17_DIR}' && exec '${SERVER_VENV}/bin/python' '${ISAAC_GROOT_N17_DIR}/gr00t/eval/run_gr00t_server.py' \
            --model-path '${HF_MODEL_PATH}' \
            --embodiment-tag '{{ server_embodiment_tag }}' \
            --use-sim-policy-wrapper \
            --port 8000" \
            > /tmp/gr00t_zmq_task${TASK_IDX}.log 2>&1 &
        SERVER_PID=$!
    fi
{% else %}
    else
        log "  [Local mode] Starting ZMQ server (model load ~3-5 min)..."
        # N1.6 G1: use shared WBC venv (VENV), not a separate server venv
        nohup "${VENV}/bin/python" "${ISAAC_GROOT_DIR}/gr00t/eval/run_gr00t_server.py" \
            --model-path "${HF_MODEL_PATH}" \
            --embodiment-tag "${EMBODIMENT}" \
            --use-sim-policy-wrapper \
            --port 8000 \
            > /tmp/gr00t_zmq_task${TASK_IDX}.log 2>&1 &
        SERVER_PID=$!
    fi
{% endif %}

    # Wait for ZMQ port :8000. N1.6 model load ~3-5 min (90x5s=7.5 min). N1.7 (Cosmos-Reason2-2B
    # backbone + 3B merged ckpt) is heavier → 144x5s=12 min.
{% if server_n17 %}
    ZMQ_MAX_ITERS=144
    ZMQ_TIMEOUT_DESC="12 min"
{% else %}
    ZMQ_MAX_ITERS=90
    ZMQ_TIMEOUT_DESC="7.5 min"
{% endif %}
    ZMQ_READY=0
    for i in $(seq 1 "${ZMQ_MAX_ITERS}"); do
        if ! kill -0 "$SERVER_PID" 2>/dev/null; then
            log "  [ERROR] ZMQ server PID $SERVER_PID died (Task ${TASK_IDX}). Last log:"
            tail -30 "/tmp/gr00t_zmq_task${TASK_IDX}.log" 2>/dev/null | while IFS= read -r line; do log "    $line"; done
            break
        fi
        if ss -tlnp 2>/dev/null | grep -q ':8000'; then
            log "  ZMQ :8000 ready (${i}x5s elapsed)"
            ZMQ_READY=1
            break
        fi
        if (( i % 12 == 0 )); then
            log "  ZMQ loading... (${i}x5s). Last: $(tail -1 /tmp/gr00t_zmq_task${TASK_IDX}.log 2>/dev/null | tr '\n' ' ')"
        fi
        sleep 5
    done
    [ "$ZMQ_READY" -eq 1 ] || die "ZMQ :8000 not ready within ${ZMQ_TIMEOUT_DESC} (Task ${TASK_IDX})"

    touch /tmp/gr00t_task${TASK_IDX}_start.marker
    cd "${ISAAC_GROOT_DIR}"
{% if collect %}
    # COLLECT mode: dump success-only (obs,action) trajectories to HDF5. The policy runs at its NATIVE
    # action chunk (--n_action_steps = the task's N_ACTION_STEPS, e.g. 20) — NOT 1; per-timestep
    # transitions are captured below MultiStepWrapper inside the script. (n_action_steps=1 collapses
    # G1 whole-body balance → 0 success; see knowledge/.../action-chunk-rollout-vs-collection.md.)
    # NUM_DEMOS = number of SUCCESSFUL demos to export (collection.num_demos override, else n_episodes).
    HDF5_FILE="${COLLECT_DIR}/datasets/gr00t_g1_task${TASK_IDX}.hdf5"
    NUM_DEMOS="${COLLECT_NUM_DEMOS}"
    if [ "${NUM_DEMOS:-0}" -le 0 ] 2>/dev/null; then NUM_DEMOS="${N_EPISODES}"; fi
    log "  [COLLECT] Collecting ${NUM_DEMOS} success demos (native chunk n_action_steps=${N_ACTION_STEPS}) → ${HDF5_FILE} ..."
    "${VENV}/bin/python" "${COLLECT_DIR}/collect_trajectories.py" \
        --env_name "${ENV_NAME}" \
        --policy_client_host localhost \
        --policy_client_port 8000 \
        --n_episodes "${NUM_DEMOS}" \
        --max_episode_steps "${MAX_STEPS}" \
        --n_action_steps "${N_ACTION_STEPS}" \
        --dataset_file "${HDF5_FILE}" \
        --video_dir "${VIDEO_DIR}" \
        --video_fps "${VIDEO_FPS}" \
        --video_crf "${VIDEO_CRF}" \
        --steps_per_render "${STEPS_PER_RENDER}" \
        --max_total_episodes "${MAX_TOTAL_EPISODES}" \
        2>&1 | tee /tmp/gr00t_rollout_task${TASK_IDX}.log \
        || log "  [warn] Task ${TASK_IDX} collection error (continuing)"

    # Convert HDF5 → GR00T LeRobotDataset (no GPU needed; lerobot is in the WBC venv).
    LEROBOT_ROOT="${COLLECT_DIR}/lerobot/task-${TASK_IDX}"
    if [ -f "${HDF5_FILE}" ]; then
        log "  [COLLECT] Converting HDF5 → LeRobotDataset at ${LEROBOT_ROOT} ..."
        "${VENV}/bin/python" "${COLLECT_DIR}/gr00t_hdf5_to_lerobot.py" \
            --hdf5 "${HDF5_FILE}" \
            --repo-id "${LEROBOT_REPO_ID}" \
            --root "${LEROBOT_ROOT}" \
            --task "${LEROBOT_TASK}" \
            2>&1 | tee -a /tmp/gr00t_rollout_task${TASK_IDX}.log \
            || log "  [warn] Task ${TASK_IDX} LeRobot conversion error (continuing)"
    else
        log "  [warn] No HDF5 produced (${HDF5_FILE}) — skipping conversion"
    fi
{% else %}
    # N1.6 rollout_policy.py uses underscore args (--env_name, not --env-name).
    # G1 loco-manip adds --n_action_steps (=20) and uses longer episodes (max_episode_steps=1440).
    log "  Running rollout (CLI mode, N1.6 underscore args)..."
    "${VENV}/bin/python" gr00t/eval/rollout_policy.py \
        --env_name "${ENV_NAME}" \
        --policy_client_host localhost \
        --policy_client_port 8000 \
        --n_episodes "${N_EPISODES}" \
        --n_envs "${N_ENVS}" \
        --n_action_steps "${N_ACTION_STEPS}" \
        --max_episode_steps "${MAX_STEPS}" \
        2>&1 | tee /tmp/gr00t_rollout_task${TASK_IDX}.log \
        || log "  [warn] Task ${TASK_IDX} rollout error (continuing)"
{% endif %}

    find /tmp -name "*.mp4" -newer /tmp/gr00t_task${TASK_IDX}_start.marker \
        -exec mv {} "${VIDEO_DIR}/" \; 2>/dev/null || true
    VIDEO_COUNT=$(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | wc -l)
    log "  Videos collected: ${VIDEO_COUNT}"

{% if collect %}
    # COLLECT mode: "success rate" line is absent; parse the collector's exported-demo count instead.
    # Denominator is NUM_DEMOS (the collect target), not N_EPISODES (rollout/eval count).
    N_SUCCESS=$(grep -oE 'DONE: [0-9]+ successful demos' \
        /tmp/gr00t_rollout_task${TASK_IDX}.log 2>/dev/null | tail -1 | grep -oE '[0-9]+' | head -1 || echo "0")
    N_SUCCESS="${N_SUCCESS:-0}"
    SR=$(awk "BEGIN { if (${NUM_DEMOS}+0>0) printf \"%.2f\", ${N_SUCCESS}/${NUM_DEMOS}; else print \"0\" }" 2>/dev/null || echo "0")
    log "  collected demos=${N_SUCCESS}/${NUM_DEMOS} (target met ratio=${SR})"
{% else %}
    SR=$(grep -oE 'success rate:[[:space:]]+[0-9.]+' \
        /tmp/gr00t_rollout_task${TASK_IDX}.log 2>/dev/null | tail -1 | awk '{print $NF}' || echo "unknown")
    N_SUCCESS=$(awk "BEGIN { printf \"%d\", ${N_EPISODES} * ${SR:-0} }" 2>/dev/null || echo "?")
    log "  success_rate=${SR} (${N_SUCCESS}/${N_EPISODES})"
{% endif %}

    {
        echo "env_name: ${ENV_NAME}"
        echo "success_rate: ${SR}"
        echo "n_episodes: ${N_EPISODES}"
        echo "n_success: ${N_SUCCESS}"
        echo "fps: ${VIDEO_FPS}, crf: ${VIDEO_CRF}, steps_per_render: ${STEPS_PER_RENDER}"
    } > "/tmp/gr00t_task${TASK_IDX}_summary.txt"

    kill "$SERVER_PID" 2>/dev/null || true
    wait "$SERVER_PID" 2>/dev/null || true

    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"
    log "  VIDEO_DIR(${VIDEO_DIR}) contents:"
    ls -la "$VIDEO_DIR/" 2>&1 | tee -a /var/log/gr00t-userdata.log || true
    UPLOAD_COUNT=0
    while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
        [ -f "$mp4_file" ] || continue
        fname=$(basename "$mp4_file")
        base="${fname%.mp4}"

        txt_file="/tmp/gr00t_ctx_task${TASK_IDX}_ep${UPLOAD_COUNT}.txt"
        {
            echo "=== GR00T-G1 Simulation Context ==="
            printf "Video:      %s\n"  "${fname}"
            printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
            echo ""
            echo "--- Environment ---"
            printf "Task:       %s\n"  "${TASK_NAME}"
            printf "Gym ID:     %s\n"  "${ENV_NAME}"
            printf "Suite:      GR00T-WholeBodyControl (GEAR WBC loco-manipulation)\n"
            printf "Robot:      Unitree G1 (%s)\n" "${ROBOT_TAG}"
            echo ""
            echo "--- Model ---"
{% if server_n17 %}
            printf "Model:      GR00T N1.7 G1 adapter (FT) — {{ server_hf_repo if server_hf_repo else server_s3_ckpt_uri }}\n"
            printf "Server:     Isaac-GR00T {{ server_isaac_groot_commit[:8] }} (Cosmos-Reason2-2B)\n"
{% else %}
            printf "Model:      {{ hf_repo }} (rev: {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }})\n"
{% endif %}
            printf "Embodiment: %s\n"  "${EMBODIMENT}"
            echo ""
            echo "--- Rollout ---"
            printf "run_id:         %s\n"  "${RUN_ID}"
            printf "task_idx:       %s\n"  "${TASK_IDX}"
            printf "episode:        %s\n"  "${UPLOAD_COUNT}"
            printf "n_episodes:     %s\n"  "${N_EPISODES}"
            printf "n_action_steps: %s\n"  "${N_ACTION_STEPS}"
            printf "success_rate:   %s/%s (%s)\n" "${N_SUCCESS:-?}" "${N_EPISODES}" "${SR:-?}"
            echo ""
            echo "--- Video Encoding ---"
            printf "fps: %s / crf: %s / steps_per_render: %s\n" \
                "${VIDEO_FPS}" "${VIDEO_CRF}" "${STEPS_PER_RENDER}"
            echo ""
            echo "--- Infrastructure ---"
            printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
            printf "Region:   %s\n"  "${REGION}"
            printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
        } > "$txt_file"

        if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/$fname" \
            --region "$REGION" 2>&1 | tee -a /var/log/gr00t-userdata.log; then
            UPLOAD_COUNT=$((UPLOAD_COUNT+1))
            log "  Uploaded: $fname"
            aws s3 cp "$txt_file" "${S3_TASK_PREFIX}/videos/${base}.txt" \
                --region "$REGION" 2>/dev/null || true
        else
            log "  [warn] Upload failed: $fname"
        fi
    done < <(find "$VIDEO_DIR" -name "*.mp4" 2>/dev/null | sort)
    log "  Videos uploaded: ${UPLOAD_COUNT}/${VIDEO_COUNT}"
    aws s3 cp "/tmp/gr00t_rollout_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/rollout.log" --region "$REGION" || true
    [ -f "/tmp/gr00t_task${TASK_IDX}_summary.txt" ] && \
        aws s3 cp "/tmp/gr00t_task${TASK_IDX}_summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

{% if collect %}
    # COLLECT mode: upload the trajectory HDF5 + the GR00T LeRobotDataset (the actual deliverable
    # for N1.7 G1 adapter FT). These are what vla-ft consumes — see the order-form.
    #
    # ⚠️ ROBUST UPLOAD (main-run lerobot/ loss root cause, 2026-06-17): the previous version piped
    #   `aws s3 sync ... 2>&1 | tail -5 | tee` and swallowed failure with `|| log warn`, then fell
    #   through to auto-terminate. Result: lerobot/ ended up 0 objects on S3 and the instance was gone
    #   before anyone could inspect. Fixes here: (a) NO tail pipe (exit status was being masked);
    #   (b) --only-show-errors (no CW progress flood that delayed the completion marker); (c) explicit
    #   exit-code check with retry; (d) VERIFY non-empty on S3 before declaring success; (e) record
    #   LEROBOT_SYNC_OK so [6/6] can refuse to auto-terminate if the deliverable never landed.
    LEROBOT_SYNC_OK=0
    if [ -f "${HDF5_FILE}" ]; then
        log "  [COLLECT] Uploading HDF5 ($(du -h "${HDF5_FILE}" 2>/dev/null | cut -f1)): ${S3_TASK_PREFIX}/dataset/"
        HDF5_OK=0
        for attempt in 1 2 3; do
            if aws s3 cp "${HDF5_FILE}" "${S3_TASK_PREFIX}/dataset/$(basename "${HDF5_FILE}")" \
                --region "$REGION" --only-show-errors; then
                HDF5_OK=1; log "  [COLLECT] HDF5 upload OK (attempt ${attempt})"; break
            fi
            log "  [warn] HDF5 upload failed (attempt ${attempt}/3) — retrying in 15s"; sleep 15
        done
        [ "$HDF5_OK" -eq 1 ] || log "  [ERROR] HDF5 upload FAILED after 3 attempts"
    fi
    if [ -d "${LEROBOT_ROOT}" ]; then
        LOCAL_N=$(find "${LEROBOT_ROOT}" -type f 2>/dev/null | wc -l | tr -d ' ')
        log "  [COLLECT] Syncing LeRobotDataset (${LOCAL_N} local files): ${S3_TASK_PREFIX}/lerobot/"
        for attempt in 1 2 3; do
            if aws s3 sync "${LEROBOT_ROOT}" "${S3_TASK_PREFIX}/lerobot/" \
                --region "$REGION" --only-show-errors; then
                S3_N=$(aws s3 ls "${S3_TASK_PREFIX}/lerobot/" --recursive --region "$REGION" 2>/dev/null | wc -l | tr -d ' ')
                log "  [COLLECT] sync attempt ${attempt}: local=${LOCAL_N} s3=${S3_N}"
                if [ "${S3_N:-0}" -gt 0 ]; then LEROBOT_SYNC_OK=1; break; fi
                log "  [warn] sync exited 0 but S3 lerobot/ shows 0 objects — retrying in 15s"
            else
                log "  [warn] LeRobot sync failed (attempt ${attempt}/3) — retrying in 15s"
            fi
            sleep 15
        done
        if [ "$LEROBOT_SYNC_OK" -eq 1 ]; then
            log "  [COLLECT] LeRobotDataset sync VERIFIED on S3 (${S3_TASK_PREFIX}/lerobot/, ${S3_N} objects)"
        else
            log "  [ERROR] LeRobotDataset sync FAILED/EMPTY after 3 attempts — instance will NOT auto-terminate (see [6/6])."
        fi
    else
        log "  [warn] LEROBOT_ROOT (${LEROBOT_ROOT}) missing — converter produced no dataset; sync skipped"
    fi
    # flush marker AFTER the upload block so it ingests to CloudWatch distinct from cp/sync progress.
    sleep 3
    log "  [COLLECT] upload block complete (HDF5_OK=${HDF5_OK:-0} LEROBOT_SYNC_OK=${LEROBOT_SYNC_OK})"
{% endif %}

    if [ -f "/tmp/gr00t_task${TASK_IDX}_summary.txt" ]; then
        SR=$(grep 'success_rate' "/tmp/gr00t_task${TASK_IDX}_summary.txt" | awk '{print $2}')
        NS=$(grep 'n_success' "/tmp/gr00t_task${TASK_IDX}_summary.txt" | awk '{print $2}')
        NE=$(grep 'n_episodes' "/tmp/gr00t_task${TASK_IDX}_summary.txt" | awk '{print $2}')
        ENV_SHORT=$(echo "$ENV_NAME" | rev | cut -d'/' -f1 | rev | cut -c1-50)
        SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${ENV_SHORT} — ${SR} (${NS}/${NE})"
    fi

    log "  Task $((TASK_IDX+1)) done"
done

# ── [5/6] SNS notification + cfn-signal ──────────────────────────
log "[5/6] Sending SNS notification..."

{% if collect %}
_MODE_INFO="Mode: COLLECT (GR00T N1.6 G1 success-only trajectory dump → HDF5 + LeRobotDataset for N1.7 G1 FT)"
{% elif remote_grpc_endpoint %}
_MODE_INFO="Mode: Bridge (remote gRPC → {{ remote_grpc_endpoint }})"
{% else %}
_MODE_INFO="Mode: Local (GR00T N1.6 G1 checkpoint loaded on EC2)"
{% endif %}

SNS_MESSAGE="[${STACK_NAME}] GR00T-G1 {% if collect %}Collection{% else %}Simulation{% endif %} complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

${_MODE_INFO}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./gr00t-g1-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py --vla gr00t-g1 --region ${REGION}"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "GR00T-G1 simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "[5/6] Sending cfn-signal..."
cfn_signal 0

# ── [6/6] EC2 auto-terminate ──────────────────────────────────────
{% if collect %}
# COLLECT mode safety gate: do NOT auto-terminate if the LeRobotDataset never landed on S3 (the
# deliverable). Keeps the instance alive (billed) so the data can be rescued / inspected, instead of
# silently losing it as the 2026-06-17 main run did. HDF5 is the recoverable fallback; the lerobot/
# dataset is the gate. Set LEROBOT_SYNC_OK default in case the collect block never ran.
LEROBOT_SYNC_OK="${LEROBOT_SYNC_OK:-0}"
if [ "${AUTO_TERMINATE}" = "true" ] && [ "${LEROBOT_SYNC_OK}" != "1" ]; then
    log "[6/6] ⚠️ AUTO_TERMINATE requested but LeRobotDataset sync NOT verified (LEROBOT_SYNC_OK=${LEROBOT_SYNC_OK})."
    log "[6/6] ⚠️ KEEPING instance ALIVE for manual rescue/inspection (HDF5 may still be on S3). Terminate manually after recovery: aws ec2 terminate-instances --instance-ids <id> --region ${REGION}"
    AUTO_TERMINATE="false"
fi
{% endif %}
if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[6/6] Auto-terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== GR00T-G1 UserData complete ====="
