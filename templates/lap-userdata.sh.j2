#!/bin/bash
# LAP-3B 1-Click UserData Script (LIBERO sim, local mode only)
# Repo:       https://github.com/lihzha/lap @ {{ lap_commit[:8] if lap_commit else 'HEAD' }}
# Checkpoint: {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }})
# Pattern:    openpi-style two-venv split — Py3.11+JAX policy server + Py3.8+cu113 LIBERO client
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with:
#   python generate.py --vla lap
#
# CloudFormation Fn::Sub placeholders (resolved at deploy time):
#   ${S3BucketName}       — results S3 bucket
#   ${SnsTopicArn}        — completion notification SNS topic
#   ${StackName}          — CDK stack name
#   ${WaitConditionUrl}   — CFN WaitConditionHandle presigned URL
#   ${Region}             — deployment region
#   ${AutoTerminate}      — "true" to auto-terminate EC2 after completion

set -euo pipefail

LAP_DIR=/home/ubuntu/lap
LAP_CKPT_DIR=${LAP_DIR}/checkpoints/lap_libero
LIBERO_VENV=${LAP_DIR}/scripts/libero/.venv
VIDEO_BASE_DIR=/tmp/lap-videos
RESULTS_BASE_DIR=/tmp/lap-results
RUN_ID=$(date '+%Y-%m-%d-%H%M')

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

# UserData runs as root; HOME must be set so uv puts caches in a stable place.
export HOME=/root
export HF_HOME=/home/ubuntu/.cache/huggingface
export OPENPI_DATA_HOME=/root/.cache/openpi
# uv installs into ~/.local/bin
export PATH="/root/.local/bin:${PATH}"

log() { echo "[LAP] $(date '+%H:%M:%S') $*" | tee -a /var/log/lap-userdata.log; }

cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/lap-userdata.log \
        && log "cfn_signal $_status sent" \
        || log "[warn] cfn_signal send failed (continuing)"
}

die() {
    log "ERROR: $*"
    # Best-effort: dump diagnostics to S3 before CFN rollback eats the instance
    if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
        local _diag_prefix="s3://${S3_BUCKET}/${RUN_ID:-unknown-run}/diag-fail"
        log "  Uploading /tmp/lap_*.log to ${_diag_prefix}..."
        aws s3 cp /var/log/lap-userdata.log "${_diag_prefix}/userdata.log" --region "$REGION" 2>/dev/null || true
        for _f in /tmp/lap_*.log; do
            [ -f "$_f" ] || continue
            aws s3 cp "$_f" "${_diag_prefix}/$(basename "$_f")" --region "$REGION" 2>/dev/null || true
        done
        # Snapshot the LIBERO venv pip list (if it exists) — common failure point
        if [ -x "${LIBERO_VENV:-/nonexistent}/bin/python" ]; then
            "${LIBERO_VENV}/bin/python" -m pip list 2>&1 \
                | aws s3 cp - "${_diag_prefix}/libero_venv_pip_list.txt" --region "$REGION" 2>/dev/null || true
        fi
    fi
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

# Stop server on script exit (success or failure)
SERVER_PID=""
_cleanup_server() {
    if [ -n "${SERVER_PID}" ] && kill -0 "${SERVER_PID}" 2>/dev/null; then
        log "[cleanup] Stopping policy server (PID ${SERVER_PID})..."
        kill "${SERVER_PID}" 2>/dev/null || true
        sleep 2
        kill -9 "${SERVER_PID}" 2>/dev/null || true
    fi
}
trap '_cleanup_server' EXIT

log "===== LAP UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/7] System dependencies ──────────────────────────────────────
log "[1/7] Installing system packages..."
export DEBIAN_FRONTEND=noninteractive

systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/lap_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/lap_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    git git-lfs curl ca-certificates awscli jq netcat-openbsd \
    gnupg apt-transport-https \
    libgl1-mesa-glx libegl1 libgles2 \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    ffmpeg build-essential \
    2>&1 | tee /tmp/lap_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

# google-cloud-cli — required by LAP because PaliGemma tokenizer is fetched from
# gs://big_vision/paligemma_tokenizer.model via gsutil (anonymous bucket, no auth).
# DLAMI does not pre-install google-cloud-sdk. Without this, serve_policy.py crashes
# at startup with FileNotFoundError: 'gsutil' inside lap.shared.download._run_gsutil.
log "[1/7] Installing google-cloud-cli (for gsutil)..."
install -d -m 0755 /usr/share/keyrings
curl -fsSL https://packages.cloud.google.com/apt/doc/apt-key.gpg \
    | gpg --dearmor -o /usr/share/keyrings/cloud.google.gpg \
    || die "google-cloud apt key fetch failed"
echo "deb [signed-by=/usr/share/keyrings/cloud.google.gpg] https://packages.cloud.google.com/apt cloud-sdk main" \
    > /etc/apt/sources.list.d/google-cloud-sdk.list
APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/lap_apt_update_gcloud.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update (gcloud repo) failed after 3 retries"
    log "[warn] apt-get update (gcloud) failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done
APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    google-cloud-cli \
    2>&1 | tee /tmp/lap_apt_gcloud.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "google-cloud-cli install failed after 3 retries"
    log "[warn] google-cloud-cli install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done
command -v gsutil >/dev/null 2>&1 || die "gsutil not on PATH after google-cloud-cli install"
log "  gsutil ready: $(gsutil version 2>&1 | head -1)"

# ── [1.5/7] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/7] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/lap/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/lap-userdata.log",
            "log_group_name": "/lap/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/lap_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs local only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs local only"
fi

# ── [2/7] NVIDIA driver check ──────────────────────────────────────
log "[2/7] Checking GPU driver..."
nvidia-smi -L 2>&1 | tee /tmp/lap_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI (continuing with EGL headless)"

# ── [3/7] uv install + LAP repo clone ──────────────────────────────
log "[3/7] Installing uv (DLAMI does not pre-install)..."
if ! command -v uv >/dev/null 2>&1; then
    curl -LsSf https://astral.sh/uv/install.sh | sh 2>&1 | tee /tmp/lap_uv_install.log \
        || die "uv install failed"
fi
log "  $(uv --version)"

log "[3/7] Cloning LAP @ {{ lap_commit[:8] if lap_commit else 'HEAD' }} (with submodules)..."
if [ ! -d "${LAP_DIR}" ]; then
    git clone --recurse-submodules https://github.com/lihzha/lap.git "${LAP_DIR}" \
        2>&1 | tee /tmp/lap_clone.log \
        || die "LAP clone failed"
{%- if lap_commit %}
    git -C "${LAP_DIR}" checkout "{{ lap_commit }}" \
        || die "LAP: checkout pinned commit {{ lap_commit[:8] }} failed"
    git -C "${LAP_DIR}" submodule update --init --recursive \
        2>&1 | tee -a /tmp/lap_clone.log \
        || die "LAP: submodule update after checkout failed"
{%- endif %}
fi
ACTUAL_COMMIT=$(git -C "${LAP_DIR}" rev-parse HEAD)
log "  LAP commit: ${ACTUAL_COMMIT}"

# Sanity: openpi submodule + libero sub-submodule must be present
[ -d "${LAP_DIR}/third_party/openpi" ] || die "openpi submodule missing"
[ -d "${LAP_DIR}/third_party/openpi/third_party/libero" ] || die "libero (via openpi) submodule missing"
[ -f "${LAP_DIR}/scripts/serve_policy.py" ] || die "serve_policy.py not found"
[ -f "${LAP_DIR}/scripts/libero/main.py" ] || die "scripts/libero/main.py not found"

# ── [4/7] LAP main venv (Py3.11 + JAX[cuda12]) ────────────────────
# `uv sync --group cuda` provisions Python 3.11, jax[cuda12]==0.5.3, flax, transformers, etc.
# GIT_LFS_SKIP_SMUDGE=1 is precautionary — LAP repo has no LFS, but transitive deps may.
log "[4/7] Provisioning LAP main venv (uv sync --group cuda, ~10-15min)..."
cd "${LAP_DIR}"
GIT_LFS_SKIP_SMUDGE=1 uv sync --group cuda 2>&1 | tee /tmp/lap_uv_sync.log \
    || die "LAP uv sync --group cuda failed (see /tmp/lap_uv_sync.log)"
GIT_LFS_SKIP_SMUDGE=1 uv pip install -e . 2>&1 | tee /tmp/lap_uv_install_e.log \
    || die "LAP editable install failed"

# Verify JAX sees the GPU before we waste time downloading the checkpoint.
log "[4/7] Verifying JAX GPU visibility..."
JAX_PLATFORMS=cuda uv run --group cuda --active python -c "
import jax
print('jax version:', jax.__version__)
print('jax devices:', jax.devices())
assert any(d.platform == 'gpu' for d in jax.devices()), 'No GPU device visible to JAX'
" 2>&1 | tee /tmp/lap_jax_check.log \
    || die "JAX GPU check failed (see /tmp/lap_jax_check.log)"

# ── [5/7] LIBERO sim venv (Py3.8 + cu113 PyTorch CPU-only) ────────
# LIBERO sim requires Python 3.8 + numpy 1.22.4 + mujoco 3.2.3, conflicting with the LAP main
# venv (Py3.11). Per scripts/libero/README.md, BOTH requirements files must be synced together
# (scripts/libero/requirements.txt + third_party/openpi/third_party/libero/requirements.txt).
log "[5/7] Provisioning LIBERO sim venv (Py3.8, ~8-12min)..."
cd "${LAP_DIR}"
uv venv --python 3.8 scripts/libero/.venv 2>&1 | tee /tmp/lap_libero_venv.log \
    || die "LIBERO venv create (uv venv --python 3.8) failed"

[ -f scripts/libero/requirements.txt ] || die "scripts/libero/requirements.txt not found"
[ -f third_party/openpi/third_party/libero/requirements.txt ] || \
    die "third_party/openpi/third_party/libero/requirements.txt not found"

set -o pipefail
uv pip sync \
    --python "${LIBERO_VENV}/bin/python" \
    scripts/libero/requirements.txt \
    third_party/openpi/third_party/libero/requirements.txt \
    --extra-index-url https://download.pytorch.org/whl/cu113 \
    --index-strategy=unsafe-best-match \
    2>&1 | tee /tmp/lap_libero_pip_sync.log \
    || die "LIBERO uv pip sync failed (see /tmp/lap_libero_pip_sync.log)"
log "  uv pip sync OK — packages installed: $("${LIBERO_VENV}/bin/python" -m pip list 2>/dev/null | wc -l)"

# Editable installs: openpi-client (websocket policy client) + libero (sim)
uv pip install \
    --python "${LIBERO_VENV}/bin/python" \
    -e third_party/openpi/packages/openpi-client \
    2>&1 | tee /tmp/lap_libero_openpi_client.log \
    || die "openpi-client editable install failed"
# LIBERO uses namespace-package layout (libero/libero/ with no top-level libero/__init__.py).
# Modern PEP 660 editable installs fail to resolve `libero.libero` from this layout, so use
# legacy .pth-based editable mode (same workaround as openvla-oft).
uv pip install \
    --python "${LIBERO_VENV}/bin/python" \
    -e third_party/openpi/third_party/libero \
    --config-settings editable_mode=compat \
    2>&1 | tee /tmp/lap_libero_install.log \
    || die "libero editable install failed"

# Pre-create LIBERO config.yaml so the namespace package's first import doesn't hit interactive
# input() (same workaround as openvla-oft). LAP's main.py uses `from libero.libero import ...`
# which triggers config.yaml creation logic in libero/libero/__init__.py.
log "[5/7] Pre-creating LIBERO config.yaml..."
mkdir -p /root/.libero
LIBERO_PKG_DIR="${LAP_DIR}/third_party/openpi/third_party/libero/libero/libero"
cat > /root/.libero/config.yaml << LIBEROCFG
assets: ${LIBERO_PKG_DIR}/assets
bddl_files: ${LIBERO_PKG_DIR}/bddl_files
benchmark_root: ${LIBERO_PKG_DIR}
datasets: ${LIBERO_PKG_DIR}/../datasets
init_states: ${LIBERO_PKG_DIR}/init_files
LIBEROCFG

# Verify imports in the LIBERO venv before we spend time on eval.
# LAP main.py uses `from libero.libero import benchmark` (namespace package layout — top-level
# `import libero` would fail because libero/__init__.py is intentionally absent).
# Use the same LIBERO_CONFIG_PATH as the eval phase so this check exercises the real path:
# libero/__init__.py reads ${LIBERO_CONFIG_PATH}/config.yaml or falls back to interactive input().
log "[5/7] Verifying LIBERO venv imports (libero.libero, mujoco, openpi_client)..."
LIBERO_CONFIG_PATH=/root/.libero "${LIBERO_VENV}/bin/python" -c "
from libero.libero import benchmark
import mujoco, openpi_client
print('libero.libero.benchmark:', benchmark.__file__)
print('mujoco:', mujoco.__version__)
print('openpi_client:', openpi_client.__file__)
" 2>&1 | tee /tmp/lap_libero_import_check.log \
    || die "LIBERO venv import check failed (see /tmp/lap_libero_import_check.log)"

# ── [5/7] Patch LAP main.py image flip (upstream bug) ─────────────
# LAP scripts/libero/main.py:279-285 has a comment↔code mismatch:
#   author's comment says obs["...image"][::-1, ::-1] (vertical+horizontal flip),
#   but the code is obs["...image"][:, ::-1] (horizontal only).
# LIBERO mujoco renders images upside-down by convention (other VLA evals — openpi,
# openvla-oft — use [::-1, ::-1]). The current LAP code feeds vertically-flipped
# images to both the policy AND the rollout video writer, so:
#   1. videos appear upside-down on output, and
#   2. policy receives malformed input → success rate drops far below paper Table III.
# Patch is idempotent (sed only matches the buggy form).
log "[5/7] Patching LAP scripts/libero/main.py image flip (upstream comment↔code mismatch)..."
LAP_MAIN_PY="${LAP_DIR}/scripts/libero/main.py"
[ -f "${LAP_MAIN_PY}" ] || die "LAP main.py not found for patch: ${LAP_MAIN_PY}"
sed -i 's|obs\["agentview_image"\]\[:, ::-1\]|obs["agentview_image"][::-1, ::-1]|' "${LAP_MAIN_PY}" \
    || die "sed patch (agentview_image) failed"
sed -i 's|obs\["robot0_eye_in_hand_image"\]\[:, ::-1\]|obs["robot0_eye_in_hand_image"][::-1, ::-1]|' "${LAP_MAIN_PY}" \
    || die "sed patch (robot0_eye_in_hand_image) failed"
# Verify both patches applied (must contain new form, must NOT contain old form)
grep -q 'obs\["agentview_image"\]\[::-1, ::-1\]' "${LAP_MAIN_PY}" \
    || die "agentview_image patch verification failed"
grep -q 'obs\["robot0_eye_in_hand_image"\]\[::-1, ::-1\]' "${LAP_MAIN_PY}" \
    || die "robot0_eye_in_hand_image patch verification failed"
! grep -q 'obs\["agentview_image"\]\[:, ::-1\]' "${LAP_MAIN_PY}" \
    || die "agentview_image old form still present after patch"
log "  main.py image flip patched (vertical+horizontal flip)"

# ── [6/7] HF checkpoint download ───────────────────────────────────
mkdir -p "${LAP_CKPT_DIR}"
{% if hf_model_revision %}
log "[6/7] Downloading HF checkpoint {{ hf_repo }} (rev {{ hf_model_revision[:8] }})..."
cd "${LAP_DIR}"
uv run --group cuda --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download(
    '{{ hf_repo }}',
    revision='{{ hf_model_revision }}',
    local_dir='${LAP_CKPT_DIR}',
)
print('checkpoint downloaded to:', path)
" 2>&1 | tee /tmp/lap_hf_download.log \
    || die "HF checkpoint download failed (see /tmp/lap_hf_download.log)"
{% else %}
log "[6/7] HF revision not pinned — downloading latest from {{ hf_repo }}..."
cd "${LAP_DIR}"
uv run --group cuda --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}', local_dir='${LAP_CKPT_DIR}')
print('checkpoint downloaded to:', path)
" 2>&1 | tee /tmp/lap_hf_download.log \
    || die "HF checkpoint download failed"
{% endif %}

# ── [7/7] Start policy server, then run LIBERO eval per task ──────
export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl
mkdir -p "${VIDEO_BASE_DIR}" "${RESULTS_BASE_DIR}"

# Start serve_policy.py once — it handles all LIBERO suites under policy_config={{ policy_config }}.
log "[7/7] Starting LAP policy server (background, port 8000)..."
cd "${LAP_DIR}"
SERVER_LOG=/tmp/lap_server.log
JAX_PLATFORMS=cuda nohup uv run --group cuda --active scripts/serve_policy.py \
    policy:checkpoint \
    --policy.config={{ policy_config }} \
    --policy.dir="${LAP_CKPT_DIR}" \
    --policy.type={{ policy_type }} \
    > "${SERVER_LOG}" 2>&1 &
SERVER_PID=$!
log "  Policy server started (PID ${SERVER_PID}) — waiting for port 8000..."

# Wait up to 15min for server. 3B JAX checkpoint mmap + JIT compile of the flow-matching
# action expert is slow first time on a fresh instance (no XLA cache). Empirically observed
# ~5min just for cuDNN/cuBLAS factory registration; full JIT compile pushes well past that.
SERVER_TIMEOUT=900
SERVER_WAIT=0
SERVER_OK=false
while [ ${SERVER_WAIT} -lt ${SERVER_TIMEOUT} ]; do
    if ! kill -0 "${SERVER_PID}" 2>/dev/null; then
        log "  [error] policy server process exited prematurely"
        tail -100 "${SERVER_LOG}" | tee -a /var/log/lap-userdata.log
        # Make sure server log makes it to S3 before the instance is rolled back
        aws s3 cp "${SERVER_LOG}" "s3://${S3_BUCKET}/${RUN_ID}/diag-fail/lap_server.log" \
            --region "$REGION" 2>/dev/null || true
        die "policy server died during startup (see /tmp/lap_server.log)"
    fi
    if nc -z localhost 8000 2>/dev/null; then
        SERVER_OK=true
        break
    fi
    sleep 10
    SERVER_WAIT=$((SERVER_WAIT + 10))
    # Periodic heartbeat so CW logs show progress and we can spot a hung server
    if [ $((SERVER_WAIT % 60)) -eq 0 ]; then
        log "  Policy server still warming up (${SERVER_WAIT}s elapsed, last server line: $(tail -1 "${SERVER_LOG}" 2>/dev/null | head -c 200))"
    fi
done
if [ "${SERVER_OK}" != true ]; then
    aws s3 cp "${SERVER_LOG}" "s3://${S3_BUCKET}/${RUN_ID}/diag-fail/lap_server.log" \
        --region "$REGION" 2>/dev/null || true
    die "policy server did not bind port 8000 within ${SERVER_TIMEOUT}s (see /tmp/lap_server.log + diag-fail/)"
fi
log "  Policy server ready (${SERVER_WAIT}s)"

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    SUITE=$(echo "$TASK" | jq -r '.suite')
    NUM_TRIALS=$(echo "$TASK" | jq -r '.num_trials_per_task')
    DESCRIPTION=$(echo "$TASK" | jq -r '.description // ""')

    VIDEO_DIR="${VIDEO_BASE_DIR}/task-${TASK_IDX}"
    RESULTS_FILE="${RESULTS_BASE_DIR}/task-${TASK_IDX}.json"
    mkdir -p "$VIDEO_DIR"

    log "[7/7] Task $((TASK_IDX+1))/${TASK_COUNT}: suite=${SUITE}, num_trials_per_task=${NUM_TRIALS}"
    touch /tmp/lap_task${TASK_IDX}_start.marker

    # Run LIBERO eval — uses the Py3.8 venv so the websocket client (openpi_client) and
    # mujoco/robosuite resolve to the right ABI.
    #
    # LIBERO_CONFIG_PATH must point at the dir containing the pre-created config.yaml
    # (/root/.libero), NOT at the libero source tree. libero/__init__.py looks up
    # `${LIBERO_CONFIG_PATH:-~/.libero}/config.yaml`; if that file is absent it falls
    # back to interactive `input()`, which crashes with EOFError on a non-tty userdata.
    # PYTHONPATH still needs the openpi/libero source tree so `import libero.libero`
    # resolves to the namespace package (editable install with editable_mode=compat).
    set +e
    (
        cd "${LAP_DIR}/scripts/libero"
        export LIBERO_CONFIG_PATH=/root/.libero
        export PYTHONPATH="${LAP_DIR}/third_party/openpi/third_party/libero:${PYTHONPATH:-}"
        # tyro CLI uses nested Args: `tyro.cli(eval_libero)` where eval_libero(args: Args).
        # All flags must therefore be prefixed with --args.<name>. tyro accepts both
        # underscore and dash variants; we use underscores to match the dataclass field
        # names exactly.
        "${LIBERO_VENV}/bin/python" main.py \
            --args.task_suite_name "${SUITE}" \
            --args.num_trials_per_task "${NUM_TRIALS}" \
            --args.policy_type LAP \
            --args.video_out_path "${VIDEO_DIR}" \
            --args.results_out_path "${RESULTS_FILE}"
    ) 2>&1 | tee "/tmp/lap_task${TASK_IDX}.log"
    EVAL_EXIT=${PIPESTATUS[0]}
    set -e
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        log "  [error] Task ${TASK_IDX} eval exit=${EVAL_EXIT} — will fail after uploading diagnostics"
    fi

    VIDEO_COUNT=$(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | wc -l)
    log "  Videos collected: ${VIDEO_COUNT}"

    # Parse success rate.
    # Preferred: results JSON written by main.py. Fallback: log scrape.
    SR="unknown"
    if [ -f "${RESULTS_FILE}" ]; then
        SR=$(jq -r '.success_rate // .total_success_rate // .overall_success_rate // empty' \
            "${RESULTS_FILE}" 2>/dev/null || echo "")
    fi
    if [ -z "${SR}" ] || [ "${SR}" = "unknown" ]; then
        SR=$(grep -oiE 'success.rate[: ]+[0-9.]+' "/tmp/lap_task${TASK_IDX}.log" 2>/dev/null \
            | tail -1 | grep -oE '[0-9.]+$' || echo "unknown")
    fi
    log "  success_rate=${SR}"

    {
        echo "model: lap-3b"
        echo "checkpoint: {{ hf_repo }}@{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
        echo "policy_config: {{ policy_config }}"
        echo "policy_type: {{ policy_type }}"
        echo "suite: ${SUITE}"
        echo "num_trials_per_task: ${NUM_TRIALS}"
        echo "success_rate: ${SR}"
        echo "description: ${DESCRIPTION}"
    } > "/tmp/lap_task${TASK_IDX}_summary.txt"

    # S3 upload (videos + logs + results JSON + summary)
    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"
    UPLOAD_COUNT=0
    while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
        [ -f "$mp4_file" ] || continue
        fname=$(basename "$mp4_file")
        base="${fname%.mp4}"

        # Per-video context txt
        txt_file="/tmp/lap_ctx_task${TASK_IDX}_ep${UPLOAD_COUNT}.txt"
        {
            echo "=== LAP-3B Simulation Context ==="
            printf "Video:      %s\n"  "${fname}"
            printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
            echo ""
            echo "--- Environment ---"
            printf "Suite:      %s\n"  "${SUITE}"
            printf "Robot:      Franka Panda 7-DOF (LIBERO via openpi submodule)\n"
            echo ""
            echo "--- Model ---"
            printf "Checkpoint: %s (rev %s)\n" "{{ hf_repo }}" "{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
            printf "Repo:       https://github.com/lihzha/lap (%s)\n" "{{ lap_commit[:8] if lap_commit else 'HEAD' }}"
            printf "Backbone:   PaliGemma-3B + Flow Matching action expert (JAX)\n"
            echo ""
            echo "--- Rollout ---"
            printf "run_id:        %s\n"  "${RUN_ID}"
            printf "task_idx:      %s\n"  "${TASK_IDX}"
            printf "total_success: %s (suite avg)\n" "${SR}"
            echo ""
            echo "--- Infrastructure ---"
            printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
            printf "Region:   %s\n"  "${REGION}"
            printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
        } > "$txt_file"

        if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/${fname}" \
            --region "$REGION" 2>&1 | tee -a /var/log/lap-userdata.log; then
            UPLOAD_COUNT=$((UPLOAD_COUNT+1))
            aws s3 cp "$txt_file" "${S3_TASK_PREFIX}/videos/${base}.txt" \
                --region "$REGION" 2>/dev/null || true
        else
            log "  [warn] Upload failed: $fname"
        fi
    done < <(find "$VIDEO_DIR" -name "*.mp4" 2>/dev/null | sort)
    log "  Videos uploaded: ${UPLOAD_COUNT}/${VIDEO_COUNT}"

    aws s3 cp "/tmp/lap_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/eval.log" --region "$REGION" || true
    [ -f "${RESULTS_FILE}" ] && \
        aws s3 cp "${RESULTS_FILE}" \
        "${S3_TASK_PREFIX}/results.json" --region "$REGION" || true
    [ -f "/tmp/lap_task${TASK_IDX}_summary.txt" ] && \
        aws s3 cp "/tmp/lap_task${TASK_IDX}_summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

    SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${SUITE} — success_rate=${SR} (${NUM_TRIALS} trials/task × 10 tasks)"
    log "  Task $((TASK_IDX+1)) done"

    # Hard-fail after S3 upload if eval crashed. Prevents silent CFN SUCCESS when
    # eval never produced rollouts (e.g., websocket handshake failure, import errors).
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        # Capture last bit of server log for postmortem
        if [ -f "${SERVER_LOG}" ]; then
            aws s3 cp "${SERVER_LOG}" "${S3_TASK_PREFIX}/server.log" --region "$REGION" || true
        fi
        die "Task ${TASK_IDX} eval failed (exit=${EVAL_EXIT}) — see s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}/eval.log"
    fi
    if [ "${VIDEO_COUNT}" -eq 0 ]; then
        if [ -f "${SERVER_LOG}" ]; then
            aws s3 cp "${SERVER_LOG}" "${S3_TASK_PREFIX}/server.log" --region "$REGION" || true
        fi
        die "Task ${TASK_IDX} produced 0 rollouts — eval likely short-circuited (see s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}/eval.log)"
    fi
done

# Upload server log for the run (always — useful even on success)
aws s3 cp "${SERVER_LOG}" "s3://${S3_BUCKET}/${RUN_ID}/server.log" --region "$REGION" || true

# Stop server explicitly before signalling success
_cleanup_server
SERVER_PID=""

# ── Notification + cfn-signal ────────────────────────────────────
log "Sending SNS notification..."

SNS_MESSAGE="[${STACK_NAME}] LAP-3B simulation complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

Model: LAP-3B (PaliGemma-3B + Flow Matching, JAX)
Checkpoint: {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }})
Simulation: LIBERO via openpi submodule (robosuite + MuJoCo, headless EGL)
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./lap-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py --vla lap"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "LAP-3B simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "Sending cfn-signal..."
cfn_signal 0

if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== LAP UserData complete ====="
