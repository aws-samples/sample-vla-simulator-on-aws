# FIX 6/7 ({{ sim_id }}-only) — RLDXSimPolicyWrapper.check_observation/_get_action are LIBERO-only
# at this pin. SIMPLER envs emit decomposed state.x/y/z + quaternion rx/ry/rz/rw + gripper and
# expect decomposed action.x/y/z/roll/pitch/yaw/gripper back, but the {{ embodiment_tag }} model
# wants state+action keys end_effector_position / end_effector_rotation / gripper_{position,close}.
# Worse, is_libero = ("state.x" in obs or "video.image" in obs) misfires True for SIMPLER (has
# both) → fractal actions wrongly routed through the eef_pos_delta branch → empty action →
# server check_action fails. Patch rldx/policy/rldx_policy.py to add the SIMPLER obs adapter
# (FIX 6) + action adapter (FIX 7). Dims verified EXACT vs ckpt statistics.json (eef_pos=3,
# eef_rot quat=4 obs / euler=3 action, gripper=1). Gate-1: 100% SR over 10 eps after this.
# Runtime clone ONLY (vendoring-0 invariant). Patch is a python script (multi-line, indentation-
# sensitive → not sed). Idempotent via markers; verifies the file still compiles.
log "[5/8] FIX 6/7: patching rldx_policy.py SIMPLER obs+action adapter..."
RLDX_POLICY_PY="${RLDX_DIR}/rldx/policy/rldx_policy.py"
"${RLDX_DIR}/.venv/bin/python" - "${RLDX_POLICY_PY}" <<'RLDX_FIX67_EOF' 2>&1 | tee /tmp/rldx_fix67.log
import sys, py_compile
P = sys.argv[1]
src = open(P).read()

OBS_MARKER = "# ===== SIMPLER KEY MAPPING (FIX 6) ====="
ACT_MARKER = "# ===== SIMPLER ACTION MAPPING (FIX 7) ====="

# FIX 6 — observation adapter. Insert right before the "# ===== VIDEO VALIDATION =====" comment
# inside check_observation (i.e. immediately after the LIBERO mapping block).
if OBS_MARKER not in src:
    obs_anchor = "        # ===== VIDEO VALIDATION ====="
    if obs_anchor not in src:
        print("FIX 6 FAIL: VIDEO VALIDATION anchor not found — commit drift?"); sys.exit(1)
    obs_block = '''        ''' + OBS_MARKER + '''
        # SIMPLER emits a quaternion (state.rw present); LIBERO does not. Synthesise the model's
        # fractal/bridge state keys. Dims verified vs statistics.json: eef_pos=3, eef_rot=4(xyzw),
        # gripper=1. Applied post-batching → arrays are already (B,T,D).
        if "state.rw" in observation:
            if all(k in observation for k in ("state.x", "state.y", "state.z")):
                observation["state.end_effector_position"] = np.concatenate(
                    [observation["state.x"], observation["state.y"], observation["state.z"]], axis=-1
                )
            if all(k in observation for k in ("state.rx", "state.ry", "state.rz", "state.rw")):
                observation["state.end_effector_rotation"] = np.concatenate(
                    [observation["state.rx"], observation["state.ry"],
                     observation["state.rz"], observation["state.rw"]], axis=-1
                )
            if "state.gripper" in observation:
                observation["state.gripper_position"] = observation["state.gripper"]

'''
    src = src.replace(obs_anchor, obs_block + obs_anchor, 1)
    print("FIX 6 applied")
else:
    print("FIX 6 already present")

# FIX 7 — action adapter. Insert right after the is_libero computation inside the sim-wrapper
# _get_action. SIMPLER (state.rw present) must NOT take the LIBERO branch and must emit BOTH the
# fractal action keys (server check_action) and the decomposed keys (client env.step()).
if ACT_MARKER not in src:
    act_anchor = '        is_libero = "state.x" in observation or "video.image" in observation\n'
    if act_anchor not in src:
        print("FIX 7 FAIL: is_libero anchor not found — commit drift?"); sys.exit(1)
    act_block = act_anchor + '''
        ''' + ACT_MARKER + '''
        # Gate-1 verified the model returns keys: end_effector_position / end_effector_rotation /
        # gripper_close. Emit the fractal keys (server validates) AND decomposed keys (env reads).
        is_simpler = "state.rw" in observation
        if is_simpler:
            is_libero = False
            flat_actions = {f"action.{k}": action[k] for k in action}
            if "end_effector_position" in action:
                eep = action["end_effector_position"]
                flat_actions["action.x"] = eep[..., 0:1]
                flat_actions["action.y"] = eep[..., 1:2]
                flat_actions["action.z"] = eep[..., 2:3]
            if "end_effector_rotation" in action:
                eer = action["end_effector_rotation"]
                flat_actions["action.roll"] = eer[..., 0:1]
                flat_actions["action.pitch"] = eer[..., 1:2]
                flat_actions["action.yaw"] = eer[..., 2:3]
            if "gripper_close" in action:
                # simpler_env.step() runs _postprocess_gripper(action.gripper) itself.
                flat_actions["action.gripper"] = action["gripper_close"]
            return flat_actions, info
'''
    src = src.replace(act_anchor, act_block, 1)
    print("FIX 7 applied")
else:
    print("FIX 7 already present")

open(P, "w").write(src)
try:
    py_compile.compile(P, doraise=True)
    print("FIX 6/7 OK — rldx_policy.py compiles")
except py_compile.PyCompileError as e:
    print("FIX 6/7 FAIL: rldx_policy.py no longer compiles:", e); sys.exit(1)
RLDX_FIX67_EOF
grep -qF 'SIMPLER ACTION MAPPING (FIX 7)' "${RLDX_POLICY_PY}" \
    || die "FIX 6/7: patch did not apply to rldx_policy.py (see /tmp/rldx_fix67.log)"
# Clear stale bytecode so the edited source is the one imported by the sim venv.
find "${RLDX_DIR}/rldx/policy" -name '*.pyc' -delete 2>/dev/null || true
rm -rf "${RLDX_DIR}/rldx/policy/__pycache__" 2>/dev/null || true
log "  FIX 6/7 applied — SIMPLER obs+action adapter installed"
{% endif %}
