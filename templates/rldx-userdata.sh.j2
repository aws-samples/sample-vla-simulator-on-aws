        || die "FIX 10: expected video-collector line not found in video_recording_wrapper.py — commit drifted?"
    sed -i 's/if "video" in k:/if "video" in k and "res512" not in k:  # FIX 10: drop res512 duplicates/' "${VIDREC_PY}"
    grep -qF 'res512' "${VIDREC_PY}" \
        || die "FIX 10: sed did not apply the res512 filter (see ${VIDREC_PY})"
    "${RLDX_DIR}/.venv/bin/python" -c "import py_compile; py_compile.compile('${VIDREC_PY}', doraise=True)" \
        || die "FIX 10: video_recording_wrapper.py no longer compiles after patch"
