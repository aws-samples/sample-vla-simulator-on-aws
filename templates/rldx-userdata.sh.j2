#!/bin/bash
# RLDX-1 (RLWRLD) 1-Click UserData Script (LIBERO sim, local mode only)
# Repo:       https://github.com/RLWRLD/RLDX-1 @ {{ rldx_commit[:8] if rldx_commit else 'HEAD' }} (code Apache-2.0)
# Checkpoint: {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}) — RLWRLD Model License v1.0 (NON-COMMERCIAL)
# Pattern:    RLWRLD's own server + client split — main .venv (torch 2.7.0) ZeroMQ policy server
#             + libero_uv venv (torch 2.5.1) LIBERO sim client. Mirrors LAP topology.
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with:
#   python generate.py --vla rldx
#
# LICENSE: weights are non-commercial (simulation benchmarking is an intended use).
# Weights are downloaded from HF at runtime (not vendored). AWS-internal enablement only.
#
# CloudFormation Fn::Sub placeholders (resolved at deploy time):
#   ${S3BucketName}       — results S3 bucket
#   ${SnsTopicArn}        — completion notification SNS topic
#   ${StackName}          — CDK stack name
#   ${WaitConditionUrl}   — CFN WaitConditionHandle presigned URL
#   ${Region}             — deployment region
#   ${AutoTerminate}      — "true" to auto-terminate EC2 after completion

set -euo pipefail

RLDX_DIR=/home/ubuntu/RLDX-1
RLDX_CKPT_DIR=/home/ubuntu/.cache/rldx/ckpt
# RLWRLD's setup_libero.sh builds this venv at a fixed in-repo path:
LIBERO_VENV=${RLDX_DIR}/rldx/eval/sim/LIBERO/libero_uv/.venv
VIDEO_BASE_DIR=/tmp/rldx-videos
RUN_ID=$(date '+%Y-%m-%d-%H%M')

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

# UserData runs as root; HOME must be set so uv puts caches in a stable place.
export HOME=/root
export HF_HOME=/home/ubuntu/.cache/huggingface
export NO_ALBUMENTATIONS_UPDATE=1
# uv installs into ~/.local/bin
export PATH="/root/.local/bin:${PATH}"

log() { echo "[RLDX] $(date '+%H:%M:%S') $*" | tee -a /var/log/rldx-userdata.log; }

cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/rldx-userdata.log \
        && log "cfn_signal $_status sent" \
        || log "[warn] cfn_signal send failed (continuing)"
}

die() {
    log "ERROR: $*"
    # Best-effort: dump diagnostics to S3 before CFN rollback eats the instance
    if [ -n "${S3_BUCKET:-}" ] && [ -n "${REGION:-}" ]; then
        local _diag_prefix="s3://${S3_BUCKET}/${RUN_ID:-unknown-run}/diag-fail"
        log "  Uploading /tmp/rldx_*.log to ${_diag_prefix}..."
        aws s3 cp /var/log/rldx-userdata.log "${_diag_prefix}/userdata.log" --region "$REGION" 2>/dev/null || true
        for _f in /tmp/rldx_*.log; do
            [ -f "$_f" ] || continue
            aws s3 cp "$_f" "${_diag_prefix}/$(basename "$_f")" --region "$REGION" 2>/dev/null || true
        done
        # Snapshot the LIBERO venv pip list (if it exists) — common failure point
        if [ -x "${LIBERO_VENV:-/nonexistent}/bin/python" ]; then
            "${LIBERO_VENV}/bin/python" -m pip list 2>&1 \
                | aws s3 cp - "${_diag_prefix}/libero_venv_pip_list.txt" --region "$REGION" 2>/dev/null || true
        fi
    fi
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

# Stop the policy server on script exit (success or failure)
SERVER_PID=""
_cleanup_server() {
    if [ -n "${SERVER_PID}" ] && kill -0 "${SERVER_PID}" 2>/dev/null; then
        log "[cleanup] Stopping policy server (PID ${SERVER_PID})..."
        kill "${SERVER_PID}" 2>/dev/null || true
        sleep 2
        kill -9 "${SERVER_PID}" 2>/dev/null || true
    fi
}
trap '_cleanup_server' EXIT

log "===== RLDX-1 UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/8] System dependencies ──────────────────────────────────────
log "[1/8] Installing system packages..."
export DEBIAN_FRONTEND=noninteractive

systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/rldx_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/rldx_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    git git-lfs curl ca-certificates awscli jq iproute2 \
    libgl1-mesa-glx libegl1 libgles2 \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    ffmpeg build-essential \
    2>&1 | tee /tmp/rldx_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

# ── [1.5/8] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/8] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/rldx/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/rldx-userdata.log",
            "log_group_name": "/rldx/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/rldx_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs local only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs local only"
fi

# ── [2/8] NVIDIA driver check ──────────────────────────────────────
log "[2/8] Checking GPU driver..."
nvidia-smi -L 2>&1 | tee /tmp/rldx_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI (continuing with EGL headless)"

# ── [3/8] uv install + RLDX-1 repo clone ───────────────────────────
log "[3/8] Installing uv (DLAMI does not pre-install)..."
if ! command -v uv >/dev/null 2>&1; then
    curl -LsSf https://astral.sh/uv/install.sh | sh 2>&1 | tee /tmp/rldx_uv_install.log \
        || die "uv install failed"
fi
log "  $(uv --version)"

log "[3/8] Cloning RLDX-1 @ {{ rldx_commit[:8] if rldx_commit else 'HEAD' }}..."
if [ ! -d "${RLDX_DIR}" ]; then
    git clone https://github.com/RLWRLD/RLDX-1.git "${RLDX_DIR}" \
        2>&1 | tee /tmp/rldx_clone.log \
        || die "RLDX-1 clone failed"
{%- if rldx_commit %}
    git -C "${RLDX_DIR}" checkout "{{ rldx_commit }}" \
        || die "RLDX-1: checkout pinned commit {{ rldx_commit[:8] }} failed"
{%- endif %}
fi
ACTUAL_COMMIT=$(git -C "${RLDX_DIR}" rev-parse HEAD)
log "  RLDX-1 commit: ${ACTUAL_COMMIT}"

[ -f "${RLDX_DIR}/rldx/eval/run_rldx_server.py" ] || die "run_rldx_server.py not found"
[ -f "${RLDX_DIR}/rldx/eval/rollout_policy.py" ] || die "rollout_policy.py not found"

# ── [4/8] RLDX-1 main venv (Py3.10 + torch 2.7.0+cu126) ────────────
# Per README: `uv sync --python 3.10` then `uv pip install -e .`. This provisions the
# model/server deps including flash-attn 2.7.4.post1 (Phase 0: prebuilt wheel imports +
# runs on sm_89 — no source build, no sm_120 dependency on the eager eval path).
log "[4/8] Provisioning RLDX-1 main venv (uv sync --python 3.10, ~10-15min)..."
cd "${RLDX_DIR}"
GIT_LFS_SKIP_SMUDGE=1 uv sync --python 3.10 2>&1 | tee /tmp/rldx_uv_sync.log \
    || die "RLDX-1 uv sync failed (see /tmp/rldx_uv_sync.log)"
GIT_LFS_SKIP_SMUDGE=1 uv pip install -e . 2>&1 | tee /tmp/rldx_uv_install_e.log \
    || die "RLDX-1 editable install failed"

# Verify the main venv imports rldx and torch sees the GPU before downloading the checkpoint.
log "[4/8] Verifying main venv (import rldx, torch CUDA visibility, flash-attn)..."
uv run --active python -c "
import torch, rldx
print('rldx:', getattr(rldx, '__version__', 'n/a'))
print('torch:', torch.__version__, 'cuda available:', torch.cuda.is_available())
assert torch.cuda.is_available(), 'CUDA not visible to torch'
cap = torch.cuda.get_device_capability()
print('device capability:', cap)
import flash_attn
print('flash_attn:', flash_attn.__version__)
" 2>&1 | tee /tmp/rldx_main_import_check.log \
    || die "main venv import/CUDA check failed (see /tmp/rldx_main_import_check.log)"

# ── [5/8] LIBERO sim venv (RLWRLD setup_libero.sh + 3 required fixes) ──
# Phase 0 finding: the pinned commit's setup_libero.sh builds the libero_uv venv but its
# final `register_libero_envs` self-test FAILS as-is (it installs rldx --no-deps and pins
# transformers 4.51.3, but rollout_policy.py's top-level `from rldx.data...` triggers eager
# model registration that needs the model deps + transformers 4.57.0). We run their setup
# (tolerating that expected final-test failure), then apply 3 fixes, then verify ourselves.
log "[5/8] Running RLWRLD setup_libero.sh (builds libero_uv venv, ~8-12min)..."
cd "${RLDX_DIR}"
# setup_libero.sh runs `set -euo pipefail` and ends with a register_libero_envs test that
# fails on this commit (see above). Capture exit but DO NOT die on it — the venv is built;
# we repair + re-verify next. A genuinely broken venv is caught by our own import check below.
# NOTE: `set +e` stops errexit from killing the script, but it does NOT disable the ERR trap —
# the failing pipeline still fires `_trap_handler` → `cfn_signal 1` → CloudFormation rollback,
# even though we continue locally. So we must ALSO `trap - ERR` here and re-arm it afterwards.
set +e
trap - ERR
bash run_scripts/eval/libero/setup_libero.sh 2>&1 | tee /tmp/rldx_setup_libero.log
SETUP_EXIT=${PIPESTATUS[0]}
set -e
trap '_trap_handler' ERR
log "  setup_libero.sh exit=${SETUP_EXIT} (final register test expected to fail pre-fix)"
[ -x "${LIBERO_VENV}/bin/python" ] || die "libero_uv venv not created by setup_libero.sh (see /tmp/rldx_setup_libero.log)"

# FIX 1 — model deps missing in LIBERO venv (setup installs rldx --no-deps).
# Mirror the main-venv resolved versions. timm NOT needed (absent from main venv).
log "[5/8] FIX 1: installing model deps into libero_uv venv (diffusers/peft/accelerate)..."
uv pip install --python "${LIBERO_VENV}/bin/python" --no-deps \
    diffusers==0.35.1 peft==0.17.1 accelerate==1.13.0 \
    2>&1 | tee /tmp/rldx_fix1_modeldeps.log \
    || die "FIX 1 (model deps) failed (see /tmp/rldx_fix1_modeldeps.log)"

# FIX 2 — transformers too old. Model code does `from transformers.masking_utils import
# create_causal_mask` (present 4.57.0, absent 4.51.3 that setup pins). Bump to 4.57.0
# (pulls tokenizers 0.22.2; matches main venv). 4.57.0 is yanked on PyPI but installs + works.
log "[5/8] FIX 2: bumping transformers 4.51.3 → 4.57.0 in libero_uv venv..."
uv pip install --python "${LIBERO_VENV}/bin/python" \
    transformers==4.57.0 \
    2>&1 | tee /tmp/rldx_fix2_transformers.log \
    || die "FIX 2 (transformers bump) failed (see /tmp/rldx_fix2_transformers.log)"

# FIX 3 — LIBERO first-run interactive prompt. libero/__init__.py prompts "custom path?(Y/N)"
# via input() → EOFError under non-interactive userdata. Seed /root/.libero/config.yaml once
# by monkeypatching input() (robust vs. setup_libero.sh's fragile `echo "y\n" | ...`).
log "[5/8] FIX 3: seeding /root/.libero/config.yaml (suppress LIBERO interactive prompt)..."
mkdir -p /root/.libero
(
    cd "${RLDX_DIR}"
    "${LIBERO_VENV}/bin/python" -c "
import builtins
builtins.input = lambda *a, **k: 'N'
from rldx.eval.sim.LIBERO.libero_env import register_libero_envs
register_libero_envs()
print('LIBERO config seeded + envs registered')
"
) 2>&1 | tee /tmp/rldx_fix3_libero_seed.log \
    || die "FIX 3 (LIBERO config seed) failed (see /tmp/rldx_fix3_libero_seed.log)"
[ -f /root/.libero/config.yaml ] && log "  LIBERO config: /root/.libero/config.yaml" \
    || log "[warn] /root/.libero/config.yaml not found after seed (may live elsewhere)"

# Verify the LIBERO venv can run the rollout worker's imports + make the target env.
# This is the gate Phase 0 named ROLLOUT_IMPORTS_OK + gym.make(target)=OK.
log "[5/8] Verifying libero_uv venv (rollout imports + gym.make target)..."
FIRST_ENV='{{ tasks[0].env_name if tasks and tasks[0].env_name else "libero_sim/pick_up_the_black_bowl_from_table_center_and_place_it_on_the_plate" }}'
(
    cd "${RLDX_DIR}"
    RLDX_VERIFY_ENV="${FIRST_ENV}" "${LIBERO_VENV}/bin/python" -c "
import os
from rldx.eval.sim.LIBERO.libero_env import register_libero_envs
register_libero_envs()
import gymnasium as gym
env = gym.make(os.environ['RLDX_VERIFY_ENV'])
env.reset(); env.close()
print('ROLLOUT_IMPORTS_OK + gym.make OK:', os.environ['RLDX_VERIFY_ENV'])
"
) 2>&1 | tee /tmp/rldx_libero_import_check.log \
    || die "libero_uv venv import/gym.make check failed (see /tmp/rldx_libero_import_check.log)"

# ── [6/8] HF checkpoint + VLM backbone pre-download ────────────────
mkdir -p "${RLDX_CKPT_DIR}"
cd "${RLDX_DIR}"
{% if hf_model_revision %}
log "[6/8] Downloading checkpoint {{ hf_repo }} (rev {{ hf_model_revision[:8] }})..."
uv run --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download(
    '{{ hf_repo }}',
    revision='{{ hf_model_revision }}',
    local_dir='${RLDX_CKPT_DIR}',
)
print('checkpoint downloaded to:', path)
" 2>&1 | tee /tmp/rldx_hf_download.log \
    || die "HF checkpoint download failed (see /tmp/rldx_hf_download.log)"
{% else %}
log "[6/8] HF revision not pinned — downloading latest from {{ hf_repo }}..."
uv run --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}', local_dir='${RLDX_CKPT_DIR}')
print('checkpoint downloaded to:', path)
" 2>&1 | tee /tmp/rldx_hf_download.log \
    || die "HF checkpoint download failed"
{% endif %}
{% if backbone_hf_repo %}
# VLM backbone is pulled by the checkpoint config at server load. Pre-fetch into HF cache so
# the server's first load doesn't race the warmup timeout fetching ~16GB on a fresh instance.
log "[6/8] Pre-downloading VLM backbone {{ backbone_hf_repo }} into HF cache..."
uv run --active python -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ backbone_hf_repo }}')
print('backbone cached at:', path)
" 2>&1 | tee /tmp/rldx_backbone_download.log \
    || die "VLM backbone download failed (see /tmp/rldx_backbone_download.log)"
{% endif %}

# ── [7/8] Start policy server (background), then run LIBERO rollouts per task ──
export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl
mkdir -p "${VIDEO_BASE_DIR}"

# Pick a free port for the ZeroMQ policy server (RLWRLD default 5555; avoid clashes).
PORT=5555
while ss -lnt 2>/dev/null | awk '{print $4}' | grep -q ":${PORT}$"; do
    PORT=$((PORT + 1))
    [ "${PORT}" -gt 65000 ] && PORT=20000
done
log "[7/8] Starting RLDX-1 policy server (background, port ${PORT})..."
SERVER_LOG=/tmp/rldx_server.log
cd "${RLDX_DIR}"
# Eager mode (no --compile). Phase 0: fused Triton/CUDA-graph suite is only imported when
# --compile {submodule|fullgraph} is passed → eager has no sm_120 dependency on sm_89 (L4).
{% if compile %}
COMPILE_ARGS=(--compile {{ compile }})
log "  [warn] compile mode '{{ compile }}' requested — requires sm_120-capable GPU; off the verified eager path"
{% else %}
COMPILE_ARGS=()
{% endif %}
CUDA_VISIBLE_DEVICES=0 nohup uv run --active python rldx/eval/run_rldx_server.py \
    --model-path "${RLDX_CKPT_DIR}" \
    --embodiment-tag {{ embodiment_tag if embodiment_tag else 'GENERAL_EMBODIMENT' }} \
    --use-sim-policy-wrapper \
    --no-strict \
    --host 127.0.0.1 \
    --port "${PORT}" \
    "${COMPILE_ARGS[@]}" \
    > "${SERVER_LOG}" 2>&1 &
SERVER_PID=$!
log "  Policy server started (PID ${SERVER_PID}) — waiting for port ${PORT}..."

# Wait up to 15min for the server. 7B model load + Qwen3-VL backbone init is slow first time.
SERVER_TIMEOUT=900
SERVER_WAIT=0
SERVER_OK=false
while [ ${SERVER_WAIT} -lt ${SERVER_TIMEOUT} ]; do
    if ! kill -0 "${SERVER_PID}" 2>/dev/null; then
        log "  [error] policy server process exited prematurely"
        tail -100 "${SERVER_LOG}" | tee -a /var/log/rldx-userdata.log
        aws s3 cp "${SERVER_LOG}" "s3://${S3_BUCKET}/${RUN_ID}/diag-fail/rldx_server.log" \
            --region "$REGION" 2>/dev/null || true
        die "policy server died during startup (see /tmp/rldx_server.log)"
    fi
    if ss -lnt 2>/dev/null | awk '{print $4}' | grep -q ":${PORT}$"; then
        SERVER_OK=true
        break
    fi
    sleep 10
    SERVER_WAIT=$((SERVER_WAIT + 10))
    if [ $((SERVER_WAIT % 60)) -eq 0 ]; then
        log "  Policy server still warming up (${SERVER_WAIT}s elapsed, last line: $(tail -1 "${SERVER_LOG}" 2>/dev/null | head -c 200))"
    fi
done
if [ "${SERVER_OK}" != true ]; then
    aws s3 cp "${SERVER_LOG}" "s3://${S3_BUCKET}/${RUN_ID}/diag-fail/rldx_server.log" \
        --region "$REGION" 2>/dev/null || true
    die "policy server did not bind port ${PORT} within ${SERVER_TIMEOUT}s (see /tmp/rldx_server.log + diag-fail/)"
fi
# Server binds the port a moment before it's fully ready to serve — give it a beat (matches
# RLWRLD eval_libero.sh `sleep 5` past port-open).
sleep 5
log "  Policy server ready (${SERVER_WAIT}s)"

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    SUITE=$(echo "$TASK" | jq -r '.suite // "libero"')
    ENV_NAME=$(echo "$TASK" | jq -r '.env_name')
    NUM_EPISODES=$(echo "$TASK" | jq -r '.num_episodes')
    DESCRIPTION=$(echo "$TASK" | jq -r '.description // ""')

    VIDEO_DIR="${VIDEO_BASE_DIR}/task-${TASK_IDX}"
    mkdir -p "$VIDEO_DIR"

    log "[7/8] Task $((TASK_IDX+1))/${TASK_COUNT}: suite=${SUITE}, env_name=${ENV_NAME}, num_episodes=${NUM_EPISODES}"
    touch /tmp/rldx_task${TASK_IDX}_start.marker

    # Run LIBERO rollout from the libero_uv venv (torch 2.5.1 ABI). The client connects to the
    # ZeroMQ policy server on 127.0.0.1:${PORT}. Args mirror RLWRLD's eval_libero.sh exactly.
    # Disable BOTH errexit AND the ERR trap (see setup_libero.sh note): a non-zero eval must
    # not auto-fire cfn_signal here — we capture EVAL_EXIT and fail explicitly via die() below,
    # AFTER uploading diagnostics. Letting the ERR trap fire would skip the S3 diag upload.
    set +e
    trap - ERR
    (
        cd "${RLDX_DIR}"
        export LIBERO_CONFIG_PATH=/root/.libero
        "${LIBERO_VENV}/bin/python" rldx/eval/rollout_policy.py \
            --n_episodes "${NUM_EPISODES}" \
            --policy_client_host 127.0.0.1 \
            --policy_client_port "${PORT}" \
            --max_episode_steps {{ max_episode_steps if max_episode_steps else 720 }} \
            --env_name "${ENV_NAME}" \
            --n_action_steps {{ n_action_steps if n_action_steps else 8 }} \
            --n_envs {{ n_envs if n_envs else 1 }} \
            --video_dir "${VIDEO_DIR}"
    ) 2>&1 | tee "/tmp/rldx_task${TASK_IDX}.log"
    EVAL_EXIT=${PIPESTATUS[0]}
    set -e
    trap '_trap_handler' ERR
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        log "  [error] Task ${TASK_IDX} eval exit=${EVAL_EXIT} — will fail after uploading diagnostics"
    fi

    VIDEO_COUNT=$(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | wc -l)
    log "  Videos collected: ${VIDEO_COUNT}"

    # Parse success rate from simulation_results.csv (success column = 1/0 per episode).
    # rollout_policy.py writes ${VIDEO_DIR}/simulation_results.csv.
    SR="unknown"
    CSV_FILE="${VIDEO_DIR}/simulation_results.csv"
    if [ -f "${CSV_FILE}" ]; then
        SR=$(awk -F, 'NR>1 && $3 ~ /^[01]$/ {s+=$3; n++} END {if (n>0) printf "%.3f", s/n; else print "unknown"}' \
            "${CSV_FILE}" 2>/dev/null || echo "unknown")
    fi
    if [ -z "${SR}" ] || [ "${SR}" = "unknown" ]; then
        SR=$(grep -oiE 'success.rate[^0-9]*[0-9.]+' "/tmp/rldx_task${TASK_IDX}.log" 2>/dev/null \
            | tail -1 | grep -oE '[0-9.]+$' || echo "unknown")
    fi
    log "  success_rate=${SR}"

    {
        echo "model: rldx-1"
        echo "checkpoint: {{ hf_repo }}@{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
        echo "embodiment_tag: {{ embodiment_tag if embodiment_tag else 'GENERAL_EMBODIMENT' }}"
        echo "compile: {{ compile if compile else 'eager' }}"
        echo "suite: ${SUITE}"
        echo "env_name: ${ENV_NAME}"
        echo "num_episodes: ${NUM_EPISODES}"
        echo "success_rate: ${SR}"
        echo "description: ${DESCRIPTION}"
    } > "/tmp/rldx_task${TASK_IDX}_summary.txt"

    # S3 upload (videos + logs + results CSV + summary)
    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"
    UPLOAD_COUNT=0
    while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
        [ -f "$mp4_file" ] || continue
        fname=$(basename "$mp4_file")
        base="${fname%.mp4}"
        # rollout_policy.py names videos ...env<NN>_episode<NN>_<success|failure>.mp4
        result="unknown"
        echo "$base" | grep -q "success" && result="success"
        echo "$base" | grep -q "failure" && result="failure"

        # Per-video context txt
        txt_file="/tmp/rldx_ctx_task${TASK_IDX}_ep${UPLOAD_COUNT}.txt"
        {
            echo "=== RLDX-1 Simulation Context ==="
            printf "Video:      %s\n"  "${fname}"
            printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
            echo ""
            echo "--- Environment ---"
            printf "Suite:      %s\n"  "${SUITE}"
            printf "Env:        %s\n"  "${ENV_NAME}"
            printf "Robot:      Franka Panda 7-DOF (LIBERO)\n"
            echo ""
            echo "--- Model ---"
            printf "Checkpoint: %s (rev %s)\n" "{{ hf_repo }}" "{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
            printf "Repo:       https://github.com/RLWRLD/RLDX-1 (%s)\n" "{{ rldx_commit[:8] if rldx_commit else 'HEAD' }}"
            printf "Backbone:   Qwen3-VL-8B + MSAT (Multi-Stream Action Transformer)\n"
            printf "Inference:  %s (eager path verified on sm_89/L4)\n" "{{ compile if compile else 'eager' }}"
            printf "License:    RLWRLD Model License v1.0 (NON-COMMERCIAL — sim benchmarking)\n"
            echo ""
            echo "--- Rollout ---"
            printf "run_id:        %s\n"  "${RUN_ID}"
            printf "task_idx:      %s\n"  "${TASK_IDX}"
            printf "result:        %s\n"  "${result}"
            printf "total_success: %s (env avg)\n" "${SR}"
            echo ""
            echo "--- Infrastructure ---"
            printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
            printf "Region:   %s\n"  "${REGION}"
            printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
        } > "$txt_file"

        if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/${fname}" \
            --region "$REGION" 2>&1 | tee -a /var/log/rldx-userdata.log; then
            UPLOAD_COUNT=$((UPLOAD_COUNT+1))
            aws s3 cp "$txt_file" "${S3_TASK_PREFIX}/videos/${base}.txt" \
                --region "$REGION" 2>/dev/null || true
        else
            log "  [warn] Upload failed: $fname"
        fi
    done < <(find "$VIDEO_DIR" -name "*.mp4" 2>/dev/null | sort)
    log "  Videos uploaded: ${UPLOAD_COUNT}/${VIDEO_COUNT}"

    aws s3 cp "/tmp/rldx_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/eval.log" --region "$REGION" || true
    [ -f "${CSV_FILE}" ] && \
        aws s3 cp "${CSV_FILE}" \
        "${S3_TASK_PREFIX}/simulation_results.csv" --region "$REGION" || true
    [ -f "/tmp/rldx_task${TASK_IDX}_summary.txt" ] && \
        aws s3 cp "/tmp/rldx_task${TASK_IDX}_summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

    SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${SUITE} :: ${ENV_NAME} — success_rate=${SR} (${NUM_EPISODES} episodes)"
    log "  Task $((TASK_IDX+1)) done"

    # Hard-fail after S3 upload if eval crashed or produced no rollouts.
    if [ "${EVAL_EXIT}" -ne 0 ]; then
        [ -f "${SERVER_LOG}" ] && aws s3 cp "${SERVER_LOG}" "${S3_TASK_PREFIX}/server.log" --region "$REGION" || true
        die "Task ${TASK_IDX} eval failed (exit=${EVAL_EXIT}) — see s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}/eval.log"
    fi
    if [ "${VIDEO_COUNT}" -eq 0 ]; then
        [ -f "${SERVER_LOG}" ] && aws s3 cp "${SERVER_LOG}" "${S3_TASK_PREFIX}/server.log" --region "$REGION" || true
        die "Task ${TASK_IDX} produced 0 rollouts — eval likely short-circuited (see s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}/eval.log)"
    fi
done

# Upload server log for the run (always — useful even on success)
aws s3 cp "${SERVER_LOG}" "s3://${S3_BUCKET}/${RUN_ID}/server.log" --region "$REGION" || true

# Stop server explicitly before signalling success
_cleanup_server
SERVER_PID=""

# ── [8/8] SNS notification + cfn-signal ──────────────────────────
log "[8/8] Sending SNS notification..."

SNS_MESSAGE="[${STACK_NAME}] RLDX-1 simulation complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

Model: RLDX-1 (RLWRLD — MSAT on Qwen3-VL-8B, eager inference)
Checkpoint: {{ hf_repo }} (rev {{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }})
License: RLWRLD Model License v1.0 (NON-COMMERCIAL — simulation benchmarking)
Simulation: LIBERO (robosuite + MuJoCo, headless EGL)
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./rldx-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py --vla rldx"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "RLDX-1 simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "[8/8] Sending cfn-signal..."
cfn_signal 0

if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== RLDX-1 UserData complete ====="
