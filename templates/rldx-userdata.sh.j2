grep -qF 'input(' "${ASSET_DL_PY}" \
    || die "FIX 9: no input() call in download_kitchen_assets.py — commit drifted, re-verify?"
if grep -qF 'FIX 9: auto-accept (headless)' "${ASSET_DL_PY}"; then
