#!/bin/bash
# π0.5 (openpi) 1-Click UserData Script (v1.2 — bridge mode, WaitCondition signal)
# Generated by pi-enablement-pack/generate.py
# DO NOT EDIT MANUALLY — regenerate with: python generate.py
#
# CloudFormation Fn::Sub placeholders (resolved at deploy time):
#   ${S3BucketName}       — results S3 bucket
#   ${SnsTopicArn}        — completion notification SNS topic
#   ${StackName}          — CDK stack name
#   ${WaitConditionUrl}   — CFN WaitConditionHandle presigned URL
#   ${Region}             — deployment region
#   ${AutoTerminate}      — "true" to auto-terminate EC2 after completion

set -euo pipefail

OPENPI_DIR=/home/ubuntu/openpi
VIDEO_BASE_DIR=/tmp/pi-videos
RUN_ID=$(date '+%Y-%m-%d-%H%M')

# UserData runs as root; HOME must be set for ~ expansion in compose.yml
export HOME=/root
export OPENPI_DATA_HOME=/root/.cache/openpi

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"
BRIDGE_MODE="${BridgeMode}"
NLB_ENDPOINT="${NlbEndpoint}"

log() { echo "[PI] $(date '+%H:%M:%S') $*" | tee -a /var/log/pi-userdata.log; }

# cfn_signal: send signal to CloudFormation WaitConditionHandle presigned URL
cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    log "  instance-id: $_instance_id"
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/pi-userdata.log \
        && log "cfn_signal $_status sent to WaitCondition" \
        || log "[warn] cfn_signal WaitCondition send failed (continuing)"
}

die() {
    log "ERROR: $*"
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

log "===== PI UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/5] System dependencies ──────────────────────────────────────
log "[1/5] Installing system packages..."
export DEBIAN_FRONTEND=noninteractive

log "[1/5] Waiting for apt lock..."

# Ubuntu 22.04 DLAMI reboots ~14-17min after boot. Root cause: cloud-init's modules:final
# runs package_update_upgrade_install concurrently with userdata → dpkg triggers fire
# (initramfs-tools, microcode-initrd) → systemd Reexecutes → needrestart DPkg::Post-Invoke
# hook schedules a reboot. Kill ALL of these mechanisms:
#
# 1. Prevent cloud-init from running package upgrades
cat > /etc/cloud/cloud.cfg.d/99_no_upgrade.cfg << 'EOF'
package_update: false
package_upgrade: false
package_reboot_if_required: false
EOF

# 2. Stop unattended-upgrades and kill any running apt-get
systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl mask unattended-upgrades 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
pkill -9 -f "apt.systemd.daily" 2>/dev/null || true

# 3. Suppress needrestart completely — remove DPkg::Post-Invoke hook
export NEEDRESTART_SUSPEND=1
export NEEDRESTART_MODE=l
rm -f /etc/apt/apt.conf.d/99needrestart 2>/dev/null || true
rm -f /etc/dpkg/dpkg.cfg.d/needrestart 2>/dev/null || true
if [ -f /etc/needrestart/needrestart.conf ]; then
    sed -i "s/^#\?\$nrconf{restart}.*$/\$nrconf{restart} = 'l';/" /etc/needrestart/needrestart.conf
fi
systemctl stop needrestart 2>/dev/null || true
systemctl disable needrestart 2>/dev/null || true
systemctl mask needrestart 2>/dev/null || true

# 4. Prevent systemd from rebooting even if something requests it
systemctl mask systemd-reboot.service 2>/dev/null || true
mkdir -p /run/systemd/system
cat > /run/systemd/system/systemd-reboot.service.d-override.conf << 'SYSEOF'
[Service]
ExecStart=
ExecStart=/bin/true
SYSEOF

APT_WAIT=0
while fuser /var/lib/apt/lists/lock >/dev/null 2>&1 || \
      fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
    sleep 10
    APT_WAIT=$((APT_WAIT + 10))
    log "  apt lock held (${APT_WAIT}s)..."
    if [ $APT_WAIT -ge 120 ]; then
        log "[warn] apt lock held 2min — forcibly killing apt processes"
        kill -9 $(fuser /var/lib/dpkg/lock-frontend 2>/dev/null) 2>/dev/null || true
        kill -9 $(fuser /var/lib/apt/lists/lock 2>/dev/null) 2>/dev/null || true
        sleep 5
        break
    fi
done

apt-get update -qq -o DPkg::Lock::Timeout=120 2>&1 | tee /tmp/pi_apt_update.log
apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=120 \
    git git-lfs curl ca-certificates awscli jq \
    libgl1-mesa-glx libegl1 libgles2 \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    2>&1 | tee /tmp/pi_apt.log

# ── [1.5/5] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/5] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/pi/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/pi-userdata.log",
            "log_group_name": "/pi/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config \
        -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/pi_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs saved locally only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs saved locally (/var/log/pi-userdata.log)"
fi

# ── [2/5] GPU driver + Docker check ──────────────────────────────
log "[2/5] Checking GPU driver + Docker..."
nvidia-smi -L 2>&1 | tee /tmp/pi_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI is being used (continuing with EGL headless)"

# Docker (DLAMI pre-installed)
docker --version 2>&1 | tee -a /var/log/pi-userdata.log || die "Docker not found on DLAMI"

# Docker Compose v2 (DLAMI may have v1 only — install v2 if needed)
if ! docker compose version &>/dev/null; then
    log "[2/5] Installing Docker Compose v2..."
    mkdir -p /usr/local/lib/docker/cli-plugins
    COMPOSE_VERSION="v2.36.0"
    curl -SL \
        "https://github.com/docker/compose/releases/download/${COMPOSE_VERSION}/docker-compose-linux-x86_64" \
        -o /usr/local/lib/docker/cli-plugins/docker-compose \
        2>&1 | tee -a /var/log/pi-userdata.log
    chmod +x /usr/local/lib/docker/cli-plugins/docker-compose
fi
log "  $(docker compose version)"

# NVIDIA Container Toolkit — configure Docker runtime for GPU passthrough
# DLAMI pre-installs nvidia-container-toolkit; configure runtime if not already set
if ! docker info 2>/dev/null | grep -q "nvidia"; then
    log "[2/5] Configuring NVIDIA Container Runtime for Docker..."
    nvidia-ctk runtime configure --runtime=docker 2>&1 | tee -a /var/log/pi-userdata.log || \
        log "[warn] nvidia-ctk configure failed — GPU inside Docker may not work"
    systemctl restart docker 2>/dev/null || true
fi

# ── [2.5/5] GPU passthrough readiness check (Docker) ─────────────
# Ensure NVIDIA GPU is accessible *inside* Docker containers before task loop starts.
# JAX inside the libero Docker container fails with "No visible GPU devices" if the
# nvidia-container-toolkit isn't fully propagated after `systemctl restart docker`.
log "[2.5/5] Verifying GPU passthrough inside Docker..."
GPU_DOCKER_WAIT=0
GPU_DOCKER_OK=false
while [ $GPU_DOCKER_WAIT -lt 180 ]; do
    GPU_OUT=$(docker run --rm --gpus all nvidia/cuda:12.1.1-base-ubuntu22.04 \
        nvidia-smi -L 2>&1 || true)
    if echo "$GPU_OUT" | grep -q "GPU 0:"; then
        log "  GPU passthrough confirmed: $(echo "$GPU_OUT" | head -1)"
        GPU_DOCKER_OK=true
        break
    fi
    log "  GPU not yet visible inside Docker (${GPU_DOCKER_WAIT}s) — retrying in 15s..."
    sleep 15
    GPU_DOCKER_WAIT=$((GPU_DOCKER_WAIT + 15))
    # Re-configure runtime in case the restart wasn't complete
    if [ $((GPU_DOCKER_WAIT % 60)) -eq 0 ]; then
        log "  Re-triggering nvidia-ctk + docker restart..."
        nvidia-ctk runtime configure --runtime=docker 2>/dev/null || true
        systemctl restart docker 2>/dev/null || true
        sleep 10
    fi
done
if [ "$GPU_DOCKER_OK" = false ]; then
    log "[warn] GPU passthrough not confirmed after 180s — tasks may fail (continuing anyway)"
fi

# ── [3/5] Clone openpi (pinned commit) ────────────────────────────
log "[3/5] Cloning openpi..."
if [ ! -d "${OPENPI_DIR}" ]; then
    git clone --recurse-submodules \
        https://github.com/Physical-Intelligence/openpi.git \
        "${OPENPI_DIR}" 2>&1 | tee /tmp/pi_clone.log \
        || die "openpi clone failed"
{%- if openpi_commit %}
    ACTUAL_COMMIT=$(git -C "${OPENPI_DIR}" rev-parse HEAD)
    EXPECTED_COMMIT="{{ openpi_commit }}"
    if [ -n "$EXPECTED_COMMIT" ] && [ "$ACTUAL_COMMIT" != "$EXPECTED_COMMIT" ]; then
        die "openpi commit mismatch: expected ${EXPECTED_COMMIT}, got ${ACTUAL_COMMIT}. Update openpi_commit in pi-config.yaml."
    fi
    log "  Commit verified: ${ACTUAL_COMMIT}"
{%- else %}
    ACTUAL_COMMIT=$(git -C "${OPENPI_DIR}" rev-parse HEAD)
    log "  [warn] openpi_commit not pinned — using HEAD: ${ACTUAL_COMMIT} (reproducibility risk)"
{%- endif %}
else
    log "openpi already exists, skipping clone"
fi

# Sanity check: compose file must exist
[ -f "${OPENPI_DIR}/examples/libero/compose.yml" ] || \
    die "compose.yml not found: ${OPENPI_DIR}/examples/libero/compose.yml"

if [ "${BRIDGE_MODE}" = "true" ]; then
    # Bridge mode: skip serve_policy (no local model) — build and start pi_grpc_bridge container
    log "[3.5/5] Bridge mode: building pi_grpc_bridge Docker image..."
    BRIDGE_DIR=/home/ubuntu/pi-bridge
    mkdir -p "${BRIDGE_DIR}"
    # Copy bridge assets (uploaded to S3 by CDK as UserData asset alongside pi.sh)
    # Assets are embedded in pi.sh via heredoc
    cat > "${BRIDGE_DIR}/pi.proto" << 'PROTO_EOF'
{{ pi_proto }}
PROTO_EOF
    cat > "${BRIDGE_DIR}/pi_grpc_bridge.py" << 'BRIDGE_EOF'
{{ pi_grpc_bridge_py }}
BRIDGE_EOF
    cat > "${BRIDGE_DIR}/requirements.txt" << 'REQ_EOF'
grpcio>=1.60.0
grpcio-tools>=1.60.0
msgpack>=1.0.0
msgpack-numpy>=0.4.8
numpy>=1.24.0
websockets>=12.0
Pillow>=10.0.0
REQ_EOF
    cat > "${BRIDGE_DIR}/Dockerfile" << 'BRIDGE_DOCKERFILE_EOF'
FROM python:3.11-slim
WORKDIR /bridge
RUN apt-get update && apt-get install -y --no-install-recommends gcc && rm -rf /var/lib/apt/lists/*
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY pi.proto .
RUN python -m grpc_tools.protoc -I. --python_out=. --grpc_python_out=. pi.proto
COPY pi_grpc_bridge.py .
EXPOSE 8000
ENV NLB_ENDPOINT=""
ENTRYPOINT ["/bin/sh", "-c", "exec python pi_grpc_bridge.py --endpoint \"${NLB_ENDPOINT}\" --port 8000"]
BRIDGE_DOCKERFILE_EOF

    docker build -t pi-grpc-bridge "${BRIDGE_DIR}" 2>&1 | tee /tmp/pi_bridge_build.log \
        || die "pi_grpc_bridge Docker build failed"

    log "  Starting pi_grpc_bridge container (NLB: ${NLB_ENDPOINT})..."
    docker run -d --name pi-grpc-bridge \
        --network host \
        -e NLB_ENDPOINT="${NLB_ENDPOINT}" \
        pi-grpc-bridge 2>&1 | tee /tmp/pi_bridge_run.log \
        || die "pi_grpc_bridge container start failed"

    # Wait for bridge WebSocket to be ready
    log "  Waiting for bridge WebSocket (port 8000)..."
    BRIDGE_WAIT=0
    while ! nc -z localhost 8000 2>/dev/null; do
        sleep 5
        BRIDGE_WAIT=$((BRIDGE_WAIT + 5))
        if [ $BRIDGE_WAIT -ge 120 ]; then
            docker logs pi-grpc-bridge 2>&1 | tee -a /var/log/pi-userdata.log
            die "pi_grpc_bridge did not start within 120s"
        fi
    done
    log "  Bridge ready (${BRIDGE_WAIT}s)"
else
    # Local mode: patch serve_policy.Dockerfile for large wheel timeout
    SERVE_DF="${OPENPI_DIR}/scripts/docker/serve_policy.Dockerfile"
    if [ -f "${SERVE_DF}" ] && ! grep -q "UV_HTTP_TIMEOUT" "${SERVE_DF}"; then
        sed -i 's/uv sync --frozen/UV_HTTP_TIMEOUT=300 uv sync --frozen/g' "${SERVE_DF}"
        log "  Patched serve_policy.Dockerfile: UV_HTTP_TIMEOUT=300"
    fi
fi

# ── [4/5] Sequential task execution ──────────────────────────────
log "[4/5] Starting sequential task execution..."

export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    SUITE=$(echo "$TASK" | jq -r '.suite')
    NUM_EPISODES=$(echo "$TASK" | jq -r '.num_episodes')
    DESCRIPTION=$(echo "$TASK" | jq -r '.description // ""')

    VIDEO_DIR="${VIDEO_BASE_DIR}/task-${TASK_IDX}"
    mkdir -p "$VIDEO_DIR"

    log "Task $((TASK_IDX+1))/${TASK_COUNT}: ${SUITE}"
    log "  num_episodes_per_task=${NUM_EPISODES}, description='${DESCRIPTION}'"

    touch /tmp/pi_task${TASK_IDX}_start.marker

    # Run via Docker Compose:
    #   LOCAL mode:  SERVER_ARGS="--env LIBERO" → serve_policy.py selects pi05_libero checkpoint
    #   BRIDGE mode: openpi_server replaced by pi_grpc_bridge (running as separate container)
    #                → compose runs only the runtime (libero) service with --scale openpi_server=0
    # --abort-on-container-exit: stop all containers when client (libero) exits
    log "  Starting Docker Compose eval (build + run, ~30-60 min)..."
    mkdir -p "${OPENPI_DIR}/data/libero/videos"
    export MUJOCO_GL=egl
    export CLIENT_ARGS="--args.task-suite-name ${SUITE} --args.num-trials-per-task ${NUM_EPISODES} --args.video-out-path data/libero/videos/${TASK_IDX}"

    if [ "${BRIDGE_MODE}" = "true" ]; then
        # Bridge mode: skip openpi_server service (pi_grpc_bridge handles port 8000 on host network)
        # network_mode: host on both containers → libero client reaches bridge on localhost:8000
        # --no-deps: don't start openpi_server (depends_on skipped); also skips its image build (~20min saved)
        export SERVER_ARGS=""
        (
            cd "${OPENPI_DIR}"
            docker compose \
                -f examples/libero/compose.yml \
                up --build --abort-on-container-exit \
                --no-deps \
                runtime
        ) 2>&1 | tee /tmp/pi_task${TASK_IDX}.log \
            || log "  [warn] Task ${TASK_IDX} compose (bridge) returned non-zero (continuing)"
    else
        export SERVER_ARGS="--env LIBERO"
        # compose.yml uses $PWD for volume mounts ($PWD:/app, ../../data) so we must cd to OPENPI_DIR
        (
            cd "${OPENPI_DIR}"
            docker compose \
                -f examples/libero/compose.yml \
                up --build --abort-on-container-exit
        ) 2>&1 | tee /tmp/pi_task${TASK_IDX}.log \
            || log "  [warn] Task ${TASK_IDX} compose returned non-zero (continuing)"
    fi

    # Copy videos from volume-mounted host path to VIDEO_DIR
    HOST_VIDEO_SRC="${OPENPI_DIR}/data/libero/videos/${TASK_IDX}"
    if [ -d "${HOST_VIDEO_SRC}" ]; then
        cp -r "${HOST_VIDEO_SRC}/." "${VIDEO_DIR}/" 2>/dev/null || true
    fi

    # Clean up containers (keep images for next task — faster rebuild)
    (cd "${OPENPI_DIR}" && docker compose -f examples/libero/compose.yml down) 2>/dev/null || true

    # Parse success rate from compose output
    # LIBERO eval typically prints: "success rate: 0.80" or "task_X success_rate: 0.8"
    SR=$(grep -oiE 'success.rate[: ]+[0-9.]+' /tmp/pi_task${TASK_IDX}.log 2>/dev/null | \
        tail -1 | grep -oE '[0-9.]+$' || echo "unknown")
    N_SUCCESS=$(awk "BEGIN { printf \"%d\", ${NUM_EPISODES} * 10 * ${SR:-0} }" 2>/dev/null || echo "?")
    log "  success_rate=${SR}"

    # Write summary
    {
        echo "suite: ${SUITE}"
        echo "success_rate: ${SR}"
        echo "num_episodes_per_task: ${NUM_EPISODES}"
        echo "n_tasks: 10"
        echo "description: ${DESCRIPTION}"
    } > "/tmp/pi_task${TASK_IDX}_summary.txt"

    # S3 upload
    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"

    VIDEO_COUNT=0
    if [ -d "${VIDEO_DIR}" ]; then
        VIDEO_COUNT=$(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | wc -l)
        while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
            [ -f "$mp4_file" ] || continue
            fname=$(basename "$mp4_file")
            if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/${fname}" \
                --region "$REGION" 2>&1 | tee -a /var/log/pi-userdata.log; then
                log "  Uploaded: ${fname}"
            else
                log "  [warn] Upload failed: ${fname}"
            fi

            # Generate and upload per-video metadata .txt
            fname_noext="${fname%.mp4}"
            if [[ "$fname_noext" == *_success ]]; then
                vid_result="success"
                cmd_part="${fname_noext%_success}"
            elif [[ "$fname_noext" == *_failure ]]; then
                vid_result="failure"
                cmd_part="${fname_noext%_failure}"
            else
                vid_result="unknown"
                cmd_part="$fname_noext"
            fi
            cmd_part="${cmd_part#rollout_}"
            language_cmd="${cmd_part//_/ }"
            txt_fname="${fname_noext}.txt"
            txt_path="/tmp/${txt_fname}"
            {
                echo "model: pi05_libero"
                echo "instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"
                echo "suite: ${SUITE}"
                echo "language_command: ${language_cmd}"
                echo "result: ${vid_result}"
                echo "run_id: ${RUN_ID}"
            } > "$txt_path"
            aws s3 cp "$txt_path" "${S3_TASK_PREFIX}/videos/${txt_fname}" \
                --region "$REGION" 2>/dev/null \
                && log "  Metadata: ${txt_fname}" \
                || log "  [warn] Metadata upload failed: ${txt_fname}"
        done < <(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | sort)
    fi

    aws s3 cp "/tmp/pi_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/compose.log" --region "$REGION" || true
    [ -f "/tmp/pi_task${TASK_IDX}_summary.txt" ] && \
        aws s3 cp "/tmp/pi_task${TASK_IDX}_summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

    log "  Videos uploaded: ${VIDEO_COUNT}"

    # Collect for SNS summary
    SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${SUITE} — success_rate=${SR} (${NUM_EPISODES} eps/task)"

    log "  Task $((TASK_IDX+1)) done"
done

# ── [5/5] SNS notification + cfn-signal ──────────────────────────
log "[5/5] Sending SNS notification..."

SNS_MESSAGE="[${STACK_NAME}] π0.5 Simulation complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

Model: π0.5 (pi05_libero checkpoint — gs://openpi-assets/checkpoints/pi05_libero)
Simulation: LIBERO (robosuite + MuJoCo, headless EGL)
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./pi-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "π0.5 simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "[5/5] Sending cfn-signal..."
cfn_signal 0

# ── EC2 auto-terminate ────────────────────────────────────────────
if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== PI UserData complete ====="
