#!/bin/bash
# OpenVLA-OFT 1-Click UserData Script (v1.0 — LIBERO sim, local mode only)
# Generated by vla-simulator/generate.py
# DO NOT EDIT MANUALLY — regenerate with: python generate.py --vla openvla-oft
#
# CloudFormation Fn::Sub placeholders (resolved at deploy time):
#   ${S3BucketName}       — results S3 bucket
#   ${SnsTopicArn}        — completion notification SNS topic
#   ${StackName}          — CDK stack name
#   ${WaitConditionUrl}   — CFN WaitConditionHandle presigned URL
#   ${Region}             — deployment region
#   ${AutoTerminate}      — "true" to auto-terminate EC2 after completion

set -euo pipefail

OFT_DIR=/home/ubuntu/openvla-oft
LIBERO_DIR=/home/ubuntu/LIBERO
MINICONDA_DIR=/opt/miniconda3
CONDA_ENV=openvla-oft
VIDEO_BASE_DIR=/tmp/openvla-oft-videos
RUN_ID=$(date '+%Y-%m-%d-%H%M')

S3_BUCKET="${S3BucketName}"
SNS_TOPIC_ARN="${SnsTopicArn}"
STACK_NAME="${StackName}"
WAIT_CONDITION_URL="${WaitConditionUrl}"
REGION="${Region}"
AUTO_TERMINATE="${AutoTerminate}"

export HOME=/root
export HF_HOME=/home/ubuntu/.cache/huggingface
export TRANSFORMERS_CACHE=/home/ubuntu/.cache/huggingface/hub

log() { echo "[OFT] $(date '+%H:%M:%S') $*" | tee -a /var/log/openvla-oft-userdata.log; }

cfn_signal() {
    local exit_code=$1
    local _status
    [ "$exit_code" -eq 0 ] && _status="SUCCESS" || _status="FAILURE"
    log "cfn_signal: $_status → WaitCondition"
    local _token
    _token=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
    local _instance_id
    _instance_id=$(curl -s -H "X-aws-ec2-metadata-token: $_token" \
        "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "i-unknown")
    local _data
    _data="{\"Status\":\"${_status}\",\"Reason\":\"Script exit\",\"UniqueId\":\"${_instance_id}\",\"Data\":\"${_status}\"}"
    curl -s -X PUT -H 'Content-Type:' \
        --data-binary "$_data" \
        "$WAIT_CONDITION_URL" \
        2>&1 | tee -a /var/log/openvla-oft-userdata.log \
        && log "cfn_signal $_status sent" \
        || log "[warn] cfn_signal send failed (continuing)"
}

die() {
    log "ERROR: $*"
    cfn_signal 1
    exit 1
}

_trap_sent=false
_trap_handler() {
    if [ "$_trap_sent" = false ]; then
        _trap_sent=true
        log "ERROR: Script exited abnormally (line ${BASH_LINENO[0]:-?})"
        cfn_signal 1
    fi
}
trap '_trap_handler' ERR

log "===== OpenVLA-OFT UserData start (RUN_ID: ${RUN_ID}) ====="

META_TOKEN=$(curl -s -X PUT "http://169.254.169.254/latest/api/token" \
    -H "X-aws-ec2-metadata-token-ttl-seconds: 60" 2>/dev/null || echo "")
INSTANCE_ID=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-id" 2>/dev/null || echo "unknown")
INSTANCE_TYPE=$(curl -s -H "X-aws-ec2-metadata-token: $META_TOKEN" \
    "http://169.254.169.254/latest/meta-data/instance-type" 2>/dev/null || echo "unknown")
log "  Instance: ${INSTANCE_ID} (${INSTANCE_TYPE})"

# ── [1/6] System dependencies ──────────────────────────────────────
log "[1/6] Installing system packages..."
export DEBIAN_FRONTEND=noninteractive

systemctl stop unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
systemctl disable unattended-upgrades apt-daily.service apt-daily-upgrade.service 2>/dev/null || true
pkill -9 -f "unattended-upgrade" 2>/dev/null || true
pkill -9 -f "apt-get" 2>/dev/null || true
sleep 5
rm -f /var/lib/dpkg/lock-frontend /var/lib/dpkg/lock /var/lib/apt/lists/lock 2>/dev/null || true
dpkg --configure -a 2>&1 | tee /tmp/oft_dpkg_fix.log || true

APT_RETRY=0
until apt-get update -qq -o DPkg::Lock::Timeout=300 2>&1 | tee /tmp/oft_apt_update.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get update failed after 3 retries"
    log "[warn] apt-get update failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

APT_RETRY=0
until apt-get install -y --no-install-recommends -o DPkg::Lock::Timeout=300 \
    git git-lfs curl ca-certificates awscli jq \
    libgl1-mesa-glx libegl1 libgles2 \
    libglib2.0-0 libsm6 libxext6 libxrender1 \
    ffmpeg build-essential \
    2>&1 | tee /tmp/oft_apt.log; do
    APT_RETRY=$((APT_RETRY + 1))
    [ $APT_RETRY -ge 3 ] && die "apt-get install failed after 3 retries"
    log "[warn] apt-get install failed (attempt $APT_RETRY), retrying in 30s..."
    sleep 30
done

# ── [1.5/6] CloudWatch Logs agent setup ──────────────────────────
log "[1.5/6] Setting up CloudWatch Logs agent..."
CW_LOG_GROUP="/openvla-oft/userdata"
if [ -f /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl ]; then
    cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'CWEOF'
{
  "logs": {
    "logs_collected": {
      "files": {
        "collect_list": [
          {
            "file_path": "/var/log/openvla-oft-userdata.log",
            "log_group_name": "/openvla-oft/userdata",
            "log_stream_name": "{instance_id}",
            "timezone": "UTC"
          }
        ]
      }
    }
  }
}
CWEOF
    /opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \
        -a fetch-config -m ec2 \
        -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json \
        -s 2>&1 | tee /tmp/oft_cwagent.log \
        && log "  CW agent started (log group: ${CW_LOG_GROUP})" \
        || log "[warn] CW agent start failed — logs local only"
else
    log "[warn] amazon-cloudwatch-agent not found — logs local only"
fi

# ── [2/6] NVIDIA driver check ──────────────────────────────────────
log "[2/6] Checking GPU driver..."
nvidia-smi -L 2>&1 | tee /tmp/oft_nvidia.log \
    || log "[warn] nvidia-smi failed — verify DLAMI (continuing with EGL headless)"

# ── [3/6] Miniconda + openvla-oft clone ────────────────────────────
log "[3/6] Installing Miniconda..."
if [ ! -d "${MINICONDA_DIR}" ]; then
    curl -sSL https://repo.anaconda.com/miniconda/Miniconda3-py310_24.7.1-0-Linux-x86_64.sh \
        -o /tmp/miniconda.sh 2>&1 | tee /tmp/oft_miniconda_dl.log \
        || die "Miniconda download failed"
    bash /tmp/miniconda.sh -b -p "${MINICONDA_DIR}" \
        2>&1 | tee /tmp/oft_miniconda_install.log \
        || die "Miniconda install failed"
fi
export PATH="${MINICONDA_DIR}/bin:${PATH}"
log "  $(conda --version)"

log "[3/6] Cloning openvla-oft (pinned: {{ oft_commit[:8] if oft_commit else 'HEAD' }})..."
if [ ! -d "${OFT_DIR}" ]; then
    git clone https://github.com/moojink/openvla-oft.git "${OFT_DIR}" \
        2>&1 | tee /tmp/oft_clone.log \
        || die "openvla-oft clone failed"
{%- if oft_commit %}
    git -C "${OFT_DIR}" checkout "{{ oft_commit }}" \
        || die "openvla-oft: checkout pinned commit {{ oft_commit[:8] }} failed"
{%- endif %}
    log "  Commit: $(git -C "${OFT_DIR}" rev-parse HEAD)"
else
    log "  openvla-oft already exists, skipping"
fi

# Create conda env (python 3.10.14)
log "[3/6] Creating conda env '${CONDA_ENV}' (python 3.10)..."
if ! conda env list | grep -q "^${CONDA_ENV} "; then
    conda create -y -n "${CONDA_ENV}" python=3.10.14 \
        2>&1 | tee /tmp/oft_conda_create.log \
        || die "conda env create failed"
fi

# Activate env (source activate instead of conda activate, for non-interactive shell)
# shellcheck disable=SC1091
source "${MINICONDA_DIR}/etc/profile.d/conda.sh"
conda activate "${CONDA_ENV}" || die "conda activate ${CONDA_ENV} failed"
log "  Python: $(python --version) @ $(which python)"

# Install PyTorch 2.2.0 (pinned per pyproject.toml)
log "[3/6] Installing PyTorch 2.2.0 + CUDA 12.1..."
pip install --no-cache-dir \
    torch==2.2.0 torchvision==0.17.0 torchaudio==2.2.0 \
    --index-url https://download.pytorch.org/whl/cu121 \
    2>&1 | tee /tmp/oft_torch.log \
    || die "torch install failed"

# openvla-oft editable install (pulls transformers fork + many deps including tensorflow==2.15)
log "[3/6] pip install -e openvla-oft (~10 min)..."
cd "${OFT_DIR}"
pip install --no-cache-dir -e . \
    2>&1 | tee /tmp/oft_pip_install.log \
    || die "openvla-oft pip install failed (see /tmp/oft_pip_install.log)"

# FlashAttention 2 (prebuilt wheel — fast) — required for parallel decoding attention
log "[3/6] Installing FlashAttention 2 (flash-attn==2.5.5)..."
pip install --no-cache-dir packaging ninja 2>&1 | tee /tmp/oft_ninja.log || true
pip install --no-cache-dir "flash-attn==2.5.5" --no-build-isolation \
    2>&1 | tee /tmp/oft_flash_attn.log \
    || log "[warn] flash-attn install failed — eval may fail or run slower (continuing)"

# ── [4/6] LIBERO repo clone + install ──────────────────────────────
log "[4/6] Cloning LIBERO repo..."
if [ ! -d "${LIBERO_DIR}" ]; then
    git clone https://github.com/Lifelong-Robot-Learning/LIBERO.git "${LIBERO_DIR}" \
        2>&1 | tee /tmp/oft_libero_clone.log \
        || die "LIBERO clone failed"
{%- if libero_commit and libero_commit != "master" %}
    git -C "${LIBERO_DIR}" checkout "{{ libero_commit }}" \
        || die "LIBERO: checkout {{ libero_commit }} failed"
{%- endif %}
fi
log "  LIBERO commit: $(git -C "${LIBERO_DIR}" rev-parse HEAD)"

log "[4/6] pip install -e LIBERO + libero_requirements.txt..."
pip install --no-cache-dir -e "${LIBERO_DIR}" \
    2>&1 | tee /tmp/oft_libero_install.log \
    || die "LIBERO pip install failed"
pip install --no-cache-dir -r "${OFT_DIR}/experiments/robot/libero/libero_requirements.txt" \
    2>&1 | tee /tmp/oft_libero_reqs.log \
    || die "libero_requirements.txt install failed"

# ── [5/6] Pre-download HF checkpoint + run eval ───────────────────
export MUJOCO_GL=egl
export PYOPENGL_PLATFORM=egl
mkdir -p "${HF_HOME}"

{% if hf_model_revision %}
log "[5/6] Pre-downloading HF checkpoint {{ hf_repo }} (rev {{ hf_model_revision[:8] }})..."
python -c "
from huggingface_hub import snapshot_download
path = snapshot_download('{{ hf_repo }}', revision='{{ hf_model_revision }}')
print(path)
" 2>&1 | tee /tmp/oft_hf_download.log \
    || die "HF checkpoint download failed"
{% else %}
log "[5/6] HF revision not pinned — run_libero_eval.py will download on demand"
{% endif %}

TASKS_JSON='{{ tasks_json }}'
TASK_COUNT=$(echo "$TASKS_JSON" | jq length)
SUMMARY_ALL=""

for TASK_IDX in $(seq 0 $((TASK_COUNT - 1))); do
    TASK=$(echo "$TASKS_JSON" | jq -r ".[$TASK_IDX]")
    SUITE=$(echo "$TASK" | jq -r '.suite')
    NUM_TRIALS=$(echo "$TASK" | jq -r '.num_trials_per_task')
    DESCRIPTION=$(echo "$TASK" | jq -r '.description // ""')

    VIDEO_DIR="${VIDEO_BASE_DIR}/task-${TASK_IDX}"
    mkdir -p "$VIDEO_DIR"

    log "[5/6] Task $((TASK_IDX+1))/${TASK_COUNT}: suite=${SUITE}, num_trials_per_task=${NUM_TRIALS}"

    # Select HF checkpoint per suite
    case "$SUITE" in
        libero_spatial) CKPT="moojink/openvla-7b-oft-finetuned-libero-spatial" ;;
        libero_object)  CKPT="moojink/openvla-7b-oft-finetuned-libero-object" ;;
        libero_goal)    CKPT="moojink/openvla-7b-oft-finetuned-libero-goal" ;;
        libero_10)      CKPT="{{ hf_repo }}" ;;
        *)              die "Unknown LIBERO suite: ${SUITE}" ;;
    esac

    log "  Checkpoint: ${CKPT}"
    touch /tmp/oft_task${TASK_IDX}_start.marker

    # Run LIBERO eval — from openvla-oft dir because save_rollout_video uses relative path ./rollouts/
    (
        cd "${OFT_DIR}"
        python experiments/robot/libero/run_libero_eval.py \
            --pretrained_checkpoint "${CKPT}" \
            --task_suite_name "${SUITE}" \
            --num_trials_per_task "${NUM_TRIALS}" \
            --center_crop True \
            --use_wandb False
    ) 2>&1 | tee "/tmp/oft_task${TASK_IDX}.log" \
        || log "  [warn] Task ${TASK_IDX} eval returned non-zero (continuing)"

    # Move rollouts into task video dir (openvla-oft saves to ./rollouts/YYYY_MM_DD/...mp4)
    find "${OFT_DIR}/rollouts" -name "*.mp4" -newer /tmp/oft_task${TASK_IDX}_start.marker \
        -exec mv {} "${VIDEO_DIR}/" \; 2>/dev/null || true
    VIDEO_COUNT=$(find "${VIDEO_DIR}" -name "*.mp4" 2>/dev/null | wc -l)
    log "  Videos collected: ${VIDEO_COUNT}"

    # Parse success rate — openvla-oft logs "Current total success rate: 0.xxx"
    SR=$(grep -oE 'Current total success rate:[[:space:]]+[0-9.]+' \
        "/tmp/oft_task${TASK_IDX}.log" 2>/dev/null | tail -1 | awk '{print $NF}' || echo "unknown")
    log "  success_rate=${SR}"

    {
        echo "suite: ${SUITE}"
        echo "checkpoint: ${CKPT}"
        echo "num_trials_per_task: ${NUM_TRIALS}"
        echo "success_rate: ${SR}"
        echo "description: ${DESCRIPTION}"
    } > "/tmp/oft_task${TASK_IDX}_summary.txt"

    # S3 upload (videos + logs + summary)
    S3_TASK_PREFIX="s3://${S3_BUCKET}/${RUN_ID}/task-${TASK_IDX}"
    log "  S3 upload: ${S3_TASK_PREFIX}"
    UPLOAD_COUNT=0
    while IFS= read -r mp4_file || [[ -n "$mp4_file" ]]; do
        [ -f "$mp4_file" ] || continue
        fname=$(basename "$mp4_file")
        base="${fname%.mp4}"
        # Parse metadata from filename: ...--openvla_oft--episode=N--success=True--task=...
        episode=$(echo "$base" | grep -oE 'episode=[0-9]+' | cut -d= -f2 || echo "?")
        result=$(echo "$base" | grep -oE 'success=(True|False)' | cut -d= -f2 || echo "?")
        task_slug=$(echo "$base" | sed -nE 's/.*--task=(.*)/\1/p')
        language_cmd="${task_slug//_/ }"

        # Context txt
        txt_file="/tmp/oft_ctx_task${TASK_IDX}_ep${UPLOAD_COUNT}.txt"
        {
            echo "=== OpenVLA-OFT Simulation Context ==="
            printf "Video:      %s\n"  "${fname}"
            printf "Date:       %s\n"  "$(date '+%Y-%m-%d')"
            echo ""
            echo "--- Environment ---"
            printf "Suite:      %s\n"  "${SUITE}"
            printf "Task:       %s\n"  "${language_cmd}"
            printf "Robot:      Franka Panda 7-DOF (LIBERO)\n"
            echo ""
            echo "--- Model ---"
            printf "Checkpoint: %s (rev: %s)\n" "${CKPT}" "{{ hf_model_revision[:8] if hf_model_revision else 'unpinned' }}"
            printf "Repo:       https://github.com/moojink/openvla-oft ({{ oft_commit[:8] if oft_commit else 'HEAD' }})\n"
            echo ""
            echo "--- Rollout ---"
            printf "run_id:        %s\n"  "${RUN_ID}"
            printf "task_idx:      %s\n"  "${TASK_IDX}"
            printf "episode:       %s\n"  "${episode}"
            printf "result:        %s\n"  "${result}"
            printf "total_success: %s (suite avg)\n" "${SR}"
            echo ""
            echo "--- Infrastructure ---"
            printf "Instance: %s (%s)\n"  "${INSTANCE_ID}" "${INSTANCE_TYPE}"
            printf "Region:   %s\n"  "${REGION}"
            printf "Stack:    %s (CDK)\n" "${STACK_NAME}"
        } > "$txt_file"

        if aws s3 cp "$mp4_file" "${S3_TASK_PREFIX}/videos/${fname}" \
            --region "$REGION" 2>&1 | tee -a /var/log/openvla-oft-userdata.log; then
            UPLOAD_COUNT=$((UPLOAD_COUNT+1))
            aws s3 cp "$txt_file" "${S3_TASK_PREFIX}/videos/${base}.txt" \
                --region "$REGION" 2>/dev/null || true
        else
            log "  [warn] Upload failed: $fname"
        fi
    done < <(find "$VIDEO_DIR" -name "*.mp4" 2>/dev/null | sort)
    log "  Videos uploaded: ${UPLOAD_COUNT}/${VIDEO_COUNT}"

    aws s3 cp "/tmp/oft_task${TASK_IDX}.log" \
        "${S3_TASK_PREFIX}/eval.log" --region "$REGION" || true
    [ -f "/tmp/oft_task${TASK_IDX}_summary.txt" ] && \
        aws s3 cp "/tmp/oft_task${TASK_IDX}_summary.txt" \
        "${S3_TASK_PREFIX}/summary.txt" --region "$REGION" || true

    SUMMARY_ALL="${SUMMARY_ALL}
[Task $((TASK_IDX+1))] ${SUITE} — success_rate=${SR} (${NUM_TRIALS} trials/task × 10 tasks)"
    log "  Task $((TASK_IDX+1)) done"
done

# ── [6/6] SNS notification + cfn-signal ──────────────────────────
log "[6/6] Sending SNS notification..."

SNS_MESSAGE="[${STACK_NAME}] OpenVLA-OFT simulation complete (RUN_ID: ${RUN_ID})
${SUMMARY_ALL}

Model: OpenVLA-OFT (OFT recipe on OpenVLA-7B base)
Simulation: LIBERO (robosuite + MuJoCo, headless EGL)
Instance: ${INSTANCE_TYPE}

Download results:
  aws s3 sync s3://${S3_BUCKET}/${RUN_ID}/ ./openvla-oft-results/${RUN_ID}/ --region ${REGION}

Teardown:
  python destroy.py --vla openvla-oft"

aws sns publish \
    --topic-arn "$SNS_TOPIC_ARN" \
    --subject "OpenVLA-OFT simulation complete — ${STACK_NAME}" \
    --message "$SNS_MESSAGE" \
    --region "$REGION" \
    || log "[warn] SNS notification failed (continuing)"

log "[6/6] Sending cfn-signal..."
cfn_signal 0

if [ "${AUTO_TERMINATE}" = "true" ]; then
    log "[auto-terminate] Terminating EC2 instance..."
    TOKEN=$(curl -s -X PUT \
        "http://169.254.169.254/latest/api/token" \
        -H "X-aws-ec2-metadata-token-ttl-seconds: 60")
    INSTANCE_ID=$(curl -s \
        -H "X-aws-ec2-metadata-token: $TOKEN" \
        http://169.254.169.254/latest/meta-data/instance-id)
    aws ec2 terminate-instances \
        --instance-ids "$INSTANCE_ID" \
        --region "$REGION" \
        || log "[warn] EC2 terminate failed — please terminate manually"
fi

log "===== OpenVLA-OFT UserData complete ====="
